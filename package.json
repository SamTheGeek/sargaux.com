{
  "name": "sargaux.com",
  "type": "module",
  "version": "1.1.6",
  "scripts": {
    "dev": "astro dev",
    "icons": "tsx scripts/generate-icons.ts",
    "prebuild": "tsx scripts/generate-icons.ts",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "pretest": "bash scripts/ensure-browsers.sh",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:quick": "playwright test tests/accessibility.spec.ts",
    "test:install": "playwright install --with-deps chromium",
    "test:security": "playwright test tests/security.spec.ts tests/security-headers.spec.ts tests/auth.spec.ts tests/auth-unit.spec.ts tests/rate-limit-unit.spec.ts tests/rsvp-api.spec.ts tests/access-control.spec.ts",
    "secret-scan": "bash scripts/secret-scan.sh",
    "gen:lookbook-webp": "tsx scripts/generate-lookbook-webp.ts",
    "verify": "npm run build && npm test"
  },
  "dependencies": {
    "@astrojs/netlify": "^8.1.1",
    "@astrojs/node": "^11.0.2",
    "@netlify/blobs": "^10.7.9",
    "@notionhq/client": "^5.22.0",
    "astro": "^7.0.6",
    "resend": "^6.17.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@netlify/edge-functions": "^3.0.8",
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "^1.61.1",
    "@types/sharp": "^0.32.0",
    "axe-core": "^4.12.1",
    "exifr": "^7.1.3",
    "node-gyp": "^13.0.1",
    "sharp": "^0.35.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
