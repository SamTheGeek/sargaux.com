# Local development defaults (safe to commit)
# Copy these into .env.local and fill the Notion values.

# Feature flags for local RSVP/notion flows
FEATURE_GLOBAL_WEDDING_SITE_ENABLED=true
FEATURE_GLOBAL_NOTION_BACKEND=true
FEATURE_GLOBAL_I18N=true
FEATURE_NYC_RSVP_ENABLED=true
FEATURE_FRANCE_RSVP_ENABLED=true
# Enable DELETE /api/rsvp for local/test cleanup (keep off in production)
FEATURE_GLOBAL_RSVP_DELETE_ENABLED=true
# RSVP preview mock party — deploy-preview only; keep off in production
# FEATURE_NYC_RSVP_PREVIEW=true

# Notion integration (required for dynamic RSVP flows)
NOTION_API_KEY=
NOTION_GUEST_LIST_DB=
NOTION_EVENT_CATALOG_DB=
NOTION_RSVP_RESPONSES_DB=

# Session cookie HMAC (required for login). Generate: openssl rand -hex 32
# Do NOT reuse CALENDAR_HMAC_SECRET.
SESSION_HMAC_SECRET=

# Calendar subscription HMAC (required for personalized .ics URLs)
# Generate: openssl rand -hex 32
CALENDAR_HMAC_SECRET=
# CALENDAR_TEST_MODE=true  # tests only — never enable in production

# Admin / ops Bearer token (protects /api/admin/* and GET /api/warm)
RESEND_ADMIN_SECRET=

# Guest name for local authenticated testing (must match Notion Full Name)
# LOCAL_TESTING_USERNAME=

# Google Maps Static API (for venue map tiles on /nyc/details)
GOOGLE_MAPS_STATIC_API_KEY=

# USPS Business Customer Gateway credentials (for scripts/check-usps-imb-status.mjs)
# Requires IV-MTR access enabled on the BCG account — see that script's header comment.
USPS_BCG_USERNAME=
USPS_BCG_PASSWORD=
# USPS_IV_MTR_ENV=cat
