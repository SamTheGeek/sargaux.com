---
interface Props {
  token?: string | null;
  label: string;
  note?: string;
  unavailableNote?: string;
  showNote?: boolean;
  compact?: boolean;
  testId?: string;
}

const {
  token = null,
  label,
  note = '',
  unavailableNote = '',
  showNote = true,
  compact = false,
  testId,
} = Astro.props;
---

<section class:list={['calendar-subscribe', compact && 'calendar-subscribe--compact']}>
  {token ? (
    <a
      href={`webcal://sargaux.com/api/calendar/${token}.ics`}
      class:list={['calendar-btn', !showNote && 'calendar-btn--standalone']}
      data-testid={testId}
    >
      {label}
    </a>
  ) : (
    <button class:list={['calendar-btn', !showNote && 'calendar-btn--standalone']} type="button" disabled data-testid={testId}>
      {label}
    </button>
  )}
  {showNote && (
    <p class="calendar-note">
      {token ? note : unavailableNote}
    </p>
  )}
</section>

<style>
  .calendar-subscribe {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .calendar-subscribe--compact {
    margin-bottom: 1.5rem;
  }

  .calendar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    min-height: 44px;
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    line-height: 1;
    background: var(--color-accent);
    color: var(--color-surface-text);
    border: none;
    cursor: pointer;
    margin-bottom: 0.5rem;
    text-decoration: none;
  }

  .calendar-btn--standalone {
    margin-bottom: 0;
  }

  .calendar-btn:hover:not(:disabled) {
    background: var(--color-accent);
    color: var(--color-surface-text);
    opacity: 0.85;
  }

  .calendar-btn:disabled {
    background: color-mix(in srgb, var(--color-accent) 42%, white);
    color: var(--color-surface-text);
    cursor: not-allowed;
    opacity: 1;
  }

  .calendar-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }
</style>
