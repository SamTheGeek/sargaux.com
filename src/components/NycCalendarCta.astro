---
interface Props {
  token?: string | null;
  label: string;
  note?: string;
  unavailableNote?: string;
  showNote?: boolean;
  compact?: boolean;
  testId?: string;
}

const {
  token = null,
  label,
  note = '',
  unavailableNote = '',
  showNote = true,
  compact = false,
  testId,
} = Astro.props;
---

<div
  class:list={['details-calendar-inline', compact && 'details-calendar-inline--compact']}
  style="text-align:center"
>
  {token ? (
    <a
      href={`webcal://sargaux.com/api/calendar/${token}.ics`}
      class="details-calendar-btn"
      data-testid={testId}
    >
      {label}
    </a>
  ) : (
    <button class="details-calendar-btn" type="button" disabled data-testid={testId}>
      {label}
    </button>
  )}
  {showNote && (
    <p class="details-calendar-note">
      {token ? note : unavailableNote}
    </p>
  )}
</div>

<style>
  .details-calendar-inline {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    width: 100%;
    align-items: center;
    gap: 10px;
  }

  .details-calendar-inline--compact {
    margin-top: 0;
  }

  .details-calendar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 12px 32px;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    background: var(--color-burnt-amber);
    color: var(--color-warm-cream);
    font-style: normal;
    line-height: 1;
    border: none;
    transition: opacity 0.15s;
  }

  .details-calendar-btn:hover {
    opacity: 0.82;
    color: var(--color-warm-cream);
  }

  .details-calendar-btn:disabled {
    opacity: 0.42;
    cursor: not-allowed;
  }

  .details-calendar-note {
    margin: 0;
    font-size: var(--font-size-caption);
    color: rgba(255, 249, 240, 0.55);
    text-align: center;
  }

  @media (max-width: 768px) {
    .details-calendar-inline {
      margin-top: 24px;
    }

    .details-calendar-inline--compact {
      margin-top: 0;
    }

    .details-calendar-note {
      max-width: 320px;
    }
  }
</style>
