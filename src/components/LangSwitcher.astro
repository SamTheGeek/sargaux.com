---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const enUrl = new URL(Astro.url);
enUrl.searchParams.set('lang', 'en');
const frUrl = new URL(Astro.url);
frUrl.searchParams.set('lang', 'fr');
---

<div class="lang-switcher" aria-label="Language">
  <a
    href={enUrl.pathname + enUrl.search}
    class:list={['flag-btn', 'flag-btn-us', { active: lang === 'en' }]}
    title="English"
    aria-label="Switch to English"
    aria-current={lang === 'en' ? 'true' : undefined}
  >
    <span class="flag flag-us" aria-hidden="true">
      <span class="flag-us-stripes"></span>
      <span class="flag-us-canton"></span>
    </span>
  </a>
  <a
    href={frUrl.pathname + frUrl.search}
    class:list={['flag-btn', 'flag-btn-fr', { active: lang === 'fr' }]}
    title="Français"
    aria-label="Passer en français"
    aria-current={lang === 'fr' ? 'true' : undefined}
  >
    <span class="flag flag-fr" aria-hidden="true">
      <span class="flag-fr-blue"></span>
      <span class="flag-fr-white"></span>
      <span class="flag-fr-red"></span>
    </span>
  </a>
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .flag-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    text-decoration: none;
    border: 1.5px solid transparent;
    opacity: 0.45;
    transition: opacity 0.15s, border-color 0.15s, transform 0.15s;
    cursor: pointer;
    overflow: hidden;
  }

  .flag-btn.active {
    opacity: 1;
    border-color: var(--color-border);
  }

  .flag-btn:not(.active):hover {
    opacity: 0.75;
    transform: translateY(-1px);
  }

  .flag {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
  }

  .flag-fr {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    background: #f1ece3;
  }

  .flag-fr-blue {
    background: #1b3a6b;
  }

  .flag-fr-white {
    background: #f8f4ed;
  }

  .flag-fr-red {
    background: #d96a1e;
  }

  .flag-us {
    background:
      repeating-linear-gradient(
        to bottom,
        #f6f1e8 0 8%,
        #f6f1e8 8% 15%,
        #c74b34 15% 23%
      );
  }

  .flag-us-stripes {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        to bottom,
        #f6f1e8 0 10%,
        #f6f1e8 10% 18%,
        #c74b34 18% 26%
      );
  }

  .flag-us-canton {
    position: absolute;
    top: 0;
    left: 0;
    width: 54%;
    height: 54%;
    background:
      radial-gradient(circle at 26% 28%, rgba(241, 236, 227, 0.9) 0 8%, transparent 9%),
      radial-gradient(circle at 52% 44%, rgba(241, 236, 227, 0.8) 0 7%, transparent 8%),
      radial-gradient(circle at 74% 24%, rgba(241, 236, 227, 0.9) 0 6%, transparent 7%),
      #1b3a6b;
  }
</style>
