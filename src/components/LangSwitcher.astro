---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const enUrl = new URL(Astro.url);
enUrl.searchParams.set('lang', 'en');
const frUrl = new URL(Astro.url);
frUrl.searchParams.set('lang', 'fr');
const usStripeRows = Array.from({ length: 13 }, (_, index) => index);
---

<div class="lang-switcher" aria-label="Language">
  <a
    href={enUrl.pathname + enUrl.search}
    data-astro-history="replace"
    class:list={['flag-btn', 'flag-btn-us', { active: lang === 'en' }]}
    title="English"
    aria-label="Switch to English"
    aria-current={lang === 'en' ? 'true' : undefined}
  >
    <span class="flag flag-us" aria-hidden="true">
      <span class="flag-us-stripes">
        {usStripeRows.map((stripe) => (
          <span class="flag-us-stripe" data-stripe={stripe}></span>
        ))}
      </span>
      <span class="flag-us-canton"></span>
    </span>
  </a>
  <a
    href={frUrl.pathname + frUrl.search}
    data-astro-history="replace"
    class:list={['flag-btn', 'flag-btn-fr', { active: lang === 'fr' }]}
    title="Français"
    aria-label="Passer en français"
    aria-current={lang === 'fr' ? 'true' : undefined}
  >
    <span class="flag flag-fr" aria-hidden="true">
      <span class="flag-fr-blue"></span>
      <span class="flag-fr-white"></span>
      <span class="flag-fr-red"></span>
    </span>
  </a>
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .flag-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    text-decoration: none;
    border: 1.5px solid transparent;
    opacity: 0.45;
    transition: opacity 0.15s, border-color 0.15s, transform 0.15s;
    cursor: pointer;
    overflow: hidden;
  }

  .flag-btn.active {
    opacity: 1;
    border-color: var(--color-border);
  }

  .flag-btn:not(.active):hover {
    opacity: 0.75;
    transform: translateY(-1px);
  }

  .flag {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
  }

  .flag-fr {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    background: var(--color-warm-cream);
  }

  .flag-fr-blue {
    background: var(--color-prussian-blue);
  }

  .flag-fr-white {
    background: var(--color-warm-cream);
  }

  .flag-fr-red {
    background: var(--color-flag-fr-red);
  }

  .flag-us {
    background: var(--color-flag-us-red);
  }

  .flag-us-stripes {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: repeat(13, 1fr);
  }

  .flag-us-stripe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    background: var(--color-warm-cream);
  }

  .flag-us-stripe:nth-child(odd) {
    background: var(--color-flag-us-red);
  }

  .flag-us-canton {
    position: absolute;
    top: 0;
    left: 0;
    width: 54%;
    height: 54%;
    background:
      radial-gradient(circle at 12% 14%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 32% 14%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 52% 14%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 72% 14%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 22% 29%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 42% 29%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 62% 29%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 82% 29%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 12% 44%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 32% 44%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 52% 44%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 72% 44%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 22% 59%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 42% 59%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 62% 59%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 82% 59%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 12% 74%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 32% 74%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 52% 74%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 72% 74%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 22% 89%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 42% 89%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 62% 89%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      radial-gradient(circle at 82% 89%, var(--color-flag-us-stars) 0 5%, transparent 5.8%),
      var(--color-prussian-blue);
  }
</style>
