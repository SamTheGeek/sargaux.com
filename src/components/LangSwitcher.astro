---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const enUrl = new URL(Astro.url);
enUrl.searchParams.set('lang', 'en');
const frUrl = new URL(Astro.url);
frUrl.searchParams.set('lang', 'fr');
---

<div class="lang-switcher" aria-label="Language">
  <a
    href={enUrl.pathname + enUrl.search}
    data-astro-history="replace"
    class:list={['flag-btn', 'flag-btn-us', { active: lang === 'en' }]}
    title="English"
    aria-label="Switch to English"
    aria-current={lang === 'en' ? 'true' : undefined}
  >
    <span class="flag flag-us" aria-hidden="true">
      <span class="flag-us-canton"></span>
    </span>
  </a>
  <a
    href={frUrl.pathname + frUrl.search}
    data-astro-history="replace"
    class:list={['flag-btn', 'flag-btn-fr', { active: lang === 'fr' }]}
    title="Français"
    aria-label="Passer en français"
    aria-current={lang === 'fr' ? 'true' : undefined}
  >
    <span class="flag flag-fr" aria-hidden="true">
      <span class="flag-fr-blue"></span>
      <span class="flag-fr-white"></span>
      <span class="flag-fr-red"></span>
    </span>
  </a>
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .flag-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    text-decoration: none;
    border: none;
    /* box-shadow on the element itself is not clipped by overflow:hidden */
    box-shadow: 0 0 0 0 transparent;
    opacity: 0.45;
    overflow: hidden;
    transition: opacity 0.15s, box-shadow 0.15s, transform 0.15s;
    cursor: pointer;
  }

  .flag-btn.active {
    opacity: 1;
    /* --color-text is dark-moss in light mode, warm-cream in dark mode — always high contrast */
    box-shadow: 0 0 0 2px var(--color-text);
  }

  .flag-btn:not(.active):hover {
    opacity: 0.75;
    transform: translateY(-1px);
  }

  /* Single clipping context — .flag-btn owns border-radius + overflow:hidden.
     No border-radius/overflow on .flag avoids double-clipping antialiasing. */
  .flag {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ── French flag ─────────────────────── */

  .flag-fr {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    height: 100%;
  }

  .flag-fr-blue {
    background: var(--color-prussian-blue);
  }

  .flag-fr-white {
    background: var(--color-warm-cream);
  }

  .flag-fr-red {
    background: var(--color-burgundy-red);
  }

  /* ── US flag ─────────────────────────── */

  /* repeating-linear-gradient gives mathematically equal stripes at any size,
     avoiding the subpixel rounding issues that 13 separate DOM elements have. */
  .flag-us {
    background-image: repeating-linear-gradient(
      to bottom,
      var(--color-burgundy-red) 0 calc(100% / 13),
      var(--color-warm-cream) calc(100% / 13) calc(200% / 13)
    );
  }

  .flag-us-canton {
    position: absolute;
    top: 0;
    left: 0;
    width: 54%;
    height: 54%;
    background:
      /* 1px fixed radius — all stars identical size regardless of gradient origin position */
      radial-gradient(circle at 12% 14%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 32% 14%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 52% 14%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 72% 14%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 22% 29%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 42% 29%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 62% 29%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 82% 29%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 12% 44%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 32% 44%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 52% 44%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 72% 44%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 22% 59%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 42% 59%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 62% 59%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 82% 59%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 12% 74%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 32% 74%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 52% 74%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 72% 74%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 22% 89%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 42% 89%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 62% 89%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      radial-gradient(circle at 82% 89%, var(--color-flag-us-stars) 0 0.75px, transparent 1.125px),
      var(--color-prussian-blue);
  }
</style>
