---
import { ClientRouter } from 'astro:transitions';
import faviconLight from '../assets/common/favicon.svg?url';
import faviconDark from '../assets/common/favicon-dark.svg?url';

interface Props {
  title: string;
  description?: string;
  event?: 'nyc' | 'france';
  page?: string;
  fullTitle?: string;
}

const { title, description = 'Wedding website for Sam & Margaux', event, page, fullTitle } = Astro.props;
const lang = Astro.locals.lang ?? 'en';
---

<!DOCTYPE html>
<html lang={lang} data-event={event} data-page={page}>
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href={faviconLight} media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href={faviconDark} media="(prefers-color-scheme: dark)" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    {(event === 'nyc' || !event) && (
      <>
        <link rel="preload" href="/fonts/helvetica-now/HelveticaNowDisplay-Medium.ttf" as="font" type="font/ttf" crossorigin />
      </>
    )}
    {event === 'france' && (
      <>
        <link rel="preload" href="/fonts/peignot-bold.otf" as="font" type="font/otf" crossorigin />
        <link rel="preload" href="/fonts/futura/FuturaPTMedium.otf" as="font" type="font/otf" crossorigin />
      </>
    )}
    <ClientRouter />
    <script>
      // Disc transition rules:
      //
      // Sub-pages (details, travel) have NO transition:name on their .nyc-disc.
      // This keeps the disc in the root VT group so it never gets its own
      // group at z:20 and floats above page content during navigation.
      //
      // Forward nav (/nyc → sub-page):
      //   The /nyc index disc DOES have transition:name="event-disc". We
      //   suppress it in astro:after-preparation (before the VT snapshot) so
      //   the old disc also stays in the root group. Both snapshots then show
      //   the disc correctly behind content — no pop.
      //
      // Backward nav (sub-page → /nyc):
      //   We restore view-transition-name="event-disc" on the sub-page disc
      //   in astro:after-preparation so the VT can FLIP it back to /nyc.
      //
      // Any nav TO /nyc:
      //   The skyline (z:3 in DOM) would sit behind the disc's VT group
      //   (z:20). astro:before-swap injects view-transition-name "nyc-skyline"
      //   onto the incoming skyline element, giving it z:22 for the animation.
      if (!window.__sargauxDiscTransitionSetup) {
        window.__sargauxDiscTransitionSetup = true;

        document.addEventListener('astro:after-preparation', (e) => {
          const from = e.from.pathname.replace(/\/$/, '');
          const to   = e.to.pathname.replace(/\/$/, '');
          const fromDepth = from.split('/').length;
          const toDepth   = to.split('/').length;

          const suppress = (el) => el?.style.setProperty('view-transition-name', 'none');
          const suppressHeader = (doc) => {
            suppress(doc?.querySelector('.site-logo'));
            suppress(doc?.querySelector('.event-toggle'));
            suppress(doc?.querySelector('.nyc-rsvp-btn'));
          };

          if (toDepth > fromDepth) {
            // Forward nav into a sub-page: suppress disc + header children on
            // both old AND new documents so nothing gets an orphaned VT group.
            // All content cross-fades together as a single root unit.
            suppress(document.querySelector('.nyc-disc'));
            suppressHeader(document);
            suppressHeader(e.newDocument);
          } else if (to === '/nyc' && from.startsWith('/nyc/')) {
            // Backward nav to /nyc: restore disc name on the sub-page so the
            // VT can FLIP it back. Suppress header children on the NEW /nyc
            // document so they stay in the root group for a unified page fade.
            document.querySelector('.nyc-disc')?.style.setProperty('view-transition-name', 'event-disc');
            suppressHeader(e.newDocument);
          } else if (from.startsWith('/nyc/') && to.startsWith('/nyc/')) {
            // Sibling sub-page nav (e.g. rsvp ↔ details ↔ travel): suppress
            // everything on the old page for a clean root cross-fade.
            suppress(document.querySelector('.nyc-disc'));
            suppressHeader(document);
          }
        });

        document.addEventListener('astro:before-swap', (event) => {
          if (event.to?.pathname?.replace(/\/$/, '') === '/nyc') {
            event.newDocument.querySelector('.nyc-skyline-wrap')?.style.setProperty('view-transition-name', 'nyc-skyline');
            event.viewTransition?.ready?.finally(() => {
              document.querySelector('.nyc-skyline-wrap')?.style.removeProperty('view-transition-name');
            });
          }
        });
      }

      if (!window.__sargauxLangTransitionSetup) {
        window.__sargauxLangTransitionSetup = true;

        const normalizeSearch = (url) => {
          const params = [...url.searchParams.entries()]
            .filter(([key]) => key !== 'lang')
            .sort(([aKey, aValue], [bKey, bValue]) => {
              if (aKey === bKey) return aValue.localeCompare(bValue);
              return aKey.localeCompare(bKey);
            });

          return new URLSearchParams(params).toString();
        };

        const isLanguageOnlyNavigation = (from, to) => {
          if (from.origin !== to.origin) return false;
          if (from.pathname !== to.pathname) return false;
          if (from.hash !== to.hash) return false;

          const fromLang = from.searchParams.get('lang') ?? 'en';
          const toLang = to.searchParams.get('lang') ?? 'en';
          if (fromLang === toLang) return false;

          return normalizeSearch(from) === normalizeSearch(to);
        };

        document.addEventListener('astro:before-swap', (event) => {
          if (!isLanguageOnlyNavigation(event.from, event.to)) return;
          event.viewTransition.skipTransition();
        });
      }
    </script>
    <title>{fullTitle ?? `${title} | Chez Sargaux`}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/base.css';

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
    font-family: var(--font-body);
  }

  body {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: var(--line-height-body);
  }

  /* ── NYC sub-page z-ordering ────────────────────────────────────────────────
   * These positioning rules live in the layout (shared CSS bundle) so the
   * stacking hierarchy is correct immediately after a SPA DOM swap, before
   * the incoming page's own CSS file has finished loading.
   * Visual styles (size, color, coordinates) remain in the page-specific files.
   *
   * NOTE: No [data-page] qualifier here — data-page is written to <html>
   * during the DOM swap and may not be present when these rules first need to
   * apply. The class names themselves are sufficient scope:
   *   .details-hero / .details-band  only exist on sub-pages
   *   .nyc-moss                       also on index, but already z:4 there
   */
  html[data-event="nyc"] .nyc-disc {
    position: fixed;
    z-index: 2;
  }

  html[data-event="nyc"] .details-hero {
    position: relative;
    z-index: 3;
  }

  html[data-event="nyc"] .nyc-moss,
  html[data-event="nyc"] .details-band {
    position: relative;
    z-index: 4;
  }

  /* Content box styling (legacy — use .card for new code) */
  .content-box {
    border: var(--border-hairline);
    padding: var(--space-md);
    background: var(--color-surface);
    color: var(--color-surface-text);
  }

  .content-box h3 {
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    color: var(--color-surface-text);
    margin-bottom: var(--space-xs);
  }

</style>
