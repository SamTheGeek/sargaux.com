---
import { ClientRouter } from 'astro:transitions';
import faviconLight from '../assets/common/favicon.svg?url';
import faviconDark from '../assets/common/favicon-dark.svg?url';

interface Props {
  title: string;
  description?: string;
  event?: 'nyc' | 'france';
  page?: string;
  fullTitle?: string;
}

const { title, description = 'Wedding website for Sam & Margaux', event, page, fullTitle } = Astro.props;
const lang = Astro.locals.lang ?? 'en';
---

<!DOCTYPE html>
<html lang={lang} data-event={event} data-page={page}>
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href={faviconLight} media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href={faviconDark} media="(prefers-color-scheme: dark)" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    {(event === 'nyc' || !event) && (
      <>
        <link rel="preload" href="/fonts/helvetica-now/HelveticaNowDisplay-Medium.ttf" as="font" type="font/ttf" crossorigin />
      </>
    )}
    {event === 'france' && (
      <>
        <link rel="preload" href="/fonts/peignot-bold.otf" as="font" type="font/otf" crossorigin />
        <link rel="preload" href="/fonts/futura/FuturaPTMedium.otf" as="font" type="font/otf" crossorigin />
      </>
    )}
    <ClientRouter />
    <script>
      // Page transition rules:
      //
      // In Astro 6, astro:after-preparation fires as a PLAIN Event (no from/to/
      // newDocument). Navigation data is only available on astro:before-preparation
      // (TransitionBeforePreparationEvent) and astro:before-swap
      // (TransitionBeforeSwapEvent). We cache from/to on before-preparation and
      // use that cache in after-preparation.
      //
      // Disc z-ordering is handled entirely by CSS:
      //   ::view-transition-group(root)       { z-index: 1 }
      //   ::view-transition-group(event-disc) { z-index: 0 }
      // This forces the disc VT group below the root group on every transition,
      // so the disc never floats over page content. The VT system leaves
      // transparent holes in root screenshots at each named element's captured
      // position — the disc slides through those holes, visible at its start and
      // end positions, without obscuring content.
      //
      // Header children (site-logo, event-toggle, nyc-rsvp-btn) have named VTs
      // only on /nyc/index, not on sub-pages. For any /nyc sub-page navigation
      // we suppress those names on BOTH the old page and the incoming document
      // to prevent one-sided orphaned VT groups that would fade independently.
      //
      // Any nav TO /nyc:
      //   before-swap injects view-transition-name "nyc-skyline" onto the
      //   incoming skyline element for its fade-in animation.
      if (!window.__sargauxDiscTransitionSetup) {
        window.__sargauxDiscTransitionSetup = true;

        let _navFrom = null;
        let _navTo   = null;

        // Cache navigation URLs from the only event that carries them.
        document.addEventListener('astro:before-preparation', (e) => {
          _navFrom = e.from;
          _navTo   = e.to;
        });

        // Suppress header children on the OLD page before the VT snapshot.
        document.addEventListener('astro:after-preparation', () => {
          const from      = _navFrom?.pathname?.replace(/\/$/, '') ?? '';
          const to        = _navTo?.pathname?.replace(/\/$/, '')   ?? '';
          const fromDepth = from.split('/').length;
          const toDepth   = to.split('/').length;

          const suppress = (el) => el?.style.setProperty('view-transition-name', 'none');
          const suppressHeader = () => {
            suppress(document.querySelector('.site-logo'));
            suppress(document.querySelector('.event-toggle'));
            suppress(document.querySelector('.nyc-rsvp-btn'));
          };

          const isNycSubpageNav =
            (toDepth > fromDepth && from.startsWith('/nyc')) ||
            (to === '/nyc' && from.startsWith('/nyc/')) ||
            (from.startsWith('/nyc/') && to.startsWith('/nyc/'));

          if (isNycSubpageNav) {
            suppressHeader();
          }
        });

        // Suppress header children on the NEW document, and handle skyline.
        // before-swap fires inside startViewTransition's callback — after the
        // old snapshot, before the new snapshot.
        document.addEventListener('astro:before-swap', (event) => {
          const from      = event.from?.pathname?.replace(/\/$/, '') ?? '';
          const to        = event.to?.pathname?.replace(/\/$/, '')   ?? '';
          const fromDepth = from.split('/').length;
          const toDepth   = to.split('/').length;

          const suppress = (el) => el?.style.setProperty('view-transition-name', 'none');
          const suppressHeaderOnDoc = (doc) => {
            suppress(doc?.querySelector('.site-logo'));
            suppress(doc?.querySelector('.event-toggle'));
            suppress(doc?.querySelector('.nyc-rsvp-btn'));
          };

          const isNycSubpageNav =
            (toDepth > fromDepth && from.startsWith('/nyc')) ||
            (to === '/nyc' && from.startsWith('/nyc/')) ||
            (from.startsWith('/nyc/') && to.startsWith('/nyc/'));

          if (isNycSubpageNav) {
            suppressHeaderOnDoc(event.newDocument);
          }

          // Skyline fade-in when arriving at /nyc.
          if (to === '/nyc') {
            event.newDocument.querySelector('.nyc-skyline-wrap')?.style.setProperty('view-transition-name', 'nyc-skyline');
            event.viewTransition?.ready?.finally(() => {
              document.querySelector('.nyc-skyline-wrap')?.style.removeProperty('view-transition-name');
            });
          }
        });
      }

      if (!window.__sargauxLangTransitionSetup) {
        window.__sargauxLangTransitionSetup = true;

        const normalizeSearch = (url) => {
          const params = [...url.searchParams.entries()]
            .filter(([key]) => key !== 'lang')
            .sort(([aKey, aValue], [bKey, bValue]) => {
              if (aKey === bKey) return aValue.localeCompare(bValue);
              return aKey.localeCompare(bKey);
            });

          return new URLSearchParams(params).toString();
        };

        const isLanguageOnlyNavigation = (from, to) => {
          if (from.origin !== to.origin) return false;
          if (from.pathname !== to.pathname) return false;
          if (from.hash !== to.hash) return false;

          const fromLang = from.searchParams.get('lang') ?? 'en';
          const toLang = to.searchParams.get('lang') ?? 'en';
          if (fromLang === toLang) return false;

          return normalizeSearch(from) === normalizeSearch(to);
        };

        document.addEventListener('astro:before-swap', (event) => {
          if (!isLanguageOnlyNavigation(event.from, event.to)) return;
          event.viewTransition.skipTransition();
        });
      }
    </script>
    <title>{fullTitle ?? `${title} | Chez Sargaux`}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/base.css';

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
    font-family: var(--font-body);
  }

  body {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: var(--line-height-body);
  }

  /* ── View-transition disc z-ordering ───────────────────────────────────────
   * The root VT group must render above the disc so the disc never floats over
   * page content during a transition. Without overrides, the disc's page
   * z-index (2) would make its VT group render above the root group (z:auto),
   * which causes the disc to obscure text and UI elements mid-animation.
   *
   * Setting root to z:1 and the disc group to z:0 fixes this. The disc still
   * animates (FLIPs between pages) — it's visible through the transparent holes
   * the VT system leaves in root screenshots at the disc's captured position.
   */
  ::view-transition-group(root) {
    z-index: 1;
  }
  ::view-transition-group(event-disc) {
    z-index: 0;
  }

  /* ── NYC sub-page z-ordering ────────────────────────────────────────────────
   * These positioning rules live in the layout (shared CSS bundle) so the
   * stacking hierarchy is correct immediately after a SPA DOM swap, before
   * the incoming page's own CSS file has finished loading.
   * Visual styles (size, color, coordinates) remain in the page-specific files.
   *
   * NOTE: No [data-page] qualifier here — data-page is written to <html>
   * during the DOM swap and may not be present when these rules first need to
   * apply. The class names themselves are sufficient scope:
   *   .details-hero / .details-band  only exist on sub-pages
   *   .nyc-moss                       also on index, but already z:4 there
   */
  html[data-event="nyc"] .nyc-disc {
    position: fixed;
    z-index: 2;
  }

  html[data-event="nyc"] .details-hero {
    position: relative;
    z-index: 3;
  }

  html[data-event="nyc"] .nyc-moss,
  html[data-event="nyc"] .details-band {
    position: relative;
    z-index: 4;
  }

  /* Content box styling (legacy — use .card for new code) */
  .content-box {
    border: var(--border-hairline);
    padding: var(--space-md);
    background: var(--color-surface);
    color: var(--color-surface-text);
  }

  .content-box h3 {
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    color: var(--color-surface-text);
    margin-bottom: var(--space-xs);
  }

</style>
