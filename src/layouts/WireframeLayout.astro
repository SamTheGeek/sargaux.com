---
import { ClientRouter } from 'astro:transitions';
import faviconLight from '../assets/common/favicon.svg?url';
import faviconDark from '../assets/common/favicon-dark.svg?url';

interface Props {
  title: string;
  description?: string;
  event?: 'nyc' | 'france';
  page?: string;
  fullTitle?: string;
}

const { title, description = 'Wedding website for Sam & Margaux', event, page, fullTitle } = Astro.props;
const lang = Astro.locals.lang ?? 'en';
---

<!DOCTYPE html>
<html lang={lang} data-event={event} data-page={page}>
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href={faviconLight} media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href={faviconDark} media="(prefers-color-scheme: dark)" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    {(event === 'nyc' || !event) && (
      <>
        <link rel="preload" href="/fonts/helvetica-now/HelveticaNowDisplay-Medium.ttf" as="font" type="font/ttf" crossorigin />
      </>
    )}
    {event === 'france' && (
      <>
        <link rel="preload" href="/fonts/peignot-bold.otf" as="font" type="font/otf" crossorigin />
        <link rel="preload" href="/fonts/futura/FuturaPTMedium.otf" as="font" type="font/otf" crossorigin />
      </>
    )}
    <ClientRouter />
    <script>
      // Disc transition rules:
      //
      // Forward nav (e.g. /nyc → /nyc/travel, toDepth > fromDepth):
      //   Suppress disc on OLD page only — disc enters on sub-page without a FLIP.
      //
      // Cross-area nav (e.g. /france → /nyc, toIsNycIndex && !fromIsNycArea):
      //   Suppress disc on BOTH old and new pages. The ::view-transition overlay
      //   sits above the entire DOM, so any disc VT pseudo-element would appear
      //   above the skyline (z:3 in DOM). With disc fully suppressed it renders
      //   at z:2 in normal flow — always below the skyline — from the first frame.
      //
      // Backward nav (e.g. /nyc/rsvp → /nyc, toIsNycIndex && fromIsNycArea):
      //   Keep the disc FLIP. Skyline is absent from the old (sub-)page, so it
      //   only appears in the new-page capture. We give it view-transition-name
      //   "nyc-skyline" in astro:before-swap so it gets its own VT group at
      //   z:22 — above the disc (z:20) and below the header (z:120) — for the
      //   duration of the FLIP animation.
      if (!window.__sargauxDiscTransitionSetup) {
        window.__sargauxDiscTransitionSetup = true;

        document.addEventListener('astro:after-preparation', (e) => {
          const fromDepth = e.from.pathname.replace(/\/$/, '').split('/').length;
          const toDepth = e.to.pathname.replace(/\/$/, '').split('/').length;
          const toIsNycIndex = e.to.pathname.replace(/\/$/, '') === '/nyc';
          const fromIsNycArea = e.from.pathname.startsWith('/nyc');
          if (toDepth > fromDepth || (toIsNycIndex && !fromIsNycArea)) {
            document.querySelector('.nyc-disc')?.style.setProperty('view-transition-name', 'none');
          }
        });

        document.addEventListener('astro:before-swap', (event) => {
          const toPath = event.to?.pathname?.replace(/\/$/, '') ?? '';
          const fromIsNycArea = event.from?.pathname?.startsWith('/nyc') ?? false;
          if (toPath === '/nyc') {
            if (!fromIsNycArea) {
              // Cross-area: suppress disc on incoming page too
              event.newDocument.querySelector('.nyc-disc')?.style.setProperty('view-transition-name', 'none');
            } else {
              // Backward nav: give skyline a VT group so it stays above the disc FLIP
              event.newDocument.querySelector('.nyc-skyline-wrap')?.style.setProperty('view-transition-name', 'nyc-skyline');
            }
          }
        });

        document.addEventListener('astro:page-load', () => {
          document.querySelector('.nyc-disc')?.style.removeProperty('view-transition-name');
          document.querySelector('.nyc-skyline-wrap')?.style.removeProperty('view-transition-name');
        });
      }

      if (!window.__sargauxLangTransitionSetup) {
        window.__sargauxLangTransitionSetup = true;

        const normalizeSearch = (url) => {
          const params = [...url.searchParams.entries()]
            .filter(([key]) => key !== 'lang')
            .sort(([aKey, aValue], [bKey, bValue]) => {
              if (aKey === bKey) return aValue.localeCompare(bValue);
              return aKey.localeCompare(bKey);
            });

          return new URLSearchParams(params).toString();
        };

        const isLanguageOnlyNavigation = (from, to) => {
          if (from.origin !== to.origin) return false;
          if (from.pathname !== to.pathname) return false;
          if (from.hash !== to.hash) return false;

          const fromLang = from.searchParams.get('lang') ?? 'en';
          const toLang = to.searchParams.get('lang') ?? 'en';
          if (fromLang === toLang) return false;

          return normalizeSearch(from) === normalizeSearch(to);
        };

        document.addEventListener('astro:before-swap', (event) => {
          if (!isLanguageOnlyNavigation(event.from, event.to)) return;
          event.viewTransition.skipTransition();
        });
      }
    </script>
    <title>{fullTitle ?? `${title} | Chez Sargaux`}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/base.css';

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
    font-family: var(--font-body);
  }

  body {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: var(--line-height-body);
  }

  /* Content box styling (legacy — use .card for new code) */
  .content-box {
    border: var(--border-hairline);
    padding: var(--space-md);
    background: var(--color-surface);
    color: var(--color-surface-text);
  }

  .content-box h3 {
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    color: var(--color-surface-text);
    margin-bottom: var(--space-xs);
  }

</style>
