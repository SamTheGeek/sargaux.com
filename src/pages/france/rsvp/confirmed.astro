---
import WireframeLayout from '../../../layouts/WireframeLayout.astro';
import { getGuestParty, getGuestEvents, getLatestRSVP } from '../../../lib/notion';
import { generateTokenIfPossible } from '../../../lib/calendar';
import { getAttendingNames, redactEmail } from '../../../lib/rsvp-display';
import { strings } from '../../../content/strings';
import { createTranslator } from '../../../lib/i18n';
import LangSwitcher from '../../../components/LangSwitcher.astro';
import type { GuestRecord } from '../../../types/guest';
import type { EventRecord } from '../../../types/event';

const guest = Astro.locals.guest ?? 'Guest';
const guestId = Astro.locals.guestId;
const lang = Astro.locals.lang ?? 'en';
const t = createTranslator(lang);

let party: GuestRecord[] = [];
let coreEvents: EventRecord[] = [];
let optionalEvents: EventRecord[] = [];
let existingRSVP = null;
let loadError: string | null = null;

if (guestId) {
  try {
    party = await getGuestParty(guestId);
    const events = (await getGuestEvents(guestId)).filter((event) => event.wedding === 'france');
    coreEvents = events.filter((event) => event.type === 'Core');
    optionalEvents = events.filter((event) => event.type === 'Optional');
    existingRSVP = await getLatestRSVP(guestId, 'france');
  } catch (error) {
    console.error('Failed to load France RSVP confirmation data:', error);
    loadError = 'We could not load your RSVP details right now. Please refresh and try again.';
  }
}

const attendingNames = getAttendingNames(existingRSVP);
const selectedEventIds = new Set(existingRSVP?.eventsAttending ?? []);
const details = existingRSVP?.details ?? {};
const calendarToken = existingRSVP ? generateTokenIfPossible(guestId) : null;
const submittedAt = existingRSVP?.submittedAt
  ? new Date(existingRSVP.submittedAt).toLocaleString(lang === 'fr' ? 'fr-FR' : 'en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    })
  : null;

function accommodationLabel(value?: string): string {
  switch (value) {
    case 'yes':
      return t(strings.france.rsvp.form.accommodation.yes);
    case 'no':
      return t(strings.france.rsvp.form.accommodation.no);
    case 'unsure':
      return t(strings.france.rsvp.form.accommodation.unsure);
    default:
      return t(strings.france.rsvp.confirmation.emptyValue);
  }
}

function transportLabel(value?: string): string {
  switch (value) {
    case 'yes':
      return t(strings.france.rsvp.form.transport.yes);
    case 'no':
      return t(strings.france.rsvp.form.transport.no);
    case 'unsure':
      return t(strings.france.rsvp.form.transport.unsure);
    default:
      return t(strings.france.rsvp.confirmation.emptyValue);
  }
}
---

<WireframeLayout title={t(strings.france.rsvp.confirmation.pageTitle)} event="france">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <a href="/france" class="back-link">{t(strings.nav.backToEvent)}</a>
    </nav>
  </header>

  <main>
    <h1>{t(strings.france.rsvp.confirmation.heading)}</h1>
    <p class="subtitle">{t(strings.france.rsvp.confirmation.subtitle)}</p>

    <div class="deadline-banner">
      <p>{t(strings.france.rsvp.deadline)} <strong>{t(strings.france.rsvp.deadlineDate)}</strong></p>
    </div>

    {!guestId ? (
      <div class="error-card" data-testid="notion-required">
        <h2>{t(strings.france.rsvp.unavailable.heading)}</h2>
        <p>{t(strings.france.rsvp.unavailable.text)}</p>
      </div>
    ) : loadError ? (
      <div class="error-card" data-testid="rsvp-load-error">
        <h2>{t(strings.france.rsvp.loadError.heading)}</h2>
        <p>{loadError}</p>
      </div>
    ) : !existingRSVP ? (
      <div class="error-card" data-testid="missing-rsvp">
        <h2>{t(strings.france.rsvp.confirmation.missing.heading)}</h2>
        <p>{t(strings.france.rsvp.confirmation.missing.text)}</p>
      </div>
    ) : (
      <>
        <section class="calendar-subscribe calendar-subscribe--confirmed">
          <p class="section-note">{t(strings.france.schedule.calendarNote)}</p>
          {calendarToken ? (
            <a
              href={`webcal://sargaux.com/api/calendar/${calendarToken}.ics`}
              class="calendar-btn"
              data-testid="calendar-confirmation-link"
            >
              {t(strings.france.schedule.calendarBtn)}
            </a>
          ) : (
            <>
              <button class="calendar-btn" disabled>{t(strings.france.schedule.calendarBtn)}</button>
              <p class="section-note">{t(strings.nyc.calendar.unavailableNote)}</p>
            </>
          )}
        </section>

        <aside class="existing-rsvp-banner" data-testid="existing-rsvp-banner">
          <p>{t(strings.france.rsvp.confirmation.savedLabel)} <strong>{submittedAt}</strong>.</p>
        </aside>

        <section class="form-section">
          <h2>{t(strings.france.rsvp.form.whosComing.heading)}</h2>
          <p class="section-note">{t(strings.france.rsvp.form.whosComing.note)}</p>
          {party.map((partyGuest) => {
            const isAttending = attendingNames.has(partyGuest.name);
            return (
              <div class:list={['guest-row', partyGuest.isPlusOne && 'plus-one']} data-guest-row>
                <span class:list={['guest-indicator', isAttending && 'guest-indicator--attending']}></span>
                <div class="guest-info">
                  <span class="guest-name-static">{partyGuest.name}</span>
                  <span class="guest-status">
                    {isAttending ? t(strings.global.attending) : t(strings.global.notAttending)}
                  </span>
                </div>
              </div>
            );
          })}
        </section>

        <section class="form-section">
          <h2>{t(strings.france.rsvp.form.coreEvents.heading)}</h2>
          <p class="section-note">{t(strings.france.rsvp.form.coreEvents.note)}</p>
          {coreEvents.length === 0 ? (
            <p class="placeholder-note">{t(strings.france.rsvp.form.coreEvents.empty)}</p>
          ) : (
            <div class="event-list">
              {coreEvents.map((event) => {
                const isSelected = selectedEventIds.size > 0
                  ? selectedEventIds.has(event.id)
                  : attendingNames.size > 0;
                return (
                  <div class="event-checkbox event-checkbox--readonly">
                    <span class:list={['checkbox-mark', isSelected && 'checkbox-mark--checked']}></span>
                    <div class="event-details">
                      <strong>{event.name}</strong>
                      <span class="event-info">
                        {[event.time, event.location].filter(Boolean).join(' · ') || t(strings.global.detailsToCome)}
                      </span>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </section>

        {optionalEvents.length > 0 && (
          <section class="form-section">
            <h2>{t(strings.france.rsvp.form.optionalEvents.heading)}</h2>
            <p class="section-note">{t(strings.france.rsvp.form.optionalEvents.note)}</p>
            <div class="event-list">
              {optionalEvents.map((event) => {
                const isSelected = selectedEventIds.has(event.id);
                return (
                  <div class="event-checkbox event-checkbox--readonly optional-event">
                    <span class:list={['checkbox-mark', isSelected && 'checkbox-mark--checked']}></span>
                    <div class="event-details">
                      <strong>{event.name}</strong>
                      <span class="event-info">
                        {[event.time, event.location].filter(Boolean).join(' · ') || t(strings.global.detailsToCome)}
                      </span>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        )}

        <section class="form-section">
          <h2>{t(strings.france.rsvp.form.dietary.heading)}</h2>
          <p class="section-note">{t(strings.france.rsvp.form.dietary.note)}</p>
          <div class="static-card">
            {details.allergens ?? existingRSVP.dietary ?? t(strings.france.rsvp.confirmation.emptyValue)}
          </div>
        </section>

        <section class="form-section two-column">
          <div>
            <h2>{t(strings.france.rsvp.form.accommodation.heading)}</h2>
            <p class="section-note">{t(strings.france.rsvp.form.accommodation.note)}</p>
            <div class="static-card">{accommodationLabel(details.accommodation)}</div>
          </div>

          <div>
            <h2>{t(strings.france.rsvp.form.transport.heading)}</h2>
            <p class="section-note">{t(strings.france.rsvp.form.transport.note)}</p>
            <div class="static-card">{transportLabel(details.transport)}</div>
          </div>
        </section>

        <section class="form-section">
          <h2>{t(strings.france.rsvp.form.message.heading)}</h2>
          <div class="static-card">
            {existingRSVP.message || t(strings.france.rsvp.confirmation.emptyValue)}
          </div>
        </section>

        <section class="form-section">
          <h2>{t(strings.france.rsvp.form.email.heading)}</h2>
          <p class="section-note">{t(strings.france.rsvp.form.email.note)}</p>
          <div class="group-email-list">
            {party.map((partyGuest) => (
              <div class="email-field group-email-row">
                <div class="group-email-label">
                  <span class="group-email-name">{partyGuest.name}</span>
                </div>
                <div class="static-card static-card--email">
                  {redactEmail(partyGuest.email) || t(strings.france.rsvp.confirmation.emailMissing)}
                </div>
              </div>
            ))}
          </div>
        </section>

        <div class="confirmation-actions">
          <a href="/france/rsvp" class="confirmation-edit-link">{t(strings.france.rsvp.confirmation.editLink)}</a>
          <p class="form-note">{t(strings.france.rsvp.form.signedInAs)} <strong>{guest}</strong>. {t(strings.france.rsvp.form.canUpdate)}</p>
        </div>
      </>
    )}
  </main>

  <footer>
    <div class="footer-row">
      <p>{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
  }

  main {
    flex: 1;
    padding: 3rem 2rem;
    max-width: 680px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .deadline-banner {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .existing-rsvp-banner {
    background: var(--color-info-bg);
    border: 1px solid var(--color-info-border);
    padding: 1rem;
    margin-bottom: 1.5rem;
    color: var(--color-info);
  }

  .calendar-subscribe {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .calendar-btn {
    display: inline-block;
    min-height: 44px;
    padding: 0 24px;
    background: var(--color-accent);
    color: var(--color-surface-text);
    border: none;
    cursor: pointer;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    line-height: 44px;
  }

  .calendar-btn:hover {
    color: var(--color-surface-text);
    opacity: 0.85;
  }

  .calendar-btn:disabled {
    background: color-mix(in srgb, var(--color-accent) 42%, white);
    cursor: not-allowed;
    opacity: 1;
  }

  .form-section {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .form-section h2 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .two-column {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .section-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.9rem;
  }

  .guest-row {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.8rem;
    border: 1px solid var(--color-border);
    margin-bottom: 0.75rem;
  }

  .guest-row.plus-one {
    border-style: dashed;
  }

  .guest-indicator {
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  .guest-indicator--attending {
    background: var(--color-text);
  }

  .guest-info {
    display: flex;
    flex: 1;
    align-items: center;
    gap: 0.75rem;
  }

  .guest-name-static {
    flex: 1;
    color: var(--color-text);
  }

  .guest-status {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    min-width: 90px;
    text-align: right;
  }

  .event-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .event-checkbox {
    display: flex;
    align-items: start;
    gap: 0.65rem;
    padding: 0.85rem;
    border: 1px solid var(--color-border);
  }

  .event-checkbox.is-core {
    background: var(--color-bg);
  }

  .checkbox-mark {
    width: 18px;
    height: 18px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin-top: 2px;
    flex-shrink: 0;
    position: relative;
  }

  .checkbox-mark--checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 1px;
    width: 5px;
    height: 10px;
    border: solid var(--color-text);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .event-details strong {
    display: block;
    margin-bottom: 0.1rem;
  }

  .event-info,
  .placeholder-note {
    color: var(--color-text-muted);
    font-size: 0.86rem;
  }

  .static-card {
    width: 100%;
    border: 1px solid var(--color-border);
    padding: 0.7rem 0.75rem;
    font-size: 0.95rem;
    font-family: inherit;
    color: var(--color-text);
    background: var(--color-bg);
    white-space: pre-wrap;
  }

  .static-card--email {
    font-size: 0.95rem;
  }

  .group-email-list {
    display: grid;
    gap: 0.85rem;
    margin-top: 0.35rem;
  }

  .email-field {
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .group-email-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .group-email-name {
    color: var(--color-text);
  }

  .confirmation-actions {
    margin-top: 1rem;
    text-align: center;
  }

  .confirmation-edit-link {
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }

  .confirmation-edit-link:hover {
    color: var(--color-text);
  }

  .form-note {
    margin-top: 0.8rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  .error-card {
    border: 1px solid var(--color-error-border);
    background: var(--color-error-bg);
    padding: 1rem;
    color: var(--color-error);
  }

  footer {
    padding: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }

  .footer-row p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 768px) {
    main {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .guest-info {
      flex-direction: column;
      align-items: start;
    }

    .guest-status {
      min-width: 0;
      text-align: left;
    }

    .two-column {
      grid-template-columns: 1fr;
    }
  }
</style>
