---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import SiteFooter from '../../components/SiteFooter.astro';

const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.france.pageTitle)} fullTitle="Chez Sargaux | France" description="France Wedding - May 2027" event="france">
  <header class="site-header" transition:name="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo" transition:name="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        {showEventToggle && (
          <div class="event-toggle" transition:name="event-toggle">
            <a href="/nyc" class="event-toggle-item event-toggle-item--nyc">{t(strings.global.toggle.nyc)}</a>
            <span class="divider">|</span>
            <span class="active event-toggle-item event-toggle-item--france">{t(strings.global.toggle.france)}</span>
          </div>
        )}
        <a href="/france/rsvp" class="btn btn-primary rsvp-btn" transition:name="header-rsvp">{t(strings.global.rsvpBtn)}</a>
      </div>
    </nav>
  </header>

  <main>

    <!-- Destination Header — travel poster style -->
    <section class="france-hero">
      <div class="destination-header" transition:name="france-index-hero-content">
        <p class="event-location">{t(strings.france.heroLocation)}</p>
        <h1 class="destination-name">{t(strings.france.heroTitle)}</h1>
        <p class="event-dates">{t(strings.france.heroDate)}</p>
        <p class="event-type">{t(strings.france.heroTagline)}</p>
      </div>
      <div class="sun-disc-large" aria-hidden="true" transition:name="event-disc"></div>
    </section>

    <div class="france-index-body" transition:name="france-index-body-content">
    <!-- Band: Programme of Events -->
    <div class="band-header">{t(strings.france.sections.programme)}</div>
    <section class="programme-section page-content">
      <div class="programme-timetable">
        <div class="programme-row">
          <p class="day-label">{t(strings.france.weekend.friday.day)}</p>
          <div class="day-events">
            <div class="event-item">
              <span class="event-time">{t(strings.france.weekend.friday.timeEvening)}</span>
              <span class="event-name">{t(strings.france.weekend.friday.welcomeDinner)}</span>
            </div>
          </div>
        </div>
        <hr class="timetable-rule">
        <div class="programme-row programme-row--main">
          <p class="day-label">{t(strings.france.weekend.saturday.day)}</p>
          <div class="day-events">
            <div class="event-item">
              <span class="event-time">{t(strings.france.weekend.saturday.timeMorning)}</span>
              <span class="event-name">{t(strings.france.weekend.saturday.breakfast)}</span>
            </div>
            <div class="event-item">
              <span class="event-time">{t(strings.france.weekend.saturday.timeAfternoon)}</span>
              <span class="event-name">{t(strings.france.weekend.saturday.ceremony)}</span>
            </div>
            <div class="event-item">
              <span class="event-time">{t(strings.france.weekend.saturday.timeEvening)}</span>
              <span class="event-name">{t(strings.france.weekend.saturday.reception)}</span>
            </div>
          </div>
        </div>
        <hr class="timetable-rule">
        <div class="programme-row">
          <p class="day-label">{t(strings.france.weekend.sunday.day)}</p>
          <div class="day-events">
            <div class="event-item">
              <span class="event-time">{t(strings.france.weekend.sunday.timeMorning)}</span>
              <span class="event-name">{t(strings.france.weekend.sunday.breakfast)}</span>
            </div>
            <div class="event-item">
              <span class="event-time">{t(strings.france.weekend.sunday.timeMidday)}</span>
              <span class="event-name">{t(strings.france.weekend.sunday.farewellBrunch)}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Band: The Details -->
    <div class="band-header">{t(strings.france.sections.details)}</div>
    <section class="details-section page-content">
      <div class="details-table">
        <div class="details-row">
          <p class="details-label">{t(strings.france.where.venueLabel)}</p>
          <div class="details-value">
            <span class="details-primary">{t(strings.france.where.venue)}</span>
            <span class="details-secondary">{t(strings.france.where.location)}</span>
          </div>
        </div>
        <hr class="timetable-rule">
        <div class="details-row">
          <p class="details-label">{t(strings.france.where.mapLabel)}</p>
          <div class="details-value">
            <div class="details-links">
              <a
                class="details-link"
                href="https://maps.apple/p/dHL2e4qibM7MGE"
                target="_blank"
                rel="noopener noreferrer"
              >
                {t(strings.france.where.appleMapLink)}
              </a>
              <a
                class="details-link"
                href="https://maps.app.goo.gl/JHZfysCfNYZqmN4T9"
                target="_blank"
                rel="noopener noreferrer"
              >
                {t(strings.france.where.googleMapLink)}
              </a>
            </div>
          </div>
        </div>
        <hr class="timetable-rule">
        <div class="details-row">
          <p class="details-label">{t(strings.france.accommodation.heading)}</p>
          <div class="details-value">
            <span class="details-primary">{t(strings.france.accommodation.stayAtVillage)}</span>
            <span class="details-secondary">{t(strings.france.accommodation.price)}</span>
          </div>
        </div>
        <hr class="timetable-rule">
        <div class="details-row">
          <p class="details-label">{t(strings.france.where.datesLabel)}</p>
          <div class="details-value">
            <span class="details-primary">{t(strings.france.when.dates)}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Band: Explore -->
    <div class="band-header">{t(strings.global.explore)}</div>
    <section class="nav-section">
      <nav class="strip-nav page-content" aria-label="Event sections">
        <a href="/france/schedule" class="strip-link">
          <span class="strip-title">{t(strings.france.nav.schedule.title)}</span>
          <span class="strip-desc">{t(strings.france.nav.schedule.desc)}</span>
          <span class="strip-arrow">→</span>
        </a>
        <a href="/france/details" class="strip-link">
          <span class="strip-title">{t(strings.france.nav.venue.title)}</span>
          <span class="strip-desc">{t(strings.france.nav.venue.desc)}</span>
          <span class="strip-arrow">→</span>
        </a>
        <a href="/france/travel" class="strip-link">
          <span class="strip-title">{t(strings.france.nav.travel.title)}</span>
          <span class="strip-desc">{t(strings.france.nav.travel.desc)}</span>
          <span class="strip-arrow">→</span>
        </a>
        <a href="/couple" class="strip-link">
          <span class="strip-title">{t(strings.france.nav.couple.title)}</span>
          <span class="strip-desc">{t(strings.france.nav.couple.desc)}</span>
          <span class="strip-arrow">→</span>
        </a>
        <a href="/france/lookbook" class="strip-link">
          <span class="strip-title">{t(strings.france.nav.lookbook.title)}</span>
          <span class="strip-desc">{t(strings.france.nav.lookbook.desc)}</span>
          <span class="strip-arrow">→</span>
        </a>
        <a href="/france/rsvp" class="strip-link strip-link--cta">
          <span class="strip-title">{t(strings.france.nav.rsvp.title)}</span>
          <span class="strip-desc">{t(strings.france.nav.rsvp.desc)}</span>
          <span class="strip-arrow">→</span>
        </a>
      </nav>
    </section>
    </div>

  </main>

  <SiteFooter guest={guest} lang={Astro.locals.lang ?? 'en'} />
</WireframeLayout>

<style>
  /* ── Destination hero — travel poster ── */
  .france-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding: var(--space-xl) var(--page-margin) var(--space-xl);
    overflow: hidden;
  }

  .destination-header {
    position: relative;
    z-index: 2;
    max-width: 640px;
  }

  .event-location {
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .destination-name {
    font-size: clamp(56px, 11vw, 128px);
    line-height: 0.92;
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    font-family: var(--font-display);
  }

  .event-dates {
    font-size: var(--font-size-h3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-h3);
    margin-bottom: var(--space-xs);
  }

  .event-type {
    font-size: var(--font-size-body);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
  }

  /* Sun disc — positioned right edge, partially cropped */
  .sun-disc-large {
    position: absolute;
    width: clamp(240px, 45vw, 560px);
    height: clamp(240px, 45vw, 560px);
    background: var(--color-accent);
    border-radius: 50%;
    right: -8%;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
  }

  /* ── Weekend programme timetable ── */
  .programme-section {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-lg);
  }

  .programme-timetable {
    max-width: 640px;
  }

  .programme-row {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    align-items: start;
  }

  .day-label {
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    padding-top: 3px;
  }

  .programme-row--main .day-label {
    color: var(--color-accent);
  }

  .day-events {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .event-item {
    display: grid;
    grid-template-columns: 12ch minmax(0, 1fr);
    column-gap: var(--space-sm);
    align-items: baseline;
  }

  .event-time {
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    color: var(--color-text-muted);
  }

  .event-name {
    font-size: var(--font-size-body);
    min-width: 0;
  }

  .timetable-rule {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  /* ── Details section ── */
  .details-section {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-lg);
  }

  .details-table {
    max-width: 640px;
  }

  .details-row {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: var(--space-md);
    padding: 20px 0;
    align-items: center;
  }

  .details-label {
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    color: var(--color-text-muted);
  }

  .details-value {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: var(--font-size-body);
    line-height: var(--line-height-body);
  }

  .details-primary {
    font-weight: 500;
  }

  .details-secondary {
    color: var(--color-text-muted);
    font-size: var(--font-size-caption);
    line-height: 1.6;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
  }

  .details-link,
  .details-value a {
    width: fit-content;
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    text-decoration: none;
  }

  .details-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* ── Navigation strip ── */
  .strip-nav {
    padding-top: var(--space-md);
    padding-bottom: var(--space-md);
  }

  .strip-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.15s;
  }

  .strip-link:first-child {
    border-top: 1px solid var(--color-border);
  }

  .strip-link:hover {
    color: var(--color-accent);
  }

  .strip-title {
    font-family: var(--font-display);
    font-size: var(--font-size-h3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
  }

  .strip-desc {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    text-align: right;
  }

  .strip-arrow {
    color: var(--color-accent);
  }

  .strip-link--cta .strip-title {
    color: var(--color-accent);
  }

  /* ── Header nav button — fixed height prevents font-metric jumps between events ── */
  .rsvp-btn {
    height: 32px;
    padding: 0 24px;
    display: inline-flex;
    align-items: center;
    font-size: var(--font-size-caption);
    line-height: 1;
    /* Orange CTA — overrides .btn-primary which uses --color-text (Prussian blue on France) */
    background: var(--color-accent) !important;
    color: var(--color-warm-cream) !important;
  }

  @media (max-width: 768px) {
    .france-hero {
      min-height: 60vh;
      padding: var(--space-lg) var(--page-margin-mobile);
      align-items: flex-start;
      flex-direction: column;
      justify-content: flex-end;
    }

    .sun-disc-large {
      top: 0;
      right: -20%;
      transform: none;
    }

    .programme-row {
      grid-template-columns: 104px 1fr;
    }

    .details-row {
      display: block;
      padding: 16px 0;
    }

    .details-label {
      display: block;
      margin-bottom: 8px;
      padding-top: 0;
    }

    .details-value {
      gap: 4px;
      max-width: 100%;
    }

  }
</style>
