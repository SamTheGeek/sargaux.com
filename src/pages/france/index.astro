---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { features } from '../../config/features';
import { generateToken } from '../../lib/calendar';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';

const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const guestId = Astro.locals.guestId;
const calendarToken = (features.france.calendarSubscribe && guestId)
  ? generateToken(guestId)
  : null;
const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.france.pageTitle)} description="France Wedding - May 2027" event="france">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        {showEventToggle && (
          <div class="event-toggle">
            <a href="/nyc">{t(strings.global.toggle.nyc)}</a>
            <span class="divider">|</span>
            <span class="active">{t(strings.global.toggle.france)}</span>
          </div>
        )}
        <a href="/france/rsvp" class="btn btn-primary rsvp-btn">{t(strings.global.rsvpBtn)}</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <ImagePlaceholder
        name="france-hero"
        folder="france"
        description="Village De Sully exterior — the grounds, main building, or scenic view of the property."
        aspectRatio="16/9"
      />
      <div class="hero-overlay">
        <h1>{t(strings.france.heroTitle)}</h1>
        <p class="date">{t(strings.france.heroDate)}</p>
        <p class="event-type">{t(strings.france.heroEventType)}</p>
      </div>
    </section>

    <!-- Quick Info Section -->
    <section class="quick-info">
      <div class="info-cards">
        <div class="content-box info-card">
          <h3>{t(strings.france.when.heading)}</h3>
          <p>{t(strings.france.when.dates)}</p>
          <p>{t(strings.france.when.desc)}</p>
        </div>
        <div class="content-box info-card">
          <h3>{t(strings.france.where.heading)}</h3>
          <p><strong>{t(strings.france.where.venue)}</strong></p>
          <p>{t(strings.france.where.location)}</p>
          <a href="https://maps.app.goo.gl/JHZfysCfNYZqmN4T9" class="map-link" target="_blank">{t(strings.france.where.mapLink)}</a>
        </div>
        <div class="content-box info-card">
          <h3>{t(strings.france.accommodation.heading)}</h3>
          <p>{t(strings.france.accommodation.stayAtVillage)}</p>
          <p><strong>{t(strings.france.accommodation.price)}</strong></p>
          <p class="note"><em>{t(strings.france.accommodation.reserveNote)}</em></p>
        </div>
      </div>
    </section>

    <!-- Weekend Overview -->
    <section class="weekend-overview">
      <div class="day-cards">
        <div class="content-box day-card">
          <h3>{t(strings.france.weekend.friday.day)}</h3>
          <div class="day-content">
            <p class="time">{t(strings.france.weekend.friday.timeEvening)}</p>
            <p><strong>{t(strings.france.weekend.friday.welcomeDinner)}</strong></p>
            <p class="desc">{t(strings.france.weekend.friday.welcomeDesc)}</p>
          </div>
        </div>
        <div class="content-box day-card highlight">
          <h3>{t(strings.france.weekend.saturday.day)}</h3>
          <div class="day-content">
            <p class="time">{t(strings.france.weekend.saturday.timeMorning)}</p>
            <p>{t(strings.france.weekend.saturday.breakfast)}</p>
            <p class="time">{t(strings.france.weekend.saturday.timeAfternoon)}</p>
            <p><strong>{t(strings.france.weekend.saturday.ceremony)}</strong></p>
            <p><strong>{t(strings.france.weekend.saturday.cocktail)}</strong></p>
            <p class="time">{t(strings.france.weekend.saturday.timeEvening)}</p>
            <p><strong>{t(strings.france.weekend.saturday.reception)}</strong></p>
          </div>
        </div>
        <div class="content-box day-card">
          <h3>{t(strings.france.weekend.sunday.day)}</h3>
          <div class="day-content">
            <p class="time">{t(strings.france.weekend.sunday.timeMorning)}</p>
            <p>{t(strings.france.weekend.sunday.breakfast)}</p>
            <p class="time">{t(strings.france.weekend.sunday.timeMidday)}</p>
            <p><strong>{t(strings.france.weekend.sunday.farewellBrunch)}</strong></p>
          </div>
        </div>
      </div>
    </section>

    <!-- Location Map -->
    <section class="location-map">
      <h2>{t(strings.france.location.heading)}</h2>
      <div class="map-placeholder">
        <p class="placeholder-note">{t(strings.france.location.mapPlaceholder)}</p>
        <p class="location-context">{t(strings.france.location.context)}</p>
      </div>
    </section>

    <!-- Calendar Subscribe (Prominent) -->
    <section class="calendar-subscribe">
      <div class="calendar-content">
        <h2>{t(strings.france.calendar.heading)}</h2>
        <p>{t(strings.france.calendar.subtext)}</p>
        {calendarToken ? (
          <a
            href={`webcal://${Astro.url.host}/api/calendar/${calendarToken}.ics`}
            class="calendar-btn-prominent"
          >
            {t(strings.france.calendar.addBtn)}
          </a>
        ) : (
          <>
            <button class="calendar-btn-prominent" disabled>{t(strings.france.calendar.addBtn)}</button>
            <p class="calendar-note">{t(strings.france.calendar.unavailableNote)}</p>
          </>
        )}
      </div>
    </section>

    <!-- Navigation Cards -->
    <section class="nav-cards">
      <nav class="event-nav" aria-label="Event sections">
        <a href="/france/schedule" class="nav-card">
          <span class="nav-title">{t(strings.france.nav.schedule.title)}</span>
          <span class="nav-desc">{t(strings.france.nav.schedule.desc)}</span>
        </a>
        <a href="/france/details" class="nav-card">
          <span class="nav-title">{t(strings.france.nav.venue.title)}</span>
          <span class="nav-desc">{t(strings.france.nav.venue.desc)}</span>
        </a>
        <a href="/france/travel" class="nav-card">
          <span class="nav-title">{t(strings.france.nav.travel.title)}</span>
          <span class="nav-desc">{t(strings.france.nav.travel.desc)}</span>
        </a>
        <a href="/france/rsvp" class="nav-card highlight">
          <span class="nav-title">{t(strings.france.nav.rsvp.title)}</span>
          <span class="nav-desc">{t(strings.france.nav.rsvp.desc)}</span>
        </a>
      </nav>
    </section>

    <!-- Venue Preview -->
    <section class="venue-preview">
      <div class="venue-grid">
        <ImagePlaceholder
          name="france-grounds"
          folder="france"
          description="The village grounds — gardens, walkways, outdoor spaces where guests will gather."
          aspectRatio="4/3"
        />
        <ImagePlaceholder
          name="france-accommodation"
          folder="france"
          description="Guest accommodation at the village — room interior or building exterior."
          aspectRatio="4/3"
        />
        <ImagePlaceholder
          name="france-ceremony"
          folder="france"
          description="Ceremony location on the property, or similar outdoor ceremony setting."
          aspectRatio="4/3"
        />
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <nav>
      <a href="/registry">{t(strings.global.registry)}</a>
      <span> · </span>
      <span class="guest-name">{guest}</span>
      <span> · </span>
      <a href="/api/logout">{t(strings.global.logout)}</a>
    </nav>
    <div class="footer-meta">
      <p class="copyright">{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
  }

  .hero-overlay {
    padding: var(--space-xl) var(--page-margin);
    text-align: center;
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .date {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-xs);
  }

  .event-type {
    font-size: var(--font-size-body);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
  }

  /* Quick Info */
  .quick-info {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .info-card p {
    margin-bottom: var(--space-xs);
  }

  .info-card .note {
    font-size: var(--font-size-caption);
    color: var(--color-accent);
    margin-top: var(--space-xs);
  }

  .map-link {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
  }

  /* Weekend Overview */
  .weekend-overview {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .day-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .day-card {
    min-height: 200px;
  }

  .day-card.highlight {
    border-color: var(--color-text);
    border-width: 2px;
  }

  .day-content {
    margin-top: var(--space-xs);
  }

  .day-content .time {
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .day-content .time:first-child {
    margin-top: 0;
  }

  .day-content p {
    margin-bottom: var(--space-xs);
  }

  .day-content .desc {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
  }

  /* Location Map */
  .location-map {
    padding: var(--space-lg) var(--page-margin);
    max-width: 800px;
    margin: 0 auto;
  }

  .location-map h2 {
    margin-bottom: var(--space-sm);
    text-align: center;
  }

  .map-placeholder {
    background: var(--color-bg);
    border: 1px dashed var(--color-border);
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
  }

  .placeholder-note {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  .location-context {
    font-size: var(--font-size-body);
    color: var(--color-text-muted);
  }

  /* Calendar Subscribe */
  .calendar-subscribe {
    padding: var(--space-lg) var(--page-margin);
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .calendar-content {
    padding: var(--space-lg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .calendar-content > p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .calendar-btn-prominent {
    display: inline-block;
    text-decoration: none;
  }

  .calendar-note {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  /* Navigation Cards */
  .nav-cards {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .event-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-sm);
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    transition: border-color 0.15s;
    text-align: center;
  }

  .nav-card:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .nav-card.highlight {
    border-color: var(--color-text);
    border-width: 2px;
  }

  .nav-title {
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    margin-bottom: var(--space-xs);
  }

  .nav-desc {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
  }

  /* Venue Preview */
  .venue-preview {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .venue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  /* RSVP button in nav */
  .rsvp-btn {
    padding: 8px 24px;
    font-size: var(--font-size-caption);
  }

  /* Footer */
  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: var(--space-xs);
  }

  @media (max-width: 768px) {
    .hero-overlay {
      padding: var(--space-lg) var(--page-margin-mobile);
    }

    .site-nav {
      flex-direction: column;
      text-align: center;
      gap: var(--space-sm);
    }

    .nav-actions {
      flex-direction: column;
    }
  }
</style>
