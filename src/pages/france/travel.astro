---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';
import '../../styles/france-travel.css';

const lang = Astro.locals.lang ?? 'en';
const t = createTranslator(lang);
const travel = strings.france.travel;
---

<WireframeLayout title={t(strings.france.travel.pageTitle)} event="france" page="travel">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <a href="/france" class="back-link">{t(strings.nav.backToEvent)}</a>
    </nav>
  </header>

  <main class="travel-page">
    <div class="travel-disc-stage" aria-hidden="true">
      <div class="travel-disc" transition:name="event-disc"></div>
    </div>

    <div class="travel-shell page-content" transition:name="france-travel-content">
      <div class="travel-intro">
        <h1>{t(strings.france.travel.heading)}</h1>
        <p class="subtitle">{t(strings.france.travel.subtitle)}</p>
      </div>

      <section class="travel-sections">
        <!-- Getting to France (will be conditionally hidden for French guests via i18n/Notion) -->
        <article class="travel-card">
          <h2>{t(strings.france.travel.toFrance.heading)}</h2>

          <h3>{t(strings.france.travel.toFrance.air.heading)}</h3>
          <p>{t(strings.france.travel.toFrance.air.intro)}</p>
          <ul>
            <li>{t(strings.france.travel.toFrance.air.cdg)}</li>
            <li>{t(strings.france.travel.toFrance.air.orly)}</li>
          </ul>

          <h3>{t(strings.france.travel.toFrance.eurostar.heading)}</h3>
          <p>{t(strings.france.travel.toFrance.eurostar.text)}</p>
          <hr class="travel-subrule" />
          <p class="travel-footnote">
            {t(strings.france.travel.toFrance.metroTickets.beforeLink)}
            {' '}
            <a
              class="travel-inline-link"
              href="https://www.iledefrance-mobilites.fr/en/application"
              target="_blank"
              rel="noopener noreferrer"
            >{t(strings.france.travel.toFrance.metroTickets.linkText)}</a>
            {' '}
            {t(strings.france.travel.toFrance.metroTickets.afterLink)}
          </p>
        </article>

        <!-- Getting to the Venue from Paris (shown to everyone) -->
        <article class="travel-card">
          <h2>{t(travel.toVenue.heading)}</h2>

          <h3>{t(travel.toVenue.train.heading)}</h3>
          <ul>
            <li>{t(travel.toVenue.train.step1)}</li>
            <li>{t(travel.toVenue.train.step2)}</li>
            <li>{t(travel.toVenue.train.step3)}</li>
          </ul>
          <p>{t(travel.toVenue.train.mobilitesNote)}</p>
          <a
            class="travel-btn"
            href="https://www.iledefrance-mobilites.fr/en"
            target="_blank"
            rel="noopener noreferrer"
          >{t(travel.toVenue.train.mobilitesBtn)} ↗</a>

          <h3>{t(travel.toVenue.car.heading)}</h3>
          <p>{t(travel.toVenue.car.text)}</p>
          <ul>
            <li>
              {t(travel.toVenue.car.directionsBeforeLink)}
              {' '}
              <a
                class="travel-inline-link"
                href="https://maps.app.goo.gl/sx7w6MoXXfBftkLe9"
                target="_blank"
                rel="noopener noreferrer"
              >
                {t(travel.toVenue.car.directionsLinkText)}
              </a>
              {' '}
              {t(travel.toVenue.car.directionsAfterLink)}
            </li>
            {t(travel.toVenue.car.tolls) && <li>{t(travel.toVenue.car.tolls)}</li>}
          </ul>
        </article>

        {lang === 'en' && (
          <>
          <!-- ETIAS Travel Authorization (English only) -->
          <article class="travel-card">
            <h2>{t(travel.etias.heading)}</h2>
            <p>{t(travel.etias.text)}</p>
            <p>{t(travel.etias.passportNote)}</p>
            <a
              class="travel-btn"
              href="https://travel-europe.europa.eu/etias_en"
              target="_blank"
              rel="noopener noreferrer"
            >{t(travel.etias.btn)} ↗</a>
          </article>

          <!-- International Driving Permit (English only) -->
          <article class="travel-card">
            <h2>{t(travel.idp.heading)}</h2>
            <p>{t(travel.idp.text)}</p>
            <a
              class="travel-btn"
              href="https://www.aaa.com/vacation/idpf.html"
              target="_blank"
              rel="noopener noreferrer"
            >{t(travel.idp.btn)} ↗</a>
          </article>

          <!-- Practical Information (English only) -->
          <article class="travel-card">
            <h2>{t(travel.practical.heading)}</h2>
            <div class="info-grid">
              <div class="info-item">
                <h3>{t(travel.practical.timezone.heading)}</h3>
                <p>{t(travel.practical.timezone.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.weather.heading)}</h3>
                <p>{t(travel.practical.weather.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.payment.heading)}</h3>
                <p>{t(travel.practical.payment.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.electricity.heading)}</h3>
                <p>{t(travel.practical.electricity.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.mobile.heading)}</h3>
                <p>{t(travel.practical.mobile.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.whatsapp.heading)}</h3>
                <p>{t(travel.practical.whatsapp.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.water.heading)}</h3>
                <p>{t(travel.practical.water.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.pharmacies.heading)}</h3>
                <p>{t(travel.practical.pharmacies.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.tipping.heading)}</h3>
                <p>{t(travel.practical.tipping.text)}</p>
              </div>
              <div class="info-item">
                <h3>{t(travel.practical.uber.heading)}</h3>
                <p>{t(travel.practical.uber.text)}</p>
              </div>
            </div>
          </article>
          </>
        )}
      </section>
    </div>
  </main>

  <footer>
    <nav class="footer-nav">
      <a href="/france">{t(strings.nav.home)}</a>
    </nav>
    <div class="footer-row">
      <p>{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>
