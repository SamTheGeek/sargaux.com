---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import '../../styles/france-details.css';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import SiteFooter from '../../components/SiteFooter.astro';
import { features } from '../../config/features';
import { Image } from 'astro:assets';
import fromabove from '../../assets/images/france/fromabove.jpg';
import laplace from '../../assets/images/france/laplace.jpg';
import bistrotdesamis from '../../assets/images/france/bistrotdesamis.jpg';
import felixpotin from '../../assets/images/france/felixpotin.png';
import lagare from '../../assets/images/france/lagare.jpg';
import mairie from '../../assets/images/france/mairie.png';
import villageroom from '../../assets/images/france/villageroom.png';
import orientexpress from '../../assets/images/france/orientexpress.png';
import louisiane from '../../assets/images/france/louisiane.jpg';

const t = createTranslator(Astro.locals.lang ?? 'en');
const guest = Astro.locals.guest;
const details = strings.france.details;
---

<WireframeLayout title={t(strings.france.details.pageTitle)} event="france" page="details">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <a href="/france" class="back-link">{t(strings.nav.backToEvent)}</a>
    </nav>
  </header>

  <main>
    <div class="france-page-content" transition:name="france-details-content">
      <h1>{t(strings.france.details.heading)}</h1>
      <p class="subtitle">{t(strings.france.details.subtitle)}</p>

      <section class="hero-venue">
        <div class="venue-image-frame venue-image-frame--hero">
          <Image
            src={fromabove}
            alt="Aerial view of Village de Sully"
            class="venue-image"
            width={1600}
          />
        </div>
      </section>

      <section class="venue-info">
        <p class="venue-desc">{t(details.intro)}</p>
      </section>

      <section class="venue-info">
        <h2>{t(details.location.heading)}</h2>
        <p><strong>{t(details.location.line1)}</strong></p>
        <p>{t(details.location.line2)}</p>
        <div class="venue-links">
          <a
            href="https://maps.apple/p/dHL2e4qibM7MGE"
            target="_blank"
            rel="noopener noreferrer"
            class="venue-link"
          >
            {t(details.location.appleMapLink)}
          </a>
          <a
            href="https://maps.app.goo.gl/JHZfysCfNYZqmN4T9"
            target="_blank"
            rel="noopener noreferrer"
            class="venue-link"
          >
            {t(details.location.googleMapLink)}
          </a>
        </div>
      </section>

      <section class="venue-spaces">
        <h2>{t(details.highlights.heading)}</h2>
        <div class="spaces-grid">
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={laplace} alt={t(details.highlights.place.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.highlights.place.title)}</h3>
            <p>{t(details.highlights.place.desc)}</p>
          </div>
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={bistrotdesamis} alt={t(details.highlights.bistrot.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.highlights.bistrot.title)}</h3>
            <p>{t(details.highlights.bistrot.desc)}</p>
          </div>
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={felixpotin} alt={t(details.highlights.felix.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.highlights.felix.title)}</h3>
            <p>{t(details.highlights.felix.desc)}</p>
          </div>
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={lagare} alt={t(details.highlights.gare.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.highlights.gare.title)}</h3>
            <p>{t(details.highlights.gare.desc)}</p>
          </div>
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={mairie} alt={t(details.highlights.mairie.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.highlights.mairie.title)}</h3>
            <p>{t(details.highlights.mairie.desc)}</p>
          </div>
        </div>
      </section>

      <section class="accommodation-details">
        <h2>{t(details.staying.heading)}</h2>

        <div class="recommendation-banner">
          <p>{t(details.staying.callout)}</p>
        </div>

        {features.france.stayingOverview && (
          <div class="accommodation-info">
            <h3>{t(details.overview.heading)}</h3>
            <ul>
              {details.overview.items.map((item) => (
                <li>{t(item)}</li>
              ))}
            </ul>
          </div>
        )}

        <div class="accommodation-info accommodation-info--booking">
          <h3>{t(details.booking.heading)}</h3>
          <p class="booking-lead"><strong>{t(details.booking.reserve)}</strong></p>
          <p class="booking-pricing">{t(details.booking.pricing)}</p>
          <p class="booking-note">{t(details.booking.followup)}</p>
        </div>
      </section>

      <section class="venue-spaces">
        <h2>{t(details.roomTypes.heading)}</h2>
        <div class="spaces-grid">
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={villageroom} alt={t(details.roomTypes.village.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.roomTypes.village.title)}</h3>
            <p>{t(details.roomTypes.village.desc)}</p>
          </div>
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={orientexpress} alt={t(details.roomTypes.orient.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.roomTypes.orient.title)}</h3>
            <p>{t(details.roomTypes.orient.desc)}</p>
          </div>
          <div class="space-card">
            <div class="venue-image-frame venue-image-frame--card">
              <Image src={louisiane} alt={t(details.roomTypes.louisiana.title)} class="venue-image" width={560} />
            </div>
            <h3>{t(details.roomTypes.louisiana.title)}</h3>
            <p>{t(details.roomTypes.louisiana.desc)}</p>
          </div>
        </div>
      </section>
    </div>
  </main>

  <SiteFooter guest={guest} lang={Astro.locals.lang ?? 'en'} homeHref="/france" />
</WireframeLayout>
