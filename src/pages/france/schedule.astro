---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';

const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.france.schedule.pageTitle)}>
  <header>
    <nav class="main-nav">
      <a href="/" class="logo">{t(strings.global.siteName)}</a>
      <a href="/france" class="back-link">{t(strings.nav.backToFrance)}</a>
    </nav>
  </header>

  <main>
    <h1>{t(strings.france.schedule.heading)}</h1>
    <p class="subtitle">{t(strings.france.schedule.subtitle)}</p>

    <!-- Check-in/Check-out Info -->
    <div class="stay-info">
      <div class="stay-time">
        <span class="stay-label">{t(strings.france.schedule.checkin)}</span>
        <span class="stay-value">{t(strings.france.schedule.checkinValue)}</span>
      </div>
      <div class="stay-divider"></div>
      <div class="stay-time">
        <span class="stay-label">{t(strings.france.schedule.checkout)}</span>
        <span class="stay-value">{t(strings.france.schedule.checkoutValue)}</span>
      </div>
    </div>

    <!-- Calendar Subscribe -->
    <section class="calendar-subscribe">
      <button class="calendar-btn" disabled>{t(strings.france.schedule.calendarBtn)}</button>
      <p class="calendar-note">{t(strings.france.schedule.calendarNote)}</p>
    </section>

    <section class="days">
      <!-- Friday -->
      <div class="day-section">
        <h2>{t(strings.france.schedule.friday.heading)}</h2>
        <div class="timeline">
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.friday.checkin.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.friday.checkin.title)}</h4>
              <p>{t(strings.france.schedule.friday.checkin.desc)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.friday.dinner.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.friday.dinner.title)}</h4>
              <p class="location">{t(strings.france.schedule.friday.dinner.location)}</p>
              <p>{t(strings.france.schedule.friday.dinner.desc)}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Saturday -->
      <div class="day-section highlight">
        <h2>{t(strings.france.schedule.saturday.heading)}</h2>
        <p class="day-note">{t(strings.france.schedule.saturday.dayNote)}</p>
        <div class="timeline">
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.breakfast.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.breakfast.title)}</h4>
              <p>{t(strings.france.schedule.saturday.breakfast.desc)}</p>
            </div>
          </div>
          <div class="timeline-item optional">
            <span class="time">{t(strings.france.schedule.saturday.excursions.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.excursions.title)}</h4>
              <p class="placeholder-note">{t(strings.france.schedule.saturday.excursions.placeholder)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.ceremony.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.ceremony.title)}</h4>
              <p class="location">{t(strings.france.schedule.saturday.ceremony.location)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.cocktail.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.cocktail.title)}</h4>
              <p class="location">{t(strings.france.schedule.saturday.cocktail.location)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.reception.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.reception.title)}</h4>
              <p>{t(strings.france.schedule.saturday.reception.desc)}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sunday -->
      <div class="day-section">
        <h2>{t(strings.france.schedule.sunday.heading)}</h2>
        <div class="timeline">
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.sunday.breakfast.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.sunday.breakfast.title)}</h4>
              <p>{t(strings.france.schedule.sunday.breakfast.desc)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.sunday.brunch.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.sunday.brunch.title)}</h4>
              <p class="location">{t(strings.france.schedule.sunday.brunch.location)}</p>
              <p>{t(strings.france.schedule.sunday.brunch.desc)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.sunday.checkout.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.sunday.checkout.title)}</h4>
              <p>{t(strings.france.schedule.sunday.checkout.desc)}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <p>{t(strings.global.copyright)}</p>
  </footer>
</WireframeLayout>

<style>
  header {
    border-bottom: 1px solid #e5e5e5;
  }

  .main-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: #1a1a1a;
  }

  .back-link {
    font-size: 0.875rem;
    color: #666;
    text-decoration: none;
  }

  .back-link:hover {
    color: #1a1a1a;
  }

  main {
    flex: 1;
    padding: 3rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #666;
    margin-bottom: 2rem;
  }

  /* Stay Info */
  .stay-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem;
    background: #f9f9f9;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .stay-time {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stay-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #888;
  }

  .stay-value {
    font-weight: 500;
    color: #1a1a1a;
  }

  .stay-divider {
    width: 1px;
    height: 2.5rem;
    background: #e5e5e5;
  }

  /* Calendar Subscribe */
  .calendar-subscribe {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .calendar-btn {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    margin-bottom: 0.5rem;
  }

  .calendar-btn:hover:not(:disabled) {
    background: #333;
  }

  .calendar-btn:disabled {
    background: #888;
    cursor: not-allowed;
  }

  .calendar-note {
    font-size: 0.875rem;
    color: #888;
    font-style: italic;
  }

  /* Days */
  .days {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .day-section h2 {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e5e5;
  }

  .day-section.highlight h2 {
    border-bottom-color: #1a1a1a;
  }

  .day-note {
    font-size: 0.875rem;
    color: #666;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
    padding: 1rem;
    border: 1px solid #e5e5e5;
    border-radius: 0.5rem;
    background: white;
  }

  .timeline-item.optional {
    border-style: dashed;
    background: #fafafa;
  }

  .time {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
    min-width: 80px;
    flex-shrink: 0;
  }

  .event {
    flex: 1;
  }

  .event h4 {
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
    font-weight: 500;
  }

  .event p {
    margin: 0;
    font-size: 0.875rem;
    color: #666;
  }

  .event .location {
    color: #888;
    font-size: 0.8125rem;
    margin-bottom: 0.25rem;
  }

  .placeholder-note {
    font-style: italic;
    color: #888 !important;
  }

  /* Footer */
  footer {
    padding: 2rem;
    text-align: center;
    border-top: 1px solid #e5e5e5;
  }

  footer p {
    font-size: 0.875rem;
    color: #888;
  }

  @media (max-width: 480px) {
    .stay-info {
      flex-direction: column;
      gap: 1rem;
    }

    .stay-divider {
      width: 100%;
      height: 1px;
    }

    .timeline-item {
      flex-direction: column;
      gap: 0.5rem;
    }

    .time {
      min-width: auto;
    }
  }
</style>
