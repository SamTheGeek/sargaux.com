---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { generateTokenIfPossible } from '../../lib/calendar';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';
import CalendarCta from '../../components/CalendarCta.astro';
import '../../styles/france-schedule.css';

Astro.response.headers.set('Cache-Control', 'private, no-store');

const guestId = Astro.locals.guestId;
const t = createTranslator(Astro.locals.lang ?? 'en');
const calendarToken = generateTokenIfPossible(guestId);
---

<WireframeLayout title={t(strings.france.schedule.pageTitle)} event="france" page="schedule">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <a href="/france" class="back-link">{t(strings.nav.backToEvent)}</a>
    </nav>
  </header>

  <main>
    <div class="france-page-content" transition:name="france-schedule-content">
      <h1>{t(strings.france.schedule.heading)}</h1>
      <p class="subtitle">{t(strings.france.schedule.subtitle)}</p>

      <!-- Check-in/Check-out Info -->
      <div class="stay-info">
        <div class="stay-time">
          <span class="stay-label">{t(strings.france.schedule.checkin)}</span>
          <span class="stay-value">{t(strings.france.schedule.checkinValue)}</span>
        </div>
        <div class="stay-divider"></div>
        <div class="stay-time">
          <span class="stay-label">{t(strings.france.schedule.checkout)}</span>
          <span class="stay-value">{t(strings.france.schedule.checkoutValue)}</span>
        </div>
      </div>

      <CalendarCta
        event="france"
        token={calendarToken}
        label={t(strings.france.schedule.calendarBtn)}
        note={t(strings.france.schedule.calendarNote)}
        unavailableNote={t(strings.nyc.calendar.unavailableNote)}
      />

      <section class="days">
      <!-- Friday -->
      <div class="day-section">
        <h2>{t(strings.france.schedule.friday.heading)}</h2>
        <div class="timeline">
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.friday.checkin.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.friday.checkin.title)}</h4>
              <p>{t(strings.france.schedule.friday.checkin.desc)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.friday.dinner.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.friday.dinner.title)}</h4>
              <p class="location">{t(strings.france.schedule.friday.dinner.location)}</p>
              <p>{t(strings.france.schedule.friday.dinner.desc)}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Saturday -->
      <div class="day-section highlight">
        <h2>{t(strings.france.schedule.saturday.heading)}</h2>
        <p class="day-note">{t(strings.france.schedule.saturday.dayNote)}</p>
        <div class="timeline">
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.breakfast.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.breakfast.title)}</h4>
              <p>{t(strings.france.schedule.saturday.breakfast.desc)}</p>
            </div>
          </div>
          <div class="timeline-item optional">
            <span class="time">{t(strings.france.schedule.saturday.excursions.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.excursions.title)}</h4>
              <p class="placeholder-note">{t(strings.france.schedule.saturday.excursions.placeholder)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.ceremony.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.ceremony.title)}</h4>
              <p class="location">{t(strings.france.schedule.saturday.ceremony.location)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.cocktail.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.cocktail.title)}</h4>
              <p class="location">{t(strings.france.schedule.saturday.cocktail.location)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.saturday.reception.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.saturday.reception.title)}</h4>
              <p>{t(strings.france.schedule.saturday.reception.desc)}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sunday -->
      <div class="day-section">
        <h2>{t(strings.france.schedule.sunday.heading)}</h2>
        <div class="timeline">
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.sunday.breakfast.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.sunday.breakfast.title)}</h4>
              <p>{t(strings.france.schedule.sunday.breakfast.desc)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.sunday.brunch.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.sunday.brunch.title)}</h4>
              <p class="location">{t(strings.france.schedule.sunday.brunch.location)}</p>
            </div>
          </div>
          <div class="timeline-item">
            <span class="time">{t(strings.france.schedule.sunday.checkout.time)}</span>
            <div class="event">
              <h4>{t(strings.france.schedule.sunday.checkout.title)}</h4>
              <p>{t(strings.france.schedule.sunday.checkout.desc)}</p>
            </div>
          </div>
        </div>
      </div>
      </section>
    </div>

  </main>

  <footer>
    <div class="footer-row">
      <p>{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
  }

main {
    flex: 1;
    padding: 3rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  /* Stay Info */
  .stay-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem;
    background: var(--color-bg);
    margin-bottom: 1.5rem;
  }

  .stay-time {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stay-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .stay-value {
    font-weight: 500;
    color: var(--color-text);
  }

  .stay-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--color-border);
  }

  /* Calendar Subscribe */
  /* Days */
  .days {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .day-section h2 {
    font-size: 1.625rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  .day-section.highlight h2 {
    border-bottom-color: var(--color-text);
  }

  .day-note {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .timeline-item.optional {
    border-style: dashed;
    background: var(--color-bg);
  }

  .time {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    min-width: 80px;
    flex-shrink: 0;
  }

  .event {
    flex: 1;
  }

  .event h4 {
    margin: 0 0 0.25rem 0;
    font-size: 1.125rem;
    font-weight: 500;
  }

  .event p {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .event .location {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    margin-bottom: 0.25rem;
  }

  .placeholder-note {
    font-style: italic;
    color: var(--color-text-muted) !important;
  }

  /* Footer */
  footer {
    padding: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }

  .footer-row p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 480px) {
    .stay-info {
      flex-direction: column;
      gap: 1rem;
    }

    .stay-divider {
      width: 100%;
      height: 1px;
    }

    .timeline-item {
      flex-direction: column;
      gap: 0.5rem;
    }

    .time {
      min-width: auto;
    }
  }
</style>
