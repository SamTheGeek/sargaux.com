---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import '../../styles/france-lookbook.css';
import '../../styles/lookbook.css';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import SiteFooter from '../../components/SiteFooter.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const guest = Astro.locals.guest;
const t = createTranslator(Astro.locals.lang ?? 'en');

const globResult = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/france/lookbook/*.{jpg,jpeg}',
  { eager: true }
);
const images = Object.entries(globResult)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);
---

<WireframeLayout title={t(strings.france.lookbook.pageTitle)} fullTitle="Chez Sargaux | France — Lookbook" event="france" page="lookbook">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <a href="/france" class="back-link">{t(strings.nav.backToEvent)}</a>
    </nav>
  </header>

  <main>
    <div class="france-lookbook-shell" transition:name="france-lookbook-content">
      <div class="france-lookbook-intro">
        <h1 class="lookbook-heading" aria-label={t(strings.france.lookbook.heading)}><span aria-hidden="true">LO</span><span class="lookbook-disc-slot" aria-hidden="true"><span class="lookbook-o-ghost">O</span><div class="lookbook-disc" transition:name="event-disc"></div></span><span aria-hidden="true">KBOOK</span></h1>
        <p class="subtitle">{t(strings.france.lookbook.subtitle)}</p>
      </div>

      <div class="france-lookbook-gallery">
        {images.length > 0 ? (
          <div class="lookbook-grid">
            {images.map(img => (
              <figure class="lookbook-item">
                <Image src={img} alt="" loading="lazy" width={800} />
              </figure>
            ))}
          </div>
        ) : (
          <p class="lookbook-empty">{t(strings.global.detailsToCome)}</p>
        )}
      </div>
    </div>
  </main>

  <SiteFooter guest={guest} lang={Astro.locals.lang ?? 'en'} />
</WireframeLayout>
