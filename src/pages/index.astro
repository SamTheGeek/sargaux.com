---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import { getAuthenticatedGuest } from '../lib/auth';
import { isSiteEnabled } from '../config/features';
import { strings } from '../content/strings';
import { createTranslator } from '../lib/i18n';
import LangSwitcher from '../components/LangSwitcher.astro';

// Only redirect if site is enabled and user is logged in
if (isSiteEnabled()) {
  const authGuest = getAuthenticatedGuest(Astro.cookies);
  if (authGuest) {
    const redirectPath = authGuest.eventInvitations.includes('nyc') ? '/nyc' : '/france';
    return Astro.redirect(redirectPath);
  }
}

const t = createTranslator(Astro.locals.lang ?? 'en');
const emptyError = t(strings.home.modal.errorEmpty);
const defaultError = t(strings.home.modal.errorDefault);
const checkingLabel = t(strings.home.modal.checkingBtn);
const submitLabel = t(strings.home.modal.submitBtn);
---

{isSiteEnabled() ? (
  <WireframeLayout title={t(strings.home.pageTitle)}>
    <main class="landing-shell">
      <section class="landing-hero">
        <div class="hero-disc" aria-hidden="true"></div>
        <div class="hero-grid page-content">
          <div class="hero-copy">
            <p class="eyebrow">Vous êtes les bienvenus à</p>
            <h1>{t(strings.home.heroTitle)}</h1>
            <p class="hero-subtitle">{t(strings.home.tagline)}</p>
            <hr class="section-rule hero-rule" />
          </div>

          <aside class="login-panel" aria-labelledby="login-panel-title">
            <form id="login-form" class="inline-login-form">
              <label for="name" class="visually-hidden">{t(strings.home.modal.nameLabel)}</label>
              <div class="inline-entry-control" id="inline-entry-control">
                <button type="button" class="btn btn-primary login-trigger-panel" id="login-trigger">
                  {t(strings.home.ctaEnter)}
                </button>
                <div class="inline-name-shell" aria-hidden="true">
                  <input
                    type="text"
                    id="name"
                    name="name"
                    class="inline-name-input"
                    placeholder={t(strings.home.modal.namePlaceholder)}
                    autocomplete="off"
                    autocapitalize="words"
                    spellcheck="false"
                    required
                  />
                </div>
              </div>
              <button type="submit" class="visually-hidden" id="submit-btn">
                {t(strings.home.modal.submitBtn)}
              </button>
              <div id="error-message" class="error-message" aria-live="polite"></div>
            </form>
            <p class="panel-intro" id="login-panel-title">Please enter your name</p>
            <p class="panel-copy">As it appears on your invitation.</p>
          </aside>
        </div>
      </section>
    </main>

    <footer class="site-footer landing-footer">
      <div class="footer-row">
        <p class="copyright">&copy; 2026 Sam Gross</p>
        <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
      </div>
    </footer>

    <style>
      main {
        flex: 1;
      }

      .landing-shell {
        position: relative;
        overflow: clip;
      }

      .landing-hero {
        position: relative;
        padding: var(--space-xl) 0 var(--space-lg);
        min-height: min(820px, calc(100vh - 120px));
        display: flex;
        align-items: center;
      }

      .hero-disc {
        position: absolute;
        width: clamp(240px, 34vw, 520px);
        height: clamp(240px, 34vw, 520px);
        border-radius: 50%;
        background: var(--color-accent);
        left: clamp(-96px, -8vw, -32px);
        top: clamp(24px, 8vw, 96px);
        z-index: 0;
      }

      .hero-grid {
        position: relative;
        z-index: 1;
        width: 100%;
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-lg);
        align-items: center;
        justify-items: center;
      }

      .hero-copy {
        max-width: 760px;
        padding-top: var(--space-2xl);
        text-align: left;
        justify-self: stretch;
      }

      .eyebrow {
        font-size: var(--font-size-caption);
        letter-spacing: var(--tracking-heading);
        text-transform: uppercase;
      }

      .eyebrow {
        margin-bottom: var(--space-sm);
        max-width: none;
        white-space: nowrap;
      }

      .hero-copy h1 {
        font-size: clamp(64px, 12vw, 156px);
        line-height: 0.9;
        margin-bottom: var(--space-sm);
        max-width: 6ch;
      }

      .hero-subtitle {
        font-size: clamp(18px, 2.8vw, 32px);
        line-height: 1.2;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .hero-rule {
        width: min(100%, 280px);
        margin: var(--space-md) 0 0;
      }

      .login-panel {
        position: relative;
        width: min(100%, 420px);
        padding: 0;
        display: grid;
        gap: var(--space-sm);
        justify-items: center;
        text-align: center;
      }

      .panel-intro {
        font-family: var(--font-display);
        font-size: var(--font-size-h3);
        line-height: 1.2;
        text-transform: uppercase;
        letter-spacing: var(--tracking-h3);
      }

      .panel-copy {
        color: var(--color-text-muted);
        max-width: 28ch;
        text-transform: uppercase;
        letter-spacing: var(--tracking-caption);
        font-size: var(--font-size-caption);
      }

      .login-trigger-panel {
        width: 100%;
        justify-content: center;
        min-height: 48px;
      }

      .inline-login-form {
        display: grid;
        gap: 12px;
        width: 100%;
      }

      .inline-entry-control {
        width: 100%;
        position: relative;
        min-height: 48px;
      }

      .inline-name-shell {
        position: absolute;
        inset: 0;
        opacity: 0;
        pointer-events: none;
      }

      .login-trigger-panel,
      input.inline-name-input {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 48px;
        padding: 12px 32px;
        background: var(--color-text);
        color: var(--color-surface-text);
        -webkit-text-fill-color: var(--color-surface-text);
        border: none;
        text-transform: uppercase;
        letter-spacing: var(--tracking-h3);
        font-weight: 500;
        font-size: var(--font-size-body);
        line-height: 1;
        text-align: center;
        caret-color: currentColor;
        border-radius: 0;
        appearance: none;
        -webkit-appearance: none;
        box-shadow: none;
        cursor: pointer;
      }

      input.inline-name-input::placeholder {
        color: rgba(241, 236, 227, 0.68);
        -webkit-text-fill-color: rgba(241, 236, 227, 0.68);
        opacity: 1;
        text-align: center;
        font-style: italic;
        font-weight: 400;
        letter-spacing: 0.02em;
        text-transform: none;
      }

      input.inline-name-input:focus {
        outline: none;
        border: none;
        cursor: text;
      }

      .inline-entry-control.is-active .login-trigger-panel {
        opacity: 0;
        pointer-events: none;
      }

      .inline-entry-control.is-active .inline-name-shell {
        opacity: 1;
        pointer-events: auto;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .error-message {
        color: var(--color-error);
        font-size: 0.875rem;
        min-height: 1.25rem;
        order: 2;
      }

      .landing-footer {
        margin-top: 0;
      }

      .footer-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }

      @media (prefers-color-scheme: dark) {
        .landing-shell {
          background:
            radial-gradient(circle at 84% 24%, rgba(217, 106, 30, 0.18), transparent 0 26%),
            linear-gradient(180deg, rgba(22, 32, 64, 0.24), transparent 240px);
        }

        .hero-copy h1,
        .panel-intro {
          font-family: 'Peignot', 'Georgia', serif;
          letter-spacing: 0.05em;
          font-weight: 700;
        }

        .hero-subtitle,
        .panel-copy,
        input,
        button {
          font-family: 'Futura', 'Century Gothic', 'Trebuchet MS', sans-serif;
        }

        .login-panel {
          background: transparent;
        }
      }

      @media (max-width: 900px) {
        .landing-hero {
          min-height: auto;
          padding-top: var(--space-lg);
        }

        .hero-grid {
          grid-template-columns: 1fr;
        }

        .hero-copy {
          padding-top: var(--space-xl);
        }

        .login-panel {
          width: min(100%, 520px);
        }
      }

      @media (max-width: 768px) {
        .landing-hero {
          padding-bottom: var(--space-md);
        }

        .hero-copy {
          padding-top: 120px;
        }

        .hero-copy h1 {
          max-width: none;
        }

        .eyebrow {
          white-space: normal;
        }

        .panel-copy {
          max-width: none;
        }
      }
    </style>
  </WireframeLayout>

  <script is:inline define:vars={{ emptyError, defaultError, checkingLabel, submitLabel }}>
    const form = document.getElementById('login-form');
    const entryControl = document.getElementById('inline-entry-control');
    const trigger = document.getElementById('login-trigger');
    const nameInput = document.getElementById('name');
    const errorMessage = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');
    const activateInlineForm = () => {
      entryControl?.classList.add('is-active');
      requestAnimationFrame(() => {
        nameInput?.focus();
        const length = nameInput?.value.length ?? 0;
        nameInput?.setSelectionRange(length, length);
      });
    };

    const collapseInlineForm = () => {
      if ((nameInput?.value ?? '').trim()) return;
      entryControl?.classList.remove('is-active');
    };

    const showError = (message) => {
      if (errorMessage) {
        errorMessage.textContent = message;
      }
    };

    const resetSubmitState = () => {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    };

    trigger?.addEventListener('click', () => {
      activateInlineForm();
      if (errorMessage) errorMessage.textContent = '';
    });

    nameInput?.addEventListener('blur', () => {
      window.setTimeout(() => {
        collapseInlineForm();
      }, 0);
    });

    document.addEventListener('pointerdown', (event) => {
      if (!entryControl?.contains(event.target)) {
        collapseInlineForm();
      }
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const name = nameInput?.value.trim() ?? '';
      if (!name) {
        showError(emptyError);
        activateInlineForm();
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = checkingLabel;
      }

      try {
        const formData = new FormData();
        formData.append('name', name);

        const response = await fetch('/api/login', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (response.ok) {
          window.location.href = data.redirectPath || '/nyc';
        } else {
          showError(data.error || defaultError);
          resetSubmitState();
        }
      } catch (error) {
        showError(defaultError);
        resetSubmitState();
      }
    });
  </script>
) : (
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="color-scheme" content="light dark" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" media="(prefers-color-scheme: light)" />
      <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />
      <meta name="viewport" content="width=device-width" />
      <meta name="generator" content={Astro.generator} />
      <title>Chez Sargaux</title>
    </head>
    <body>
      <main>
        <h1>Chez Sargaux</h1>
      </main>
      <footer>
        <p>&copy; 2026</p>
      </footer>
    </body>
  </html>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; font-family: var(--font-body); }
    body { display: flex; flex-direction: column; background-color: var(--color-bg); color: var(--color-text); }
    main { flex: 1; display: flex; align-items: center; justify-content: center; }
    h1 { font-size: 3rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; }
    footer { padding: 2rem; text-align: center; }
    footer p { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
    @media (max-width: 768px) { h1 { font-size: 2rem; } }
  </style>
)}
