---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import faviconLight from '../assets/common/favicon.svg?url';
import faviconDark from '../assets/common/favicon-dark.svg?url';
import { getAuthenticatedGuest } from '../lib/auth';
import { isSiteEnabled } from '../config/features';
import { getPrimaryEventRoute } from '../lib/event-routing';
import { strings } from '../content/strings';
import { createTranslator } from '../lib/i18n';
import SiteFooter from '../components/SiteFooter.astro';

// Only redirect if site is enabled and user is logged in
if (isSiteEnabled()) {
  const authGuest = getAuthenticatedGuest(Astro.cookies);
  if (authGuest) {
    const redirectPath = getPrimaryEventRoute(authGuest.eventInvitations);
    return Astro.redirect(redirectPath);
  }
}

const t = createTranslator(Astro.locals.lang ?? 'en');
const emptyError = t(strings.home.modal.errorEmpty);
const defaultError = t(strings.home.modal.errorDefault);
const checkingLabel = t(strings.home.modal.checkingBtn);
const submitLabel = t(strings.home.modal.submitBtn);
---

{isSiteEnabled() ? (
  <WireframeLayout title={t(strings.home.pageTitle)}>
    <main class="landing-shell">
      <section class="landing-hero">
        <div class="hero-disc" aria-hidden="true" transition:name="event-disc" transition:persist="home-hero-disc"></div>
        <div class="hero-grid page-content" transition:name="landing-content">
          <div class="hero-copy">
            <p class="eyebrow">Vous êtes les bienvenus</p>
            <h1>{t(strings.home.heroTitle)}</h1>
            <p class="hero-subtitle">{t(strings.home.tagline)}</p>
            <hr class="section-rule hero-rule" />
          </div>

          <aside class="login-panel" aria-labelledby="login-panel-title">
            <form id="login-form" class="inline-login-form">
              <label for="name" class="visually-hidden">{t(strings.home.modal.nameLabel)}</label>
              <div class="inline-entry-control" id="inline-entry-control">
                <button type="button" class="btn btn-primary login-trigger-panel" id="login-trigger">
                  {t(strings.home.ctaEnter)}
                </button>
                <div class="inline-name-shell">
                  <input
                    type="text"
                    id="name"
                    name="name"
                    class="inline-name-input"
                    placeholder={t(strings.home.modal.namePlaceholder)}
                    autocomplete="off"
                    autocapitalize="words"
                    spellcheck="false"
                    required
                  />
                  <span class="inline-progress-label" aria-hidden="true">{checkingLabel}</span>
                  <button type="submit" class="inline-submit-btn" id="inline-submit" aria-label="Submit name">
                    <span aria-hidden="true" id="inline-submit-symbol">→</span>
                  </button>
                </div>
              </div>
              <button type="submit" class="visually-hidden" id="submit-btn">
                {t(strings.home.modal.submitBtn)}
              </button>
              <div id="error-message" class="error-message" aria-live="polite"></div>
            </form>
            <div class="panel-text" id="login-panel-title">
              <span class="panel-intro">{t(strings.home.inline.prompt)}</span>
              <span class="panel-copy">{t(strings.home.inline.note)}</span>
            </div>
          </aside>
        </div>
      </section>
    </main>

    <SiteFooter className="landing-footer" lang={Astro.locals.lang ?? 'en'} showNav={false} />

    <style>
      main {
        flex: 1;
      }

      .landing-shell {
        position: relative;
        overflow: clip;
      }

      .landing-hero {
        position: relative;
        padding: var(--space-xl) 0 var(--space-lg);
        min-height: min(820px, calc(100vh - 120px));
        display: flex;
        align-items: center;
      }

      .hero-disc {
        position: absolute;
        width: clamp(240px, 34vw, 520px);
        height: clamp(240px, 34vw, 520px);
        border-radius: 50%;
        background: var(--color-accent);
        left: clamp(-96px, -8vw, -32px);
        top: clamp(24px, 8vw, 96px);
        z-index: 0;
      }

      .hero-grid {
        position: relative;
        z-index: 1;
        width: 100%;
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-lg);
        align-items: center;
        justify-items: center;
      }

      .hero-copy {
        max-width: 760px;
        padding-top: var(--space-2xl);
        text-align: left;
        justify-self: stretch;
      }

      .eyebrow {
        font-size: var(--font-size-caption);
        letter-spacing: var(--tracking-heading);
        text-transform: uppercase;
      }

      .eyebrow {
        margin-bottom: var(--space-sm);
        max-width: none;
        white-space: nowrap;
      }

      .hero-copy h1 {
        font-size: clamp(64px, 12vw, 156px);
        line-height: 0.9;
        margin-bottom: var(--space-sm);
        max-width: 6ch;
      }

      .hero-subtitle {
        font-size: clamp(18px, 2.8vw, 32px);
        line-height: 1.2;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .hero-rule {
        width: min(100%, 280px);
        margin: var(--space-md) 0 0;
      }

      .login-panel {
        position: relative;
        width: min(100%, 420px);
        padding: 0;
        display: grid;
        gap: 10px;
        justify-items: center;
        text-align: center;
      }

      .panel-text {
        display: grid;
        gap: 4px;
        justify-items: center;
        width: min(100%, 388px);
      }

      .panel-intro {
        font-family: var(--font-display);
        font-size: var(--font-size-h3);
        line-height: 1.2;
        text-transform: uppercase;
        letter-spacing: var(--tracking-h3);
        display: block;
        width: min(100%, 372px);
      }

      .panel-copy {
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: var(--tracking-caption);
        font-size: var(--font-size-caption);
        line-height: 1.35;
        display: block;
        width: min(100%, 360px);
      }

      .login-trigger-panel {
        width: 100%;
        justify-content: center;
        min-height: 48px;
      }

      .inline-login-form {
        display: grid;
        gap: 12px;
        width: 100%;
      }

      .inline-entry-control {
        width: 100%;
        position: relative;
        min-height: 48px;
      }

      .inline-name-shell {
        position: absolute;
        inset: 0;
        display: none;
        align-items: center;
        overflow: hidden;
      }

      .login-trigger-panel,
      input.inline-name-input {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 48px;
        padding: 12px 32px;
        background: var(--color-text);
        color: var(--color-surface-text);
        -webkit-text-fill-color: var(--color-surface-text);
        border: none;
        text-transform: uppercase;
        letter-spacing: var(--tracking-h3);
        font-weight: 500;
        font-size: var(--font-size-body);
        line-height: 1;
        text-align: center;
        caret-color: currentColor;
        border-radius: 0;
        appearance: none;
        -webkit-appearance: none;
        box-shadow: none;
        cursor: pointer;
      }

      input.inline-name-input {
        padding-left: 64px;
        padding-right: 64px;
        transition:
          color 140ms ease,
          -webkit-text-fill-color 140ms ease,
          opacity 140ms ease;
      }

      input.inline-name-input::placeholder {
        color: var(--color-surface-text-placeholder);
        -webkit-text-fill-color: var(--color-surface-text-placeholder);
        opacity: 1;
        text-align: center;
        font-style: italic;
        font-weight: 400;
        letter-spacing: 0.02em;
        text-transform: none;
      }

      input.inline-name-input:focus {
        outline: none;
        border: none;
        cursor: text;
      }

      .inline-entry-control.is-active .login-trigger-panel {
        opacity: 0;
        pointer-events: none;
      }

      .inline-entry-control.is-active .inline-name-shell {
        display: flex;
      }

      .inline-entry-control.is-loading input.inline-name-input {
        color: transparent;
        -webkit-text-fill-color: transparent;
        cursor: progress;
      }

      .inline-entry-control.is-loading input.inline-name-input::placeholder {
        color: transparent;
        -webkit-text-fill-color: transparent;
      }

      .inline-progress-label {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px 64px;
        color: var(--color-surface-text-loading);
        font-size: 0.75rem;
        letter-spacing: var(--tracking-caption);
        text-transform: uppercase;
        pointer-events: none;
        opacity: 0;
        transition: opacity 140ms ease;
        z-index: 1;
      }

      .inline-entry-control.is-loading .inline-progress-label {
        opacity: 1;
      }

      .inline-submit-btn {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: var(--color-accent);
        padding: 0;
        margin: 0;
        font-family: var(--font-display);
        font-size: 1.35rem;
        line-height: 1;
        cursor: pointer;
        z-index: 2;
      }

      .inline-entry-control.is-loading .inline-submit-btn {
        cursor: progress;
      }

      .inline-submit-btn:hover {
        opacity: 0.8;
      }

      .inline-submit-btn:focus {
        outline: none;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .error-message {
        color: var(--color-error);
        font-size: 0.875rem;
        min-height: 1.25rem;
        order: 2;
      }

      .landing-footer {
        margin-top: 0;
      }

      @media (prefers-color-scheme: dark) {
        .landing-shell {
          background-color: var(--color-nyc-skyline-dark);
          background-image:
            radial-gradient(circle at 84% 24%, rgba(217, 106, 30, 0.18), transparent 0 26%),
            linear-gradient(180deg, rgba(22, 32, 64, 0.24), transparent 240px);
        }

        .landing-footer {
          background-color: var(--color-nyc-skyline-dark);
        }

        .hero-copy h1,
        .panel-intro {
          font-family: 'Peignot', 'Georgia', serif;
          letter-spacing: 0.05em;
          font-weight: 700;
        }

        .hero-subtitle,
        .panel-copy,
        input,
        button {
          font-family: 'Futura', 'Century Gothic', 'Trebuchet MS', sans-serif;
        }

        /* In dark mode, --color-text (background) and --color-surface-text
           both resolve to warm-cream — use --color-bg for legible text. */
        .login-trigger-panel,
        input.inline-name-input {
          color: var(--color-bg);
          -webkit-text-fill-color: var(--color-bg);
        }

        input.inline-name-input::placeholder {
          color: var(--color-bg);
          -webkit-text-fill-color: var(--color-bg);
          opacity: 0.45;
        }

        .login-panel {
          background: transparent;
        }
      }

      @media (max-width: 900px) {
        .landing-hero {
          min-height: auto;
          padding-top: var(--space-lg);
        }

        .hero-grid {
          grid-template-columns: 1fr;
        }

        .hero-copy {
          padding-top: var(--space-xl);
        }

        .login-panel {
          width: min(100%, 520px);
        }
      }

      @media (max-width: 768px) {
        .landing-hero {
          padding-bottom: var(--space-md);
        }

        .hero-copy {
          padding-top: 120px;
        }

        .hero-copy h1 {
          max-width: none;
        }

        .eyebrow {
          white-space: normal;
        }

        .panel-text {
          width: min(100%, 360px);
        }
      }
    </style>
  </WireframeLayout>

  <script is:inline data-astro-rerun define:vars={{ emptyError, defaultError, checkingLabel, submitLabel }}>
    (() => {
      window.__homeLoginController?.abort?.();

      const controller = new AbortController();
      window.__homeLoginController = controller;

      const { signal } = controller;
      const form = document.getElementById('login-form');
      const entryControl = document.getElementById('inline-entry-control');
      const trigger = document.getElementById('login-trigger');
      const nameInput = document.getElementById('name');
      const errorMessage = document.getElementById('error-message');
      const submitBtn = document.getElementById('submit-btn');
      const inlineSubmit = document.getElementById('inline-submit');
      const inlineSubmitSymbol = document.getElementById('inline-submit-symbol');

      if (!form || !entryControl || !trigger || !nameInput || !errorMessage || !submitBtn || !inlineSubmit) {
        return;
      }

      let isSubmitting = false;

      const activateInlineForm = () => {
        if (isSubmitting) return;
        entryControl.classList.add('is-active');
        requestAnimationFrame(() => {
          nameInput.focus();
          const length = nameInput.value.length ?? 0;
          nameInput.setSelectionRange(length, length);
        });
      };

      const collapseInlineForm = () => {
        if (isSubmitting || nameInput.value.trim()) return;
        entryControl.classList.remove('is-active');
      };

      const showError = (message) => {
        errorMessage.textContent = message;
      };

      const setSubmitState = (submitting) => {
        isSubmitting = submitting;
        entryControl.classList.toggle('is-loading', submitting);
        form.setAttribute('aria-busy', submitting ? 'true' : 'false');
        nameInput.disabled = submitting;
        inlineSubmit.disabled = submitting;
        submitBtn.disabled = submitting;
        submitBtn.textContent = submitting ? checkingLabel : submitLabel;

        if (inlineSubmitSymbol) {
          inlineSubmitSymbol.textContent = submitting ? '…' : '→';
        }

        inlineSubmit.setAttribute('aria-label', submitting ? checkingLabel : 'Submit name');
      };

      const navigateWithTransition = (href) => {
        const redirectLink = document.createElement('a');
        redirectLink.href = href;
        redirectLink.hidden = true;
        document.body.appendChild(redirectLink);
        redirectLink.click();
        redirectLink.remove();
      };

      trigger.addEventListener('click', () => {
        showError('');
        activateInlineForm();
      }, { signal });

      nameInput.addEventListener('input', () => {
        if (errorMessage.textContent) {
          showError('');
        }
      }, { signal });

      nameInput.addEventListener('blur', () => {
        window.setTimeout(() => {
          collapseInlineForm();
        }, 0);
      }, { signal });

      document.addEventListener('pointerdown', (event) => {
        if (!entryControl.contains(event.target)) {
          collapseInlineForm();
        }
      }, { signal });

      document.addEventListener('astro:before-swap', () => {
        controller.abort();
      }, { once: true, signal });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (isSubmitting) return;

        const name = nameInput.value.trim();
        if (!name) {
          showError(emptyError);
          activateInlineForm();
          return;
        }

        showError('');
        setSubmitState(true);

        let shouldResetState = true;

        try {
          const formData = new FormData();
          formData.append('name', name);

          const response = await fetch('/api/login', {
            method: 'POST',
            body: formData,
          });

          const data = await response.json();

          if (response.ok) {
            shouldResetState = false;
            navigateWithTransition(data.redirectPath || '/nyc');
            return;
          }

          showError(data.error || defaultError);
        } catch (error) {
          showError(defaultError);
        } finally {
          if (shouldResetState && !signal.aborted) {
            setSubmitState(false);
            activateInlineForm();
          }
        }
      }, { signal });
    })();
  </script>
) : (
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="color-scheme" content="light dark" />
      <link rel="icon" type="image/svg+xml" href={faviconLight} media="(prefers-color-scheme: light)" />
      <link rel="icon" type="image/svg+xml" href={faviconDark} media="(prefers-color-scheme: dark)" />
      <meta name="viewport" content="width=device-width" />
      <meta name="generator" content={Astro.generator} />
      <title>Chez Sargaux</title>
    </head>
    <body>
      <main>
        <h1>Chez Sargaux</h1>
      </main>
      <footer>
        <p>&copy; 2026</p>
      </footer>
    </body>
  </html>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; font-family: var(--font-body); }
    body { display: flex; flex-direction: column; background-color: var(--color-bg); color: var(--color-text); }
    main { flex: 1; display: flex; align-items: center; justify-content: center; }
    h1 { font-size: 3rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; }
    footer { padding: 2rem; text-align: center; }
    footer p { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
    @media (max-width: 768px) { h1 { font-size: 2rem; } }
  </style>
)}
