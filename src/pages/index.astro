---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { getAuthenticatedGuest } from '../lib/auth';
import { isSiteEnabled, isEnabled } from '../config/features';
import { strings } from '../content/strings';
import { createTranslator } from '../lib/i18n';
import LangSwitcher from '../components/LangSwitcher.astro';

// Only redirect if site is enabled and user is logged in
if (isSiteEnabled()) {
  const authGuest = getAuthenticatedGuest(Astro.cookies);
  if (authGuest) {
    const redirectPath = authGuest.eventInvitations.includes('nyc') ? '/nyc' : '/france';
    return Astro.redirect(redirectPath);
  }
}

const t = createTranslator(Astro.locals.lang ?? 'en');
---

{isSiteEnabled() ? (
  <WireframeLayout title={t(strings.home.pageTitle)}>
    <main>
      <section class="hero">
        <div class="hero-image">
          <ImagePlaceholder
            name="hero-main"
            folder="hero"
            description="Full-width couple photo — candid moment, engagement-style, or favorite photo together. Should feel warm and inviting."
            aspectRatio="21/9"
          />
        </div>
        <div class="hero-content">
          <h1>{t(strings.home.heroTitle)}</h1>
          <hr class="section-rule" />
          <p class="tagline">{t(strings.home.tagline)}</p>
          <div class="cta-area">
            <button class="btn btn-outline" id="login-trigger">{t(strings.home.ctaEnter)}</button>
          </div>
        </div>
      </section>

      {isEnabled('homepage.teaser') && (
        <section class="teaser">
          <p class="teaser-text">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
        </section>
      )}
    </main>

    <!-- Login Modal -->
    <div class="modal-backdrop" id="login-modal" aria-hidden="true" inert>
      <div class="modal" role="dialog" aria-labelledby="modal-title" aria-modal="true">
        <button class="modal-close" id="modal-close" aria-label="Close">&times;</button>

        <h2 id="modal-title">{t(strings.home.modal.title)}</h2>
        <p class="modal-subtitle">{t(strings.home.modal.subtitle)}</p>

        <form id="login-form">
          <label for="name" class="visually-hidden">{t(strings.home.modal.nameLabel)}</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder={t(strings.home.modal.namePlaceholder)}
            autocomplete="off"
            autocapitalize="words"
            spellcheck="false"
            required
          />
          <div id="error-message" class="error-message" aria-live="polite"></div>
          <button type="submit" class="btn btn-primary submit-btn" id="submit-btn">{t(strings.home.modal.submitBtn)}</button>
        </form>
      </div>
    </div>

    <footer class="site-footer">
      <div class="footer-row">
        <p class="copyright">&copy; 2026 Sam Gross</p>
        <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
      </div>
    </footer>


    <style>
    main {
      flex: 1;
    }

    .hero {
      display: flex;
      flex-direction: column;
    }

    .hero-image {
      width: 100%;
    }

    .hero-content {
      padding: var(--space-xl) var(--page-margin);
      text-align: center;
      max-width: var(--content-max-width);
      margin: 0 auto;
      width: 100%;
    }

    .hero-content .section-rule {
      max-width: 120px;
      margin: var(--space-md) auto;
    }

    .tagline {
      font-size: var(--font-size-h3);
      color: var(--color-text-muted);
      margin-bottom: var(--space-lg);
    }

    .cta-area {
      margin-top: var(--space-sm);
    }

    /* Teaser */
    .teaser {
      padding: var(--space-xl) var(--page-margin);
      max-width: 640px;
      margin: 0 auto;
      text-align: center;
      content-visibility: auto;
      contain-intrinsic-size: 200px;
    }

    .teaser-text {
      color: var(--color-text-muted);
      line-height: 1.8;
    }

    /* Modal */
    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1001;
      padding: var(--space-sm);
      opacity: 1;
      transition: opacity 0.2s;
    }

    .modal-backdrop[aria-hidden="true"] {
      opacity: 0;
      pointer-events: none;
    }

    .modal {
      background: var(--color-bg);
      padding: var(--space-lg);
      max-width: 400px;
      width: 100%;
      position: relative;
      transform: scale(1);
      transition: transform 0.2s;
    }

    .modal-backdrop[aria-hidden="true"] .modal {
      transform: scale(0.95);
    }

    .modal-close {
      position: absolute;
      top: var(--space-sm);
      right: var(--space-sm);
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--color-text-muted);
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-close:hover {
      color: var(--color-text);
    }

    .modal h2 {
      margin-bottom: var(--space-xs);
      text-align: center;
    }

    .modal-subtitle {
      color: var(--color-text-muted);
      text-align: center;
      margin-bottom: var(--space-md);
      font-size: 0.9375rem;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    form input {
      text-align: center;
    }

    .error-message {
      color: var(--color-error);
      font-size: 0.875rem;
      text-align: center;
      min-height: 1.25rem;
    }

    .submit-btn {
      width: 100%;
    }

    .submit-btn:disabled {
      cursor: not-allowed;
    }

    .footer-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    @media (max-width: 768px) {
      .hero-content {
        padding: var(--space-lg) var(--page-margin-mobile);
      }

      .tagline {
        font-size: var(--font-size-body);
      }
    }
    </style>
  </WireframeLayout>

  <script is:inline type="module">
    const modal = document.getElementById('login-modal');
    const trigger = document.getElementById('login-trigger');
    const closeBtn = document.getElementById('modal-close');
    const nameInput = document.getElementById('name');
    const form = document.getElementById('login-form');
    const errorMessage = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');

    const openModal = () => {
      if (modal) {
        modal.setAttribute('aria-hidden', 'false');
        modal.removeAttribute('inert');
      }
      document.body.style.overflow = 'hidden';
      nameInput?.focus();
    };

    const closeModal = () => {
      if (modal) {
        modal.setAttribute('aria-hidden', 'true');
        modal.setAttribute('inert', '');
      }
      document.body.style.overflow = '';
      if (errorMessage) errorMessage.textContent = '';
    };

    const showError = (message) => {
      if (errorMessage) {
        errorMessage.textContent = message;
      }
    };

    trigger?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);

    // Close on backdrop click
    modal?.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });

    // Close on Escape
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') {
        closeModal();
      }
    });

    // Handle form submission
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const name = nameInput?.value.trim() ?? '';
      if (!name) {
        showError('Please enter your name');
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Checking...';
      }

      try {
        const formData = new FormData();
        formData.append('name', name);

        const response = await fetch('/api/login', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (response.ok) {
          window.location.href = data.redirectPath || '/nyc';
        } else {
          showError(data.error || 'Something went wrong. Please try again.');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Continue';
          }
        }
      } catch (error) {
        showError('Something went wrong. Please try again.');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Continue';
        }
      }
    });
  </script>
) : (
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="color-scheme" content="light dark" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" media="(prefers-color-scheme: light)" />
      <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />
      <meta name="viewport" content="width=device-width" />
      <meta name="generator" content={Astro.generator} />
      <title>Chez Sargaux</title>
    </head>
    <body>
      <main>
        <h1>Chez Sargaux</h1>
      </main>
      <footer>
        <p>&copy; 2026</p>
      </footer>
    </body>
  </html>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; font-family: var(--font-body); }
    body { display: flex; flex-direction: column; background-color: var(--color-bg); color: var(--color-text); }
    main { flex: 1; display: flex; align-items: center; justify-content: center; }
    h1 { font-size: 3rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; }
    footer { padding: 2rem; text-align: center; }
    footer p { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
    @media (max-width: 768px) { h1 { font-size: 2rem; } }
  </style>
)}
