---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import { strings } from '../content/strings';
import { createTranslator } from '../lib/i18n';
import LangSwitcher from '../components/LangSwitcher.astro';
import exifr from 'exifr';
import path from 'path';

const t = createTranslator(Astro.locals.lang ?? 'en');
const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];

// Format a Date as "Month Day, Year" using UTC fields (EXIF stores local time, exifr parses as UTC)
function formatExifDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}

// All 16 couple photos (photo_1.jpeg is already in the hero)
const allPhotos = Array.from({ length: 16 }, (_, i) => `/images/couple/couple - ${i + 1}.jpeg`);

// Read EXIF dates at build time
const exifDates = await Promise.all(
  allPhotos.map(async (src) => {
    try {
      const filePath = path.join(process.cwd(), 'public', src);
      const data = await exifr.parse(filePath, ['DateTimeOriginal']);
      return data?.DateTimeOriginal ? formatExifDate(data.DateTimeOriginal) : null;
    } catch {
      return null;
    }
  })
);
const photosWithDates = allPhotos.map((src, i) => ({ src, date: exifDates[i] }));

// Pick 6 at random on every render, each with a slight rotation and vertical offset
const shuffled = [...photosWithDates].sort(() => Math.random() - 0.5).slice(0, 6);
const scattered = shuffled.map(({ src, date }) => ({
  src,
  alt: `Sam and Margaux`,
  date,
  rotate: (Math.random() * 10 - 5).toFixed(1),   // –5° to +5°
  ty: (Math.random() * 48 - 24).toFixed(0),        // –24px to +24px
}));
---

<WireframeLayout title={t(strings.couple.pageTitle)} description="Shared page for Sam and Margaux" event="nyc">
  <header class="site-header couple-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions couple-nav-actions">
        <span class="couple-nav-label">{t(strings.couple.navLabel)}</span>
        {eventInvitations.includes('nyc') && (
          <a href="/nyc" class="couple-event-link">NYC</a>
        )}
        {eventInvitations.includes('france') && (
          <a href="/france" class="couple-event-link">France</a>
        )}
      </div>
    </nav>
  </header>

  <main class="couple-shell">
    <section class="couple-hero">
      <div class="couple-disc couple-disc--amber" aria-hidden="true" transition:name="event-disc" transition:persist="couple-disc-amber"></div>
      <div class="couple-disc couple-disc--blue" aria-hidden="true" transition:persist="couple-disc-blue"></div>
      <div class="couple-ribbon couple-ribbon--moss" aria-hidden="true" transition:persist="couple-ribbon-moss"></div>
      <div class="couple-ribbon couple-ribbon--espresso" aria-hidden="true" transition:persist="couple-ribbon-espresso"></div>

      <div class="couple-grid page-content">
        <div class="couple-copy">
          <p class="couple-eyebrow">{t(strings.couple.eyebrow)}</p>
          <h1>{t(strings.couple.heroTitle)}</h1>
          <p class="couple-subtitle">{t(strings.couple.subtitle)}</p>
          <hr class="section-rule couple-rule" />
        </div>

        <aside class="couple-panel" aria-labelledby="couple-panel-title">
          <div class="photo-card">
            <div class="photo-card-inner">
              <div class="photo-label-row">
                <span class="photo-label" id="couple-panel-title">{t(strings.couple.photoLabel)}</span>
                <span class="photo-label photo-label--muted">Chez Sargaux</span>
              </div>
              <figure class="couple-photo-frame" transition:persist="couple-photo-frame">
                <img src="/images/couple/photo_1.jpeg" alt="Sam and Margaux together" class="couple-photo" />
              </figure>
              <p class="photo-caption">{t(strings.couple.photoCaption)}</p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="couple-gallery" aria-label="Photos">
      <div class="gallery-scatter">
        {scattered.map(({ src, alt, date, rotate, ty }) => (
          <div class="photo-card gallery-scatter-card" style={`--rotate: ${rotate}deg; --ty: ${ty}px`}>
            <div class="photo-card-inner">
              <div class="photo-label-row">
                <span class="photo-label photo-label--muted">{date ?? 'Chez Sargaux'}</span>
              </div>
              <figure class="couple-photo-frame">
                <img src={src} alt={alt} loading="lazy" decoding="async" class="couple-photo" />
              </figure>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <footer class="site-footer couple-footer">
    <nav>
      <a href="/registry">{t(strings.global.registry)}</a>
      {guest && (
        <>
          <span> · </span>
          <span class="guest-name">{guest}</span>
        </>
      )}
      <span> · </span>
      <a href="/api/logout">{t(strings.global.logout)}</a>
    </nav>
    <div class="footer-row">
      <p class="copyright">{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  .couple-header {
    background:
      linear-gradient(90deg, rgba(241, 236, 227, 0.98), rgba(241, 236, 227, 0.9)),
      linear-gradient(120deg, rgba(217, 106, 30, 0.12), rgba(27, 58, 107, 0.1));
    border-bottom: 1px solid rgba(47, 63, 54, 0.18);
    backdrop-filter: blur(14px);
  }

  .couple-nav-actions {
    gap: 12px;
  }

  .couple-nav-label {
    font-size: var(--font-size-caption);
    letter-spacing: var(--tracking-caption);
    text-transform: uppercase;
    color: rgba(58, 46, 38, 0.7);
  }

  .couple-event-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 72px;
    min-height: 32px;
    padding: 0 16px;
    border-radius: 999px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    font-size: var(--font-size-caption);
    border: 1px solid rgba(47, 63, 54, 0.18);
    background: rgba(241, 236, 227, 0.72);
    color: var(--color-text);
  }

  .couple-event-link:hover {
    color: var(--color-text);
    border-color: rgba(217, 106, 30, 0.4);
    background: rgba(241, 236, 227, 0.94);
  }

  .couple-shell {
    position: relative;
    overflow: clip;
    flex: 1;
  }

  .couple-hero {
    position: relative;
    min-height: min(840px, calc(100vh - 112px));
    padding: var(--space-xl) 0 var(--space-lg);
    display: flex;
    align-items: center;
    background:
      radial-gradient(circle at 16% 20%, rgba(217, 106, 30, 0.16), transparent 32%),
      radial-gradient(circle at 88% 14%, rgba(27, 58, 107, 0.16), transparent 28%),
      linear-gradient(150deg, rgba(241, 236, 227, 1) 0%, rgba(241, 236, 227, 0.96) 48%, rgba(58, 46, 38, 0.08) 100%);
  }

  .couple-disc {
    position: absolute;
    border-radius: 50%;
    filter: blur(0.2px);
  }

  .couple-disc--amber {
    width: clamp(220px, 28vw, 420px);
    height: clamp(220px, 28vw, 420px);
    left: clamp(-72px, -4vw, -24px);
    top: 72px;
    background: rgba(217, 106, 30, 0.9);
  }

  .couple-disc--blue {
    width: clamp(180px, 20vw, 280px);
    height: clamp(180px, 20vw, 280px);
    right: clamp(16px, 6vw, 120px);
    top: clamp(40px, 10vw, 120px);
    background: rgba(27, 58, 107, 0.88);
  }

  .couple-ribbon {
    position: absolute;
    border-radius: 999px;
    transform: rotate(-12deg);
    opacity: 0.76;
  }

  .couple-ribbon--moss {
    width: min(480px, 58vw);
    height: 24px;
    right: -40px;
    bottom: 120px;
    background: rgba(47, 63, 54, 0.9);
  }

  .couple-ribbon--espresso {
    width: min(340px, 46vw);
    height: 18px;
    left: 18%;
    bottom: 88px;
    background: rgba(58, 46, 38, 0.72);
  }

  .couple-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 420px);
    gap: var(--space-xl);
    align-items: center;
  }

  .couple-copy {
    max-width: 720px;
    padding-top: var(--space-2xl);
    position: relative;
    z-index: 2;
  }

  .couple-eyebrow {
    margin-bottom: var(--space-sm);
    font-size: var(--font-size-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    color: rgba(58, 46, 38, 0.8);
    max-width: 28rem;
  }

  .couple-copy h1 {
    font-size: clamp(60px, 10vw, 140px);
    line-height: 0.9;
    max-width: 6ch;
    margin-bottom: var(--space-sm);
  }

  .couple-subtitle {
    max-width: 34rem;
    font-size: clamp(18px, 2.5vw, 30px);
    line-height: 1.24;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(47, 63, 54, 0.82);
  }

  .couple-rule {
    width: min(100%, 320px);
    margin: var(--space-md) 0 0;
    border-top-color: rgba(47, 63, 54, 0.22);
  }

  .couple-panel {
    justify-self: end;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .photo-card {
    position: relative;
    border-radius: 32px;
    padding: 14px;
    background:
      linear-gradient(135deg, rgba(27, 58, 107, 0.18), rgba(217, 106, 30, 0.2) 54%, rgba(47, 63, 54, 0.18));
    box-shadow:
      0 28px 70px rgba(58, 46, 38, 0.16),
      inset 0 0 0 1px rgba(241, 236, 227, 0.4);
  }

  .photo-card-inner {
    border-radius: 24px;
    padding: 18px;
    background: rgba(241, 236, 227, 0.92);
    border: 1px solid rgba(58, 46, 38, 0.12);
    backdrop-filter: blur(10px);
  }

  .photo-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .photo-label {
    font-size: var(--font-size-caption);
    letter-spacing: var(--tracking-caption);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .photo-label--muted {
    color: rgba(58, 46, 38, 0.6);
  }

  .couple-photo-frame {
    margin: 0;
    border-radius: 18px;
    overflow: hidden;
    background: rgba(27, 58, 107, 0.08);
    border: 1px solid rgba(27, 58, 107, 0.12);
    aspect-ratio: 4 / 5;
  }

  .couple-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-caption {
    margin-top: 14px;
    font-size: var(--font-size-caption);
    line-height: 1.6;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    color: rgba(58, 46, 38, 0.72);
  }

  /* ── Gallery ─────────────────────────────────── */

  .couple-gallery {
    background: #F1ECE3;
    padding: var(--space-2xl) var(--space-lg);
    border-top: 1px solid rgba(47, 63, 54, 0.1);
  }

  .gallery-scatter {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 300px));
    justify-content: center;
    gap: 2rem 3rem;
    padding: var(--space-lg) var(--space-xl);
  }

  .gallery-scatter-card {
    transform: rotate(var(--rotate)) translateY(var(--ty));
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    position: relative;
    z-index: 1;
  }

  .gallery-scatter-card:hover {
    transform: rotate(0deg) translateY(0px) scale(1.03);
    z-index: 10;
    box-shadow:
      0 40px 100px rgba(58, 46, 38, 0.22),
      inset 0 0 0 1px rgba(241, 236, 227, 0.5);
  }

  @media (max-width: 900px) {
    .gallery-scatter {
      grid-template-columns: repeat(2, minmax(0, 300px));
    }
  }

  @media (max-width: 540px) {
    .gallery-scatter {
      grid-template-columns: minmax(0, 340px);
    }

    .gallery-scatter-card {
      transform: rotate(var(--rotate));
    }
  }

  @media (prefers-color-scheme: dark) {
    .couple-gallery {
      background: #131d1a;
      border-top-color: rgba(241, 236, 227, 0.06);
    }
  }

  .couple-footer {
    border-top-color: rgba(47, 63, 54, 0.12);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: var(--space-xs);
  }

  @media (prefers-color-scheme: dark) {
    .couple-header {
      background:
        linear-gradient(90deg, rgba(15, 26, 46, 0.96), rgba(26, 36, 32, 0.9)),
        linear-gradient(120deg, rgba(217, 106, 30, 0.14), rgba(27, 58, 107, 0.18));
      border-bottom-color: rgba(241, 236, 227, 0.1);
    }

    .couple-nav-label {
      color: rgba(241, 236, 227, 0.6);
    }

    .couple-event-link {
      background: rgba(22, 32, 64, 0.72);
      border-color: rgba(241, 236, 227, 0.12);
      color: var(--color-surface-text);
    }

    .couple-event-link:hover {
      color: var(--color-surface-text);
      border-color: rgba(217, 106, 30, 0.42);
      background: rgba(22, 32, 64, 0.92);
    }

    .couple-hero {
      background:
        radial-gradient(circle at 16% 18%, rgba(217, 106, 30, 0.18), transparent 32%),
        radial-gradient(circle at 84% 16%, rgba(27, 58, 107, 0.28), transparent 30%),
        linear-gradient(145deg, #131d1a 0%, #101b31 56%, #1d2836 100%);
    }

    .couple-eyebrow {
      color: rgba(241, 236, 227, 0.72);
    }

    .couple-subtitle {
      color: rgba(241, 236, 227, 0.82);
    }

    .couple-rule {
      border-top-color: rgba(241, 236, 227, 0.16);
    }

    .photo-card {
      background:
        linear-gradient(135deg, rgba(27, 58, 107, 0.34), rgba(217, 106, 30, 0.28) 54%, rgba(47, 63, 54, 0.32));
      box-shadow:
        0 28px 80px rgba(0, 0, 0, 0.32),
        inset 0 0 0 1px rgba(241, 236, 227, 0.08);
    }

    .photo-card-inner {
      background: rgba(20, 28, 40, 0.9);
      border-color: rgba(241, 236, 227, 0.08);
    }

    .photo-label {
      color: rgba(241, 236, 227, 0.92);
    }

    .photo-label--muted,
    .photo-caption {
      color: rgba(241, 236, 227, 0.56);
    }

    .couple-photo-frame {
      background: rgba(241, 236, 227, 0.04);
      border-color: rgba(241, 236, 227, 0.08);
    }
  }

  @media (max-width: 900px) {
    .couple-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .couple-copy {
      padding-top: var(--space-xl);
    }

    .couple-panel {
      justify-self: stretch;
      max-width: 440px;
    }
  }

  @media (max-width: 768px) {
    .couple-header .site-nav {
      grid-template-columns: 1fr;
      justify-items: start;
      gap: 10px;
    }

    .couple-nav-actions {
      flex-wrap: wrap;
      justify-self: start;
    }

    .couple-hero {
      min-height: auto;
      padding: var(--space-lg) 0;
    }

    .couple-disc--amber {
      width: 180px;
      height: 180px;
      left: -36px;
      top: 96px;
    }

    .couple-disc--blue {
      width: 132px;
      height: 132px;
      right: -24px;
      top: 44px;
    }

    .couple-ribbon--moss {
      height: 18px;
      width: 240px;
      right: -70px;
      bottom: 104px;
    }

    .couple-ribbon--espresso {
      width: 180px;
      height: 14px;
      left: 8%;
      bottom: 78px;
    }

    .couple-copy h1 {
      font-size: clamp(44px, 16vw, 76px);
    }

    .couple-subtitle {
      font-size: 18px;
    }

    .photo-card {
      border-radius: 24px;
      padding: 10px;
    }

    .photo-card-inner {
      border-radius: 18px;
      padding: 14px;
    }

    .footer-row {
      flex-wrap: wrap;
    }
  }
</style>
