---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import { strings } from '../content/strings';
import { couplePhotoDateFallbacks } from '../content/couplePhotoDates';
import { createTranslator } from '../lib/i18n';
import SiteFooter from '../components/SiteFooter.astro';
import exifr from 'exifr';
import path from 'path';

const t = createTranslator(Astro.locals.lang ?? 'en');
const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const singleEventHref = eventInvitations.includes('nyc')
  ? '/nyc'
  : eventInvitations.includes('france')
    ? '/france'
    : null;
const singleEventLabel = eventInvitations.includes('nyc')
  ? 'NYC'
  : eventInvitations.includes('france')
    ? 'France'
    : null;
const heroPhotoSrc = '/images/couple/photo_1.jpeg';

function formatExifDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}

function toWebp(src: string): string {
  return src.replace(/\.jpeg$/i, '.webp');
}

const allPhotos = Array.from({ length: 38 }, (_, i) => `/images/couple/couple - ${i + 1}.jpeg`);

const exifDates = await Promise.all(
  allPhotos.map(async (src) => {
    try {
      const filePath = path.join(process.cwd(), 'public', src);
      const data = await exifr.parse(filePath, ['DateTimeOriginal']);
      if (data?.DateTimeOriginal) {
        return formatExifDate(data.DateTimeOriginal);
      }
    } catch {
      // Fall through to the checked-in fallback when metadata is missing.
    }

    return couplePhotoDateFallbacks[src] ?? null;
  })
);

const photosWithDates = allPhotos.map((src, i) => ({ jpeg: src, webp: toWebp(src), date: exifDates[i] }));

let heroPhotoDate: string | null = null;
try {
  const heroFilePath = path.join(process.cwd(), 'public', heroPhotoSrc);
  const data = await exifr.parse(heroFilePath, ['DateTimeOriginal']);
  if (data?.DateTimeOriginal) {
    heroPhotoDate = formatExifDate(data.DateTimeOriginal);
  }
} catch {
  // Fall through to the checked-in fallback when metadata is missing.
}

heroPhotoDate ??= couplePhotoDateFallbacks[heroPhotoSrc] ?? null;

const storyRows = [
  {
    copy: [
      'After meeting through Hinge during the early weeks of Lockdown, Sam and Margaux went on a whirlwind series of pandemic-tinged dates in Brooklyn \u2014 sharing a synced viewing of Casablanca, picking up to-go cocktails and watching the sun set over Manhattan, and picnicking in the park.',
      'For the past 6 years, they\u2019ve shared a passion for exploring \u2014 from Brooklyn to cities around the world \u2014 looking at modern & contemporary art, collecting vinyls & city magnets, and watching visually arresting films. They\u2019ve visited countries across North America and Europe, and bonded over their nearly-identical trips to Japan just before they met. Last December, they organized a three-day long date in Amsterdam, where they became engaged.',
    ],
    doublePhotos: true,
  },
  {
    copy: [
      'Sam was born and raised in the suburbs of Washington, D.C. before attending the University of Maryland. He moved to New York in 2015 and never wants to live anywhere else.',
      'Margaux was born in the suburbs of Lille before moving to Paris, and later to Connecticut. She attended the University of Connecticut for undergraduate & graduate studies. She moved to New York in 2019 and never wants to live anywhere else.',
    ],
    doublePhotos: false,
  },
];

const closingLine = 'They are both so excited to celebrate with you!';

// 10 photos: 4 for row 1 (double × 2 sides), 2 for row 2, 2 for closing row
const shuffled = [...photosWithDates].sort(() => Math.random() - 0.5).slice(0, 10);

function makeCard(photo: (typeof photosWithDates)[0]) {
  return {
    ...photo,
    alt: 'Sam and Margaux' as const,
    rotate: (Math.random() * 6 - 3).toFixed(1),
    ty: (Math.random() * 24 - 12).toFixed(0),
  };
}

let idx = 0;
const galleryRows = storyRows.map(({ copy, doublePhotos }) => {
  const count = doublePhotos ? 2 : 1;
  const left = shuffled.slice(idx, idx + count).map(makeCard); idx += count;
  const right = shuffled.slice(idx, idx + count).map(makeCard); idx += count;
  return { copy, left, right, doublePhotos };
});
const closingCards = shuffled.slice(idx, idx + 2).map(makeCard);
---

<WireframeLayout title={t(strings.couple.pageTitle)} description="Shared page for Sam and Margaux" event="nyc">
  <header class="site-header couple-header" transition:name="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo" transition:name="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions couple-nav-actions">
        {showEventToggle && (
          <div class="event-toggle" transition:name="event-toggle">
            <a href="/nyc" class="event-toggle-item event-toggle-item--nyc">NYC</a>
            <span class="divider">|</span>
            <a href="/france" class="event-toggle-item event-toggle-item--france">France</a>
          </div>
        )}
        {!showEventToggle && singleEventHref && singleEventLabel && (
          <a href={singleEventHref} class="couple-event-nav-link">{singleEventLabel}</a>
        )}
      </div>
    </nav>
  </header>

  <main class="couple-shell">
    <section class="couple-hero">
      <div class="couple-disc couple-disc--amber" aria-hidden="true" transition:name="event-disc" transition:persist="couple-disc-amber"></div>
      <div class="couple-disc couple-disc--blue" aria-hidden="true" transition:persist="couple-disc-blue"></div>

      <div class="couple-grid page-content" transition:name="couple-content">
        <div class="couple-copy">
          <p class="couple-eyebrow">{t(strings.couple.eyebrow)}</p>
          <h1>{t(strings.couple.heroTitle)}</h1>
          <p class="couple-subtitle">Margaux Ancel &amp;<br />Sam Gross</p>
          <hr class="section-rule couple-rule" />
        </div>

        <aside class="couple-panel" aria-labelledby="couple-panel-title">
          <div class="photo-card">
            <div class="photo-card-inner">
              <div class="photo-label-row">
                <span class="photo-label" id="couple-panel-title">{heroPhotoDate ?? t(strings.couple.photoLabel)}</span>
                <span class="photo-label photo-label--muted">Chez Sargaux</span>
              </div>
              <figure class="couple-photo-frame" transition:persist="couple-photo-frame">
                <picture class="couple-photo-picture">
                  <source srcset={toWebp(heroPhotoSrc)} type="image/webp" />
                  <img src={heroPhotoSrc} alt="Sam and Margaux together" class="couple-photo" />
                </picture>
              </figure>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="couple-gallery" aria-label="Photos">
      <div class="couple-gallery-shell page-content">
        {galleryRows.map(({ copy, left, right, doublePhotos }) => (
          <div class={`gallery-row ${doublePhotos ? 'gallery-row--double' : 'gallery-row--single'}`}>
            <div class="photo-column photo-column--left">
              {left.map((photo) => (
                <article
                  class="photo-card gallery-scatter-card"
                  style={`--rotate: ${photo.rotate}deg; --ty: ${photo.ty}px;`}
                >
                  <div class="photo-card-inner">
                    <div class="photo-label-row">
                      <span class="photo-label photo-label--muted">{photo.date ?? 'Chez Sargaux'}</span>
                    </div>
                    <figure class="couple-photo-frame">
                      <picture class="couple-photo-picture">
                        <source srcset={photo.webp} type="image/webp" />
                        <img src={photo.jpeg} alt={photo.alt} loading="lazy" decoding="async" class="couple-photo" />
                      </picture>
                    </figure>
                  </div>
                </article>
              ))}
            </div>

            <article class="story-card" aria-label="Story">
              {copy.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </article>

            <div class="photo-column photo-column--right">
              {right.map((photo) => (
                <article
                  class="photo-card gallery-scatter-card"
                  style={`--rotate: ${photo.rotate}deg; --ty: ${photo.ty}px;`}
                >
                  <div class="photo-card-inner">
                    <div class="photo-label-row">
                      <span class="photo-label photo-label--muted">{photo.date ?? 'Chez Sargaux'}</span>
                    </div>
                    <figure class="couple-photo-frame">
                      <picture class="couple-photo-picture">
                        <source srcset={photo.webp} type="image/webp" />
                        <img src={photo.jpeg} alt={photo.alt} loading="lazy" decoding="async" class="couple-photo" />
                      </picture>
                    </figure>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}

        <div class="gallery-row closing-row">
          <div class="photo-column photo-column--left">
            {closingCards[0] && (
              <article
                class="photo-card gallery-scatter-card"
                style={`--rotate: ${closingCards[0].rotate}deg; --ty: ${closingCards[0].ty}px;`}
              >
                <div class="photo-card-inner">
                  <div class="photo-label-row">
                    <span class="photo-label photo-label--muted">{closingCards[0].date ?? 'Chez Sargaux'}</span>
                  </div>
                  <figure class="couple-photo-frame">
                    <picture class="couple-photo-picture">
                      <source srcset={closingCards[0].webp} type="image/webp" />
                      <img src={closingCards[0].jpeg} alt="Sam and Margaux" loading="lazy" decoding="async" class="couple-photo" />
                    </picture>
                  </figure>
                </div>
              </article>
            )}
          </div>

          <p class="closing-line">{closingLine}</p>

          <div class="photo-column photo-column--right">
            {closingCards[1] && (
              <article
                class="photo-card gallery-scatter-card"
                style={`--rotate: ${closingCards[1].rotate}deg; --ty: ${closingCards[1].ty}px;`}
              >
                <div class="photo-card-inner">
                  <div class="photo-label-row">
                    <span class="photo-label photo-label--muted">{closingCards[1].date ?? 'Chez Sargaux'}</span>
                  </div>
                  <figure class="couple-photo-frame">
                    <picture class="couple-photo-picture">
                      <source srcset={closingCards[1].webp} type="image/webp" />
                      <img src={closingCards[1].jpeg} alt="Sam and Margaux" loading="lazy" decoding="async" class="couple-photo" />
                    </picture>
                  </figure>
                </div>
              </article>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter guest={guest} lang={Astro.locals.lang ?? 'en'} />
</WireframeLayout>

<style>
  .couple-header {
    background: var(--color-bg);
  }

  .couple-nav-actions {
    gap: var(--space-sm);
  }

  .couple-event-nav-link {
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    font-size: var(--font-size-caption);
    font-weight: 500;
  }

  .couple-event-nav-link:hover {
    color: var(--color-text);
  }

  .couple-shell {
    position: relative;
    overflow: clip;
    flex: 1;
    background: var(--color-bg);
  }

  .couple-hero {
    position: relative;
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .couple-disc {
    position: absolute;
    border-radius: 50%;
    background: var(--color-accent);
    pointer-events: none;
  }

  .couple-disc--amber {
    width: clamp(240px, 28vw, 360px);
    height: clamp(240px, 28vw, 360px);
    top: calc(var(--space-xl) * -1);
    left: clamp(-140px, -10vw, -56px);
    opacity: 0.92;
    z-index: 1;
  }

  .couple-disc--blue {
    width: clamp(120px, 14vw, 184px);
    height: clamp(120px, 14vw, 184px);
    right: clamp(24px, 8vw, 120px);
    bottom: calc(var(--space-xl) * -0.5);
    background: var(--color-prussian-blue);
    opacity: 0.88;
    z-index: 1;
  }

  .couple-grid {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(400px, 480px);
    gap: var(--space-xl);
    align-items: start;
  }

  .couple-copy {
    max-width: 38rem;
    padding-top: var(--space-md);
  }

  .couple-eyebrow {
    margin-bottom: var(--space-sm);
    font-size: var(--font-size-caption);
    letter-spacing: var(--tracking-heading);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .couple-copy h1 {
    max-width: 6ch;
    margin-bottom: var(--space-sm);
    font-size: clamp(64px, 10vw, 128px);
    line-height: 0.88;
  }

  .couple-subtitle {
    max-width: 32rem;
    color: var(--color-text-muted);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .couple-rule {
    width: min(100%, 320px);
    margin: var(--space-lg) 0 0;
  }

  .couple-panel {
    justify-self: end;
    width: 100%;
  }

  .photo-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-text);
    border-radius: 30px 30px 22px 22px;
    padding: 14px;
  }

  .photo-card::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 12px;
    background: var(--color-accent);
    border-radius: 0 0 22px 22px;
    pointer-events: none;
    z-index: 0;
  }

  .photo-card::after {
    display: none;
  }

  .photo-card-inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-sm);
    min-height: 100%;
    padding: 12px 0 0;
    background: var(--color-bg);
    border-radius: 22px 22px 16px 16px;
    overflow: hidden;
  }

  .photo-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 0 12px;
  }

  .photo-label {
    color: var(--color-text);
    font-size: var(--font-size-caption);
    letter-spacing: var(--tracking-caption);
    text-transform: uppercase;
  }

  .photo-label--muted {
    color: var(--color-text-muted);
  }

  .couple-photo-frame {
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-surface);
    border-radius: 8px 8px 0 0;
  }

  .couple-photo-picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .couple-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .couple-gallery {
    padding: var(--space-2xl) 0;
    background: var(--color-bg);
  }

  .couple-gallery-shell {
    display: grid;
    gap: var(--space-2xl);
  }

  .gallery-row {
    display: grid;
    grid-template-columns: 5fr 3fr 5fr;
    gap: var(--space-xl) var(--space-lg);
    align-items: stretch;
  }

  .photo-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    justify-content: center;
  }

  .gallery-row--double .photo-column {
    justify-content: space-between;
  }

  /* Double-photo rows use a shorter aspect ratio so two fit comfortably */
  .gallery-row--double .couple-photo-frame {
    aspect-ratio: 3 / 4;
  }

  .story-card {
    display: grid;
    align-content: center;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
    min-height: 100%;
  }

  .story-card p {
    color: var(--color-text-muted);
  }

  .closing-line {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-style: italic;
    font-size: clamp(17px, 1.5vw, 20px);
  }

  .gallery-scatter-card {
    transform: rotate(var(--rotate)) translateY(var(--ty));
    transition: transform 0.2s ease;
  }

  .gallery-scatter-card:hover {
    transform: rotate(var(--rotate)) translateY(calc(var(--ty) - 4px));
  }

  .couple-panel .photo-card {
    background: var(--color-prussian-blue);
  }

  @media (max-width: 960px) {
    .couple-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .couple-copy {
      margin-inline: auto;
      text-align: center;
    }

    .couple-copy h1,
    .couple-subtitle,
    .couple-rule {
      margin-inline: auto;
    }

    .couple-panel {
      justify-self: center;
      max-width: 420px;
    }

    .gallery-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      justify-items: center;
    }

    .photo-column--left { order: 1; }
    .photo-column--right { order: 2; }

    .gallery-scatter-card {
      width: min(100%, 320px);
    }

    .story-card,
    .closing-line {
      order: 3;
      grid-column: 1 / -1;
      min-height: 0;
      width: min(100%, 36rem);
      margin-inline: auto;
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .couple-header .site-nav {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 10px;
    }

    .couple-nav-actions {
      flex-wrap: wrap;
      justify-self: center;
    }

    .couple-hero {
      padding: var(--space-xl) 0;
    }

    .couple-disc--amber {
      width: 192px;
      height: 192px;
      top: -72px;
      left: -72px;
    }

    .couple-disc--blue {
      width: 120px;
      height: 120px;
      right: -24px;
      bottom: 56px;
    }

    .couple-copy {
      padding-top: 0;
    }

    .couple-copy h1 {
      font-size: clamp(48px, 16vw, 80px);
    }

    .couple-subtitle {
      font-size: clamp(22px, 6vw, 32px);
    }

    .photo-card {
      padding: 12px;
      border-radius: 26px 26px 20px 20px;
    }

    .photo-card-inner {
      padding: 10px 0 0;
      border-radius: 18px 18px 14px 14px;
    }

    .photo-label-row {
      padding: 0 10px;
    }

  }

  @media (max-width: 640px) {
    .couple-gallery {
      padding: var(--space-xl) 0;
    }

    .couple-gallery-shell {
      gap: var(--space-xl);
    }

    .gallery-row {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      justify-items: center;
    }

    .photo-column,
    .story-card,
    .closing-line {
      grid-column: 1 / -1;
      order: 0;
    }

    .gallery-scatter-card {
      transform: rotate(var(--rotate));
    }

    .gallery-scatter-card:hover {
      transform: rotate(var(--rotate));
    }

    .story-card {
      order: 0;
      padding: var(--space-md);
    }

    .closing-line {
      order: 0;
      padding: var(--space-md);
    }
  }
</style>
