---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import '../../styles/nyc-subpages.css';
import { getLatestRSVP } from '../../lib/notion';
import { generateTokenIfPossible } from '../../lib/calendar';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';
import NycCalendarCta from '../../components/NycCalendarCta.astro';

const guest = Astro.locals.guest;
const guestId = Astro.locals.guestId;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const t = createTranslator(Astro.locals.lang ?? 'en');

const MAPS_KEY = process.env.GOOGLE_MAPS_STATIC_API_KEY;

const DINNER_LAT = 40.72235;
const DINNER_LNG = -73.95709;

function buildStaticMapUrl(lat: number, lng: number, zoom = 15): string {
  const u = new URL('https://maps.googleapis.com/maps/api/staticmap');
  u.searchParams.set('center', `${lat},${lng}`);
  u.searchParams.set('zoom', String(zoom));
  u.searchParams.set('size', '600x280');
  u.searchParams.set('scale', '2');
  u.searchParams.set('maptype', 'roadmap');
  u.searchParams.set('markers', `color:0xD96A1E|${lat},${lng}`);
  u.searchParams.set('key', MAPS_KEY!);
  return u.toString();
}

function buildMapsLink(lat: number, lng: number): string {
  const u = new URL('https://www.google.com/maps/search/');
  u.searchParams.set('api', '1');
  u.searchParams.set('query', `${lat},${lng}`);
  return u.toString();
}

const DANCING_LAT = 40.7131;
const DANCING_LNG = -73.9620;

const dinnerMapSrc = MAPS_KEY ? buildStaticMapUrl(DINNER_LAT, DINNER_LNG) : null;
const dinnerMapsHref = 'https://maps.app.goo.gl/f5YwZ9FCuj1osoLi7';

const dancingMapSrc = MAPS_KEY ? buildStaticMapUrl(DANCING_LAT, DANCING_LNG, 14) : null;
const dancingMapsHref = buildMapsLink(DANCING_LAT, DANCING_LNG);
const latestRSVP = guestId
  ? await getLatestRSVP(guestId, 'nyc').catch((error) => {
      console.error('Failed to load NYC RSVP status for calendar CTA:', error);
      return null;
    })
  : null;
const calendarToken = latestRSVP ? generateTokenIfPossible(guestId) : null;
---

<WireframeLayout title={t(strings.nyc.details.pageTitle)} fullTitle="Chez Sargaux | NYC — Event Details" event="nyc" page="details">

  <!-- Amber disc — z:2. Sits behind .nyc-page-main (z:5) during transitions. -->
  <div class="nyc-disc" aria-hidden="true" transition:name="event-disc"></div>

  <!-- Sticky header -->
  <header class="site-header nyc-header" transition:name="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        {showEventToggle && (
          <div class="event-toggle">
            <span class="active event-toggle-item event-toggle-item--nyc">{t(strings.global.toggle.nyc)}</span>
            <span class="divider">|</span>
            <a href="/france" class="event-toggle-item event-toggle-item--france">{t(strings.global.toggle.france)}</a>
          </div>
        )}
        <a href="/nyc/rsvp" class="btn nyc-rsvp-btn">{t(strings.global.rsvpBtn)}</a>
      </div>
    </nav>
  </header>

  <div class="nyc-page-main">
    <!-- Cream hero — disc is visible here before moss covers it on scroll -->
    <div class="details-hero">
      <div class="page-content details-hero-inner">
        <a href="/nyc" class="details-back">{t(strings.nav.backToEvent)}</a>
        <h1>{t(strings.nyc.details.heroTitle)}</h1>
        <p class="details-date">{t(strings.nyc.details.subtitle)}</p>
      </div>
    </div>
  </div>

  <!-- ═══════ Moss zone ═══════ -->
  <div class="nyc-page-moss">

  <!-- Section band: Details -->
  <div class="nyc-moss details-band">{t(strings.nyc.nav.details.title)}</div>

  <section class="nyc-moss details-section">
    <div class="page-content">
      <div class="nyc-info-table">
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.details.dressCode.heading)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.details.dressCode.value)}
            <span class="nyc-info-secondary">{t(strings.nyc.details.dressCode.note)}</span>
          </span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.details.whatToExpect.heading)}</span>
          <span class="nyc-info-val nyc-info-val--prose">{t(strings.nyc.details.whatToExpect.text)}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section band: Schedule -->
  <div class="nyc-moss details-band">{t(strings.nyc.details.schedule.heading)}</div>

  <section class="nyc-moss details-section">
    <div class="page-content">
      <div class="nyc-info-table">
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.details.schedule.dinner.time)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.details.schedule.dinner.title)}
            <span class="nyc-info-secondary">{t(strings.nyc.details.schedule.dinner.desc)}</span>
          </span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">6:23 PM</span>
          <span class="nyc-info-val">{t(strings.nyc.details.schedule.sunset)}</span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.details.schedule.dancing.time)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.details.schedule.dancing.title)}
            <span class="nyc-info-secondary">{t(strings.nyc.details.schedule.dancing.desc)}</span>
          </span>
        </div>
      </div>
      <NycCalendarCta
        token={calendarToken}
        label={t(strings.nyc.calendar.addBtn)}
        note={t(strings.nyc.details.calendar.note)}
        unavailableNote={t(strings.nyc.calendar.unavailableNote)}
      />
    </div>
  </section>

  <!-- Section band: Venues -->
  <div class="nyc-moss details-band">{t(strings.nyc.details.venues.heading)}</div>

  <section class="nyc-moss details-venues">
    <div class="page-content">
      <div class="venue-grid">

        <!-- Dinner venue -->
        <div class="venue-card">
          <div class="venue-photo">
            <img
              src="/images/nyc/bar-blondeau.avif"
              alt="Interior of Bar Blondeau at the Wythe Hotel, Brooklyn"
              class="venue-photo-img"
              loading="eager"
            />
          </div>
          <div class="venue-body">
            <div class="venue-text">
              <p class="venue-type">Celebration</p>
              <h3 class="venue-name">{t(strings.nyc.details.venues.dinner.name)}</h3>
              <p class="venue-address">{t(strings.nyc.details.venues.dinner.address)}</p>
            </div>
            <div class="venue-map-section">
              {dinnerMapSrc && (
                <a
                  href={dinnerMapsHref}
                  class="venue-map-link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open Bar Blondeau in Google Maps"
                >
                  <img
                    class="venue-map"
                    src={dinnerMapSrc}
                    alt="Map of Bar Blondeau at the Wythe Hotel, Brooklyn"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    width="600"
                    height="280"
                  />
                </a>
              )}
              <a href={dinnerMapsHref} class="venue-directions-link" target="_blank" rel="noopener noreferrer">
                Get Directions →
              </a>
            </div>
          </div>
        </div>

        <!-- Dancing venue (TBD) -->
        <div class="venue-card">
          <div class="venue-photo">
            <img
              src="/images/nyc/blondeau-placeholder.avif"
              alt="Dancing venue"
              class="venue-photo-img"
              loading="lazy"
            />
          </div>
          <div class="venue-body">
            <div class="venue-text">
              <p class="venue-type">{t(strings.nyc.details.venues.dancing.title)}</p>
              <h3 class="venue-name">{t(strings.nyc.details.venues.dancing.name)}</h3>
              <p class="venue-address">Williamsburg, Brooklyn</p>
            </div>
            <div class="venue-map-section">
              {dancingMapSrc && (
                <a
                  href={dancingMapsHref}
                  class="venue-map-link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open Williamsburg area in Google Maps"
                >
                  <img
                    class="venue-map"
                    src={dancingMapSrc}
                    alt="Map of Williamsburg, Brooklyn"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    width="600"
                    height="280"
                  />
                </a>
              )}
              <a
                href="https://maps.google.com"
                class="venue-directions-link venue-directions-link--disabled"
                aria-disabled="true"
                tabindex="-1"
              >
                Get Directions →
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="nyc-moss nyc-footer site-footer">
    <nav>
      <a href="/registry">{t(strings.global.registry)}</a>
      <span> · </span>
      <span class="guest-name">{guest}</span>
      <span> · </span>
      <a href="/api/logout">{t(strings.global.logout)}</a>
    </nav>
    <div class="nyc-footer-meta">
      <p class="copyright">{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>

  </div><!-- .nyc-page-moss -->

</WireframeLayout>

<style is:global>

  /* ── Foundation ──────────────────────────────────── */

  html[data-event="nyc"] body {
    background: var(--color-warm-cream) !important;
    color: var(--color-dark-moss) !important;
    overflow-x: hidden;
  }

  /* ── Header ──────────────────────────────────────── */

  html[data-event="nyc"] .nyc-header {
    background: var(--color-warm-cream) !important;
    border-bottom: 1px solid rgba(23, 50, 11, 0.18) !important;
  }

  html[data-event="nyc"] .nyc-header .site-logo,
  html[data-event="nyc"] .nyc-header .site-logo:hover,
  html[data-event="nyc"] .nyc-header .event-toggle .active,
  html[data-event="nyc"] .nyc-header .event-toggle .divider {
    color: var(--color-dark-moss) !important;
  }

  html[data-event="nyc"] .nyc-header .event-toggle a {
    color: rgba(23, 50, 11, 0.4) !important;
  }

  html[data-event="nyc"] .nyc-rsvp-btn {
    background: var(--color-dark-moss) !important;
    color: var(--color-warm-cream) !important;
    height: 32px;
    padding: 0 24px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    line-height: 1;
    transition: opacity 0.15s;
    border: none;
  }

  html[data-event="nyc"] .nyc-rsvp-btn:hover {
    opacity: 0.85;
    color: var(--color-warm-cream) !important;
  }

  /* ── Amber disc — z:2 ────────────────────────────── */

  html[data-event="nyc"] .nyc-disc {
    position: fixed;
    width: clamp(260px, 44vh, 500px);
    height: clamp(260px, 44vh, 500px);
    background: var(--color-burnt-amber);
    border-radius: 50%;
    top: 3vh;
    left: -8%;
    z-index: 2;
  }

  /* ── Cream hero ──────────────────────────────────── */

  html[data-event="nyc"] .details-hero {
    position: relative;
    z-index: 3; /* sits above disc so text is readable */
    min-height: 38vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 48px;
  }

  html[data-event="nyc"] .details-hero-inner {
    width: 100%;
  }

  html[data-event="nyc"] .details-back,
  html[data-event="nyc"] .details-back:link,
  html[data-event="nyc"] .details-back:visited {
    display: inline-block;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-dark-moss);
    -webkit-text-fill-color: var(--color-dark-moss);
    text-decoration: none;
    margin-bottom: 24px;
    transition: opacity 0.15s;
  }

  html[data-event="nyc"] .details-back:hover {
    opacity: 0.6;
    color: var(--color-dark-moss);
    -webkit-text-fill-color: var(--color-dark-moss);
  }

  html[data-event="nyc"] .details-hero h1 {
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 500;
    line-height: 0.93;
    color: var(--color-dark-moss);
    text-transform: uppercase;
    margin: 0 0 20px;
    white-space: nowrap;
  }

  /* ── Moss zone — z:4 ─────────────────────────────── */

  html[data-event="nyc"] .nyc-moss {
    position: relative;
    z-index: 4;
  }

  html[data-event="nyc"] .details-section,
  html[data-event="nyc"] .details-venues,
  html[data-event="nyc"] .nyc-footer {
    background: var(--color-dark-moss) !important;
    color: var(--color-warm-cream) !important;
  }

  /* Section band (cream-on-moss label strip) */
  html[data-event="nyc"] .details-band {
    position: relative;
    z-index: 4;
    padding: 14px 64px;
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--color-warm-cream) !important;
    color: rgba(23, 50, 11, 0.5) !important;
    border-top: 1px solid rgba(23, 50, 11, 0.1);
  }

  html[data-event="nyc"] .details-section {
    padding: 40px 0 48px;
  }

  /* ── Info table (shared with index) ──────────────── */

  html[data-event="nyc"] .nyc-info-table {
    margin: 0;
  }

  html[data-event="nyc"] .nyc-info-row {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 249, 240, 0.15);
    align-items: baseline;
  }

  html[data-event="nyc"] .nyc-info-row:first-child {
    border-top: none;
  }

  html[data-event="nyc"] .nyc-info-row:last-child {
    border-bottom: none;
  }

  html[data-event="nyc"] .nyc-info-key {
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 249, 240, 0.45);
    padding-top: 3px;
  }

  html[data-event="nyc"] .nyc-info-val {
    font-size: var(--font-size-body);
    line-height: 1.6;
    color: var(--color-warm-cream);
  }

  html[data-event="nyc"] .nyc-info-val--prose {
    white-space: pre-line;
    max-width: 760px;
  }

  html[data-event="nyc"] .nyc-info-secondary {
    display: block;
    font-size: var(--font-size-caption);
    color: rgba(255, 249, 240, 0.45);
    margin-top: 4px;
  }

  /* ── Venues section ──────────────────────────────── */

  html[data-event="nyc"] .details-venues {
    padding: 40px 0 48px;
  }

  html[data-event="nyc"] .venue-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px; /* tight gap — border-like gap between cards */
  }

  html[data-event="nyc"] .venue-card {
    background: rgba(255, 249, 240, 0.04);
    display: flex;
    flex-direction: column;
  }

  html[data-event="nyc"] .venue-photo-img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  html[data-event="nyc"] .venue-body {
    padding: 20px 24px 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  html[data-event="nyc"] .venue-map-section {
    margin-top: auto;
  }

  html[data-event="nyc"] .venue-type {
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-burnt-amber);
    margin: 0 0 8px;
  }

  html[data-event="nyc"] .venue-name {
    font-size: var(--font-size-h3);
    font-weight: 500;
    color: var(--color-warm-cream);
    margin: 0 0 6px;
    line-height: 1.2;
  }

  html[data-event="nyc"] .venue-address {
    font-size: var(--font-size-body);
    color: rgba(255, 249, 240, 0.5);
    margin: 0 0 20px;
    line-height: 1.5;
  }

  /* Static map tile */
  html[data-event="nyc"] .venue-map-link {
    display: block;
    text-decoration: none;
    overflow: hidden;
  }

  html[data-event="nyc"] .venue-map {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 600 / 280;
    object-fit: cover;
    transition: opacity 0.2s;
    filter: saturate(0.8) brightness(0.95);
  }

  html[data-event="nyc"] .venue-map-link:hover .venue-map {
    opacity: 0.85;
  }

  /* Directions link — shown below map tile (or alone when no API key) */
  html[data-event="nyc"] .venue-directions-link,
  html[data-event="nyc"] .venue-directions-link:link,
  html[data-event="nyc"] .venue-directions-link:visited {
    display: inline-block;
    margin-top: 12px;
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-burnt-amber);
    -webkit-text-fill-color: var(--color-burnt-amber);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  html[data-event="nyc"] .venue-directions-link:hover {
    opacity: 0.75;
    color: var(--color-burnt-amber);
    -webkit-text-fill-color: var(--color-burnt-amber);
  }

  html[data-event="nyc"] .venue-directions-link--disabled {
    opacity: 0.3;
    pointer-events: none;
    cursor: default;
  }

  /* TBD venue */
  /* ── Footer ──────────────────────────────────────── */

  html[data-event="nyc"] .nyc-footer {
    border-top-color: rgba(255, 249, 240, 0.12) !important;
  }

  html[data-event="nyc"] .nyc-footer nav a,
  html[data-event="nyc"] .nyc-footer nav span,
  html[data-event="nyc"] .nyc-footer .copyright {
    color: rgba(255, 249, 240, 0.4) !important;
  }

  html[data-event="nyc"] .nyc-footer nav a:hover {
    color: var(--color-warm-cream) !important;
  }

  html[data-event="nyc"] .nyc-footer-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 8px;
  }

  /* ── Dark mode ────────────────────────────────────── */

  @media (prefers-color-scheme: dark) {
    html[data-event="nyc"] body {
      background: var(--color-dark-moss) !important;
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .nyc-header {
      background: var(--color-dark-moss) !important;
      border-bottom-color: rgba(255, 249, 240, 0.08) !important;
    }

    html[data-event="nyc"] .nyc-header .site-logo,
    html[data-event="nyc"] .nyc-header .site-logo:hover,
    html[data-event="nyc"] .nyc-header .event-toggle .active,
    html[data-event="nyc"] .nyc-header .event-toggle .divider {
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .nyc-header .event-toggle a {
      color: rgba(255, 249, 240, 0.45) !important;
    }

    html[data-event="nyc"] .nyc-rsvp-btn {
      background: var(--color-burnt-amber) !important;
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .details-hero {
      /* Dark mode: hero bg matches header */
    }

    html[data-event="nyc"] .details-hero h1 {
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .details-back,
    html[data-event="nyc"] .details-back:link,
    html[data-event="nyc"] .details-back:visited {
      color: rgba(255, 249, 240, 0.7) !important;
      -webkit-text-fill-color: rgba(255, 249, 240, 0.7) !important;
    }

    html[data-event="nyc"] .details-back:hover {
      opacity: 0.6 !important;
      color: rgba(255, 249, 240, 0.7) !important;
      -webkit-text-fill-color: rgba(255, 249, 240, 0.7) !important;
    }

    html[data-event="nyc"] .nyc-moss {
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .details-section,
    html[data-event="nyc"] .details-venues,
    html[data-event="nyc"] .nyc-footer {
      background: var(--color-nyc-skyline-dark) !important;
    }

    html[data-event="nyc"] .details-band {
      background: var(--color-dark-moss) !important;
      color: rgba(255, 249, 240, 0.4) !important;
      border-top-color: rgba(255, 249, 240, 0.06) !important;
    }

    html[data-event="nyc"] .nyc-info-row {
      border-bottom-color: rgba(255, 249, 240, 0.08) !important;
    }

    html[data-event="nyc"] .venue-map {
      filter: saturate(0.7) brightness(0.8);
    }
  }

  /* ── Mobile ───────────────────────────────────────── */

  @media (max-width: 768px) {
    html[data-event="nyc"] .nyc-disc {
      width: clamp(160px, 50vw, 260px);
      height: clamp(160px, 50vw, 260px);
      left: -18%;
      top: 72px;
    }

    html[data-event="nyc"] .details-hero {
      min-height: 28vh;
      padding-bottom: 32px;
    }

    html[data-event="nyc"] .details-hero h1 {
      font-size: clamp(40px, 12vw, 64px);
      white-space: normal;
    }

    html[data-event="nyc"] .details-band {
      padding-left: 24px;
      padding-right: 24px;
    }

    html[data-event="nyc"] .venue-grid {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    html[data-event="nyc"] .venue-body {
      padding: 16px 20px 24px;
    }
  }

</style>
