---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';

const guest = Astro.locals.guest;
const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.nyc.details.pageTitle)}>
  <header>
    <nav class="main-nav">
      <a href="/" class="logo">{t(strings.global.siteName)}</a>
      <a href="/nyc" class="back-link">{t(strings.nav.backToNyc)}</a>
    </nav>
  </header>

  <main>
    <h1>{t(strings.nyc.details.heroTitle)}</h1>
    <p class="subtitle">{t(strings.nyc.details.subtitle)} <span class="tentative">{t(strings.nyc.heroDateTentative)}</span></p>

    <!-- Schedule Timeline -->
    <section class="schedule">
      <h2>{t(strings.nyc.details.schedule.heading)}</h2>
      <div class="timeline">
        <div class="timeline-item">
          <span class="time">{t(strings.nyc.details.schedule.dinner.time)}</span>
          <div class="event">
            <h4>{t(strings.nyc.details.schedule.dinner.title)}</h4>
            <p>{t(strings.nyc.details.schedule.dinner.desc)}</p>
          </div>
        </div>
        <div class="timeline-item">
          <span class="time">{t(strings.nyc.details.schedule.dancing.time)}</span>
          <div class="event">
            <h4>{t(strings.nyc.details.schedule.dancing.title)}</h4>
            <p>{t(strings.nyc.details.schedule.dancing.desc)}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Venues - Responsive horizontal/vertical -->
    <section class="venues">
      <h2>{t(strings.nyc.details.venues.heading)}</h2>
      <div class="venue-grid">
        <div class="venue-card">
          <ImagePlaceholder
            name="nyc-dinner"
            folder="nyc"
            description="Dinner venue interior"
            aspectRatio="4/3"
          />
          <h3>{t(strings.nyc.details.venues.dinner.title)}</h3>
          <p>{t(strings.nyc.details.venues.dinner.name)}</p>
          <div class="map-placeholder">
            <!-- Google Maps Static API placeholder -->
            <p class="placeholder-note">{t(strings.nyc.details.venues.dinner.mapPlaceholder)}</p>
          </div>
        </div>
        <div class="venue-card">
          <ImagePlaceholder
            name="nyc-dancing"
            folder="nyc"
            description="Dancing venue"
            aspectRatio="4/3"
          />
          <h3>{t(strings.nyc.details.venues.dancing.title)}</h3>
          <p>{t(strings.nyc.details.venues.dancing.name)}</p>
          <div class="map-placeholder">
            <p class="placeholder-note">{t(strings.nyc.details.venues.dancing.mapPlaceholder)}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What to Expect -->
    <section class="what-to-expect">
      <h2>{t(strings.nyc.details.whatToExpect.heading)}</h2>
      <p>{t(strings.nyc.details.whatToExpect.text)}</p>
    </section>

    <!-- Dress Code -->
    <section class="dress-code">
      <h2>{t(strings.nyc.details.dressCode.heading)}</h2>
      <p><strong>{t(strings.nyc.details.dressCode.value)}</strong></p>
      <p>{t(strings.nyc.details.dressCode.note)}</p>
    </section>

    <!-- Calendar Subscribe -->
    <section class="calendar-section">
      <h2>{t(strings.nyc.details.calendar.heading)}</h2>
      <button class="calendar-btn" disabled>{t(strings.nyc.details.calendar.btn)}</button>
      <p class="placeholder-note">{t(strings.nyc.details.calendar.note)}</p>
    </section>
  </main>

  <footer>
    <p>{t(strings.global.copyright)}</p>
  </footer>
</WireframeLayout>

<style>
  header {
    border-bottom: 1px solid #e5e5e5;
  }

  .main-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: #1a1a1a;
  }

  .back-link {
    font-size: 0.875rem;
    color: #666;
    text-decoration: none;
  }

  .back-link:hover {
    color: #1a1a1a;
  }

  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #666;
    margin-bottom: 3rem;
  }

  .tentative {
    font-size: 0.875rem;
    font-style: italic;
  }

  section {
    margin-bottom: 3rem;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 0.5rem;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline-item {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .time {
    font-weight: 600;
    min-width: 80px;
    color: #1a1a1a;
  }

  .event h4 {
    margin: 0 0 0.25rem 0;
    font-weight: 500;
  }

  .event p {
    margin: 0;
    color: #666;
  }

  /* Venue Grid - Horizontal on desktop, vertical on mobile */
  .venue-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .venue-grid {
      grid-template-columns: 1fr;
    }
  }

  .venue-card {
    border: 1px solid #e5e5e5;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .venue-card h3 {
    margin: 1rem;
    font-size: 1.25rem;
    font-weight: 500;
  }

  .venue-card > p {
    margin: 0 1rem 1rem;
    color: #666;
  }

  .map-placeholder {
    margin: 1rem;
    padding: 2rem;
    background: #f5f5f5;
    border-radius: 0.25rem;
    text-align: center;
  }

  .placeholder-note {
    font-size: 0.875rem;
    color: #666;
    font-style: italic;
  }

  /* What to Expect */
  .what-to-expect p {
    line-height: 1.8;
    color: #444;
  }

  /* Dress Code */
  .dress-code p {
    margin: 0.5rem 0;
  }

  /* Calendar */
  .calendar-section {
    text-align: center;
    padding: 2rem;
    background: #f9f9f9;
    border-radius: 0.5rem;
  }

  .calendar-btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: #1a1a1a;
    color: white;
    text-decoration: none;
    border: none;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    cursor: pointer;
  }

  .calendar-btn:hover:not(:disabled) {
    background: #333;
  }

  .calendar-btn:disabled {
    background: #888;
    cursor: not-allowed;
  }

  /* Footer */
  footer {
    padding: 2rem;
    text-align: center;
    border-top: 1px solid #e5e5e5;
  }

  footer p {
    font-size: 0.875rem;
    color: #888;
  }
</style>
