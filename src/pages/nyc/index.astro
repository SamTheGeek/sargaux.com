---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { features } from '../../config/features';
import { generateToken } from '../../lib/calendar';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';
import skylineFill from '../../assets/nyc/skyline-fill.svg?raw';
import skylineOutline from '../../assets/nyc/skyline.svg?url';

const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const guestId = Astro.locals.guestId;
const calendarToken = (features.nyc.calendarSubscribe && guestId)
  ? generateToken(guestId)
  : null;
const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.nyc.pageTitle)} fullTitle="Chez Sargaux | NYC" description="NYC Wedding - October 2026" event="nyc">

  <!--
    Z-index stack (all in ROOT context — nothing creates an intermediate SC):

      body bg  var(--color-warm-cream)  cream
      z:1      hero text   position:fixed, top-left
      z:2      sun disc    position:fixed, right
      z:3      skyline     position:relative, in normal flow, scrolls over text
      z:4      moss sections  solid var(--color-dark-moss), cover disc + text as you scroll past

    Skyline colouring:
      Inline SVG (skyline-fill.svg) with fill="currentColor" — color driven by
      CSS var(--color-dark-moss) via .nyc-skyline-fill svg { color: ... }.
      Transparent sky above buildings is invisible against the cream body.
  -->

  <!-- Fixed amber disc, right side, z:2 -->
  <div class="nyc-disc" aria-hidden="true" transition:name="event-disc"></div>

  <!-- Sticky header, z:100 via base.css -->
  <header class="site-header nyc-header" transition:name="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo" transition:name="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        {showEventToggle && (
          <div class="event-toggle" transition:name="event-toggle">
            <span class="active event-toggle-item event-toggle-item--nyc">{t(strings.global.toggle.nyc)}</span>
            <span class="divider">|</span>
            <a href="/france" class="event-toggle-item event-toggle-item--france">{t(strings.global.toggle.france)}</a>
          </div>
        )}
        <a href="/nyc/rsvp" class="btn nyc-rsvp-btn" transition:name="header-rsvp">{t(strings.global.rsvpBtn)}</a>
      </div>
    </nav>
  </header>

  <!-- Fixed hero text, z:1 — stays put while skyline scrolls over it -->
  <div class="nyc-hero-text">
    <h1>New York<br>With Love</h1>
    <p class="nyc-date">{t(strings.nyc.heroDate)}</p>
    <hr class="nyc-rule">
    <p class="nyc-venue">{t(strings.nyc.where.dinner)} · Brooklyn</p>
  </div>

  <!--
    Spacer: transparent, in normal flow.
    Gives the page scroll depth so the skyline starts below the hero text.
    Approx: header height + enough room to read the heading before skyline intrudes.
  -->
  <div class="nyc-spacer" aria-hidden="true"></div>

  <!--
    Skyline: in normal flow, z:3, scrolls up over fixed text.
    Inline SVG uses fill="currentColor" so CSS --color-dark-moss drives the color.
    -5px horizontal overhang (CSS) ensures pixel-perfect edge-to-edge coverage.
  -->
  <div class="nyc-skyline-wrap" aria-hidden="true" transition:persist="nyc-skyline">
    <div class="nyc-skyline-img nyc-skyline-fill" set:html={skylineFill}></div>
    <img class="nyc-skyline-img nyc-skyline-outline" src={skylineOutline} alt="">
  </div>

  <!-- ═══════════════════════════════════
       Moss zone — z:4, solid bg covers
       fixed disc and text as you scroll
       ═══════════════════════════════════ -->

  <section class="nyc-moss nyc-info">
    <div class="nyc-info-inner page-content">
      <div class="nyc-info-table">
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.when.heading)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.when.date)}
            <span class="nyc-info-secondary">{t(strings.nyc.when.time)}</span>
          </span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.where.heading)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.where.dinner)}<br>
            80 Wythe Ave, 6th Floor · Brooklyn, NY<br>
            <span class="nyc-info-secondary">{t(strings.nyc.where.separator)} {t(strings.nyc.where.dancing)}</span>
          </span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.dressCode.heading)}</span>
          <span class="nyc-info-val">{t(strings.nyc.dressCode.value)}</span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.rsvpDeadline.heading)}</span>
          <span class="nyc-info-val">{t(strings.nyc.rsvpDeadline.value)}</span>
        </div>
      </div>
    </div>
  </section>

  <div class="nyc-moss nyc-calendar-band">{t(strings.nyc.calendar.heading)}</div>

  <section class="nyc-moss nyc-calendar">
    <div class="page-content nyc-calendar-inner">
      <div class="nyc-calendar-copy">
        <p class="nyc-calendar-label">{t(strings.nyc.calendar.heading)}</p>
        <p class="nyc-calendar-text">{t(strings.nyc.calendar.subtext)}</p>
      </div>
      <div class="nyc-calendar-actions">
        {calendarToken ? (
          <a
            href={`webcal://sargaux.com/api/calendar/${calendarToken}.ics`}
            class="nyc-calendar-btn calendar-btn-prominent"
          >
            {t(strings.nyc.calendar.addBtn)}
          </a>
        ) : (
          <>
            <button class="nyc-calendar-btn calendar-btn-prominent" disabled>
              {t(strings.nyc.calendar.addBtn)}
            </button>
            <p class="nyc-calendar-note">{t(strings.nyc.calendar.unavailableNote)}</p>
          </>
        )}
      </div>
    </div>
  </section>

  <div class="nyc-moss nyc-explore-band">{t(strings.global.explore)}</div>

  <section class="nyc-moss nyc-nav">
    <nav class="strip-nav page-content" aria-label="Event sections">
      <a href="/nyc/details" class="nyc-strip-link">
        <span class="nyc-strip-title">{t(strings.nyc.nav.details.title)}</span>
        <span class="nyc-strip-desc">{t(strings.nyc.nav.details.desc)}</span>
        <span class="nyc-strip-arrow">→</span>
      </a>
      <a href="/nyc/travel" class="nyc-strip-link">
        <span class="nyc-strip-title">{t(strings.nyc.nav.travel.title)}</span>
        <span class="nyc-strip-desc">{t(strings.nyc.nav.travel.desc)}</span>
        <span class="nyc-strip-arrow">→</span>
      </a>
      <a href="/couple" class="nyc-strip-link">
        <span class="nyc-strip-title">{t(strings.nyc.nav.couple.title)}</span>
        <span class="nyc-strip-desc">{t(strings.nyc.nav.couple.desc)}</span>
        <span class="nyc-strip-arrow">→</span>
      </a>
      <a href="/nyc/rsvp" class="nyc-strip-link nyc-strip-cta">
        <span class="nyc-strip-title">{t(strings.nyc.nav.rsvp.title)}</span>
        <span class="nyc-strip-desc">{t(strings.nyc.nav.rsvp.desc)}</span>
        <span class="nyc-strip-arrow">→</span>
      </a>
    </nav>
  </section>

  <footer class="nyc-moss nyc-footer site-footer">
    <nav>
      <a href="/registry">{t(strings.global.registry)}</a>
      <span> · </span>
      <span class="guest-name">{guest}</span>
      <span> · </span>
      <a href="/api/logout">{t(strings.global.logout)}</a>
    </nav>
    <div class="nyc-footer-meta">
      <p class="copyright">{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>

</WireframeLayout>

<style is:global>

  /* ── Foundation ─────────────────────────────── */

  html[data-event="nyc"] body {
    background: var(--color-warm-cream) !important;
    color: var(--color-dark-moss) !important;
    overflow-x: hidden; /* prevents horizontal scroll from skyline bleed */
  }

  /* ── Header ─────────────────────────────────── */

  html[data-event="nyc"] .nyc-header {
    background: var(--color-warm-cream) !important;
    border-bottom: 1px solid rgba(23, 50, 11, 0.18) !important;
  }

  html[data-event="nyc"] .nyc-header .site-logo,
  html[data-event="nyc"] .nyc-header .site-logo:hover,
  html[data-event="nyc"] .nyc-header .event-toggle .active,
  html[data-event="nyc"] .nyc-header .event-toggle .divider {
    color: var(--color-dark-moss) !important;
  }

  html[data-event="nyc"] .nyc-header .event-toggle a {
    color: rgba(23, 50, 11, 0.4) !important;
  }

  html[data-event="nyc"] .nyc-rsvp-btn {
    background: var(--color-dark-moss) !important;
    color: var(--color-warm-cream) !important;
    height: 32px;
    padding: 0 24px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    line-height: 1;
    transition: opacity 0.15s;
    border: none;
  }

  html[data-event="nyc"] .nyc-rsvp-btn:hover {
    opacity: 0.85;
    color: var(--color-warm-cream) !important;
  }

  /* ── Sun disc — z:2 ─────────────────────────── */

  html[data-event="nyc"] .nyc-disc {
    position: fixed;
    width: clamp(300px, 50vh, 580px);
    height: clamp(300px, 50vh, 580px);
    background: var(--color-burnt-amber);
    border-radius: 50%;
    top: 3vh;
    left: -14%;
    z-index: 2;
  }

  /* ── Fixed hero text — z:1 ─────────────────── */

  html[data-event="nyc"] .nyc-hero-text {
    position: fixed;
    top: 80px;           /* just below the sticky header */
    right: 64px;
    z-index: 1;
    text-align: right;
    /* No background-color — cream body shows through. */
  }

  html[data-event="nyc"] .nyc-hero-text h1 {
    font-size: clamp(48px, 8vw, 112px);
    line-height: 0.93;
    color: var(--color-dark-moss);
    text-transform: uppercase;
    font-weight: 500;
    /*
      Each <br> creates a hard line break.
      white-space: nowrap prevents soft wrap within each line,
      so "New York" stays on line 1 and "With Love" on line 2.
    */
    white-space: nowrap;
    margin-bottom: 16px;
  }

  html[data-event="nyc"] .nyc-date {
    font-size: 20px;
    letter-spacing: 0.05em;
    color: var(--color-dark-moss);
    margin-bottom: 16px;
    white-space: nowrap;
  }

  html[data-event="nyc"] .nyc-rule {
    border: none;
    border-top: 1px solid rgba(23, 50, 11, 0.3);
    margin: 16px 0;
  }

  html[data-event="nyc"] .nyc-venue {
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(23, 50, 11, 0.55);
    white-space: nowrap;
  }

  /* ── Spacer ─────────────────────────────────── */

  html[data-event="nyc"] .nyc-spacer {
    /*
      Pushes the skyline down so the heading is readable before scrolling.
      Header (~56px) + heading + date + venue ≈ 350–400px total fixed content.
      A 40vh spacer gives comfortable breathing room.
    */
    height: 40vh;
  }

  /* ── Skyline — z:3, scrolls over fixed text ── */

  html[data-event="nyc"] .nyc-skyline-wrap {
    position: relative;
    z-index: 3;
    /* 5px bleed on left/right to avoid edge artifacting */
    width: calc(100% + 10px);
    margin-left: -5px;
    height: clamp(220px, 48vh, 520px);
    /* No overflow:hidden — building tops overflow upward into cream (transparent sky is invisible) */
  }

  html[data-event="nyc"] .nyc-skyline-img {
    position: absolute;
    bottom: -5px; /* 5px bleed at bottom eliminates hairline against moss section */
    left: 0;
    width: 100%;
    height: auto;
    display: block;
  }

  /* Inline SVG fill — currentColor picks up the wrapper color */
  html[data-event="nyc"] .nyc-skyline-fill {
    color: var(--color-dark-moss);
  }

  html[data-event="nyc"] .nyc-skyline-fill svg {
    display: block;
    width: 100%;
    height: auto;
    color: inherit;
  }

  /* In light mode, only show the filled skyline */
  html[data-event="nyc"] .nyc-skyline-outline {
    display: none;
  }

  /* ── Moss zone — z:4 ────────────────────────── */

  html[data-event="nyc"] .nyc-moss {
    background: var(--color-dark-moss) !important;
    color: var(--color-warm-cream) !important;
    position: relative;
    z-index: 4;
  }

  html[data-event="nyc"] .nyc-info {
    padding: 64px 0;
  }

  /* .nyc-info-inner uses page-content class for centering — no override needed */

  html[data-event="nyc"] .nyc-info-table {
    margin-bottom: 0;
  }

  html[data-event="nyc"] .nyc-info-row {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 249, 240, 0.15);
    align-items: baseline;
  }

  html[data-event="nyc"] .nyc-info-key {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 249, 240, 0.45);
    padding-top: 3px;
  }

  html[data-event="nyc"] .nyc-info-val {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-warm-cream);
  }

  html[data-event="nyc"] .nyc-info-secondary {
    display: block;
    font-size: 12px;
    color: rgba(255, 249, 240, 0.45);
    margin-top: 4px;
  }

  html[data-event="nyc"] .nyc-calendar {
    padding: 32px 0 24px;
  }

  html[data-event="nyc"] .nyc-calendar-band {
    padding: 16px 64px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-warm-cream) !important;
    color: var(--color-dark-moss) !important;
  }

  html[data-event="nyc"] .nyc-calendar-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 32px;
    align-items: end;
    padding-top: 8px;
  }

  html[data-event="nyc"] .nyc-calendar-copy {
    max-width: 420px;
  }

  html[data-event="nyc"] .nyc-calendar-label {
    margin: 0 0 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 249, 240, 0.45);
  }

  html[data-event="nyc"] .nyc-calendar-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-warm-cream);
  }

  html[data-event="nyc"] .nyc-calendar-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  html[data-event="nyc"] .nyc-calendar-btn,
  html[data-event="nyc"] .nyc-calendar-actions .calendar-btn-prominent {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 12px 32px;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    background: var(--color-burnt-amber);
    color: var(--color-warm-cream);
    font-style: normal;
    line-height: 1;
    border: none;
    transition: opacity 0.15s;
  }

  html[data-event="nyc"] .nyc-calendar-btn:hover,
  html[data-event="nyc"] .nyc-calendar-actions .calendar-btn-prominent:hover {
    opacity: 0.85;
    color: var(--color-warm-cream);
  }

  html[data-event="nyc"] .nyc-calendar-btn:disabled,
  html[data-event="nyc"] .nyc-calendar-actions .calendar-btn-prominent:disabled {
    opacity: 0.42;
    cursor: not-allowed;
  }

  html[data-event="nyc"] .nyc-calendar-note {
    margin: 0;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(255, 249, 240, 0.45);
    max-width: 260px;
  }

  html[data-event="nyc"] .nyc-explore-band {
    padding: 16px 64px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-warm-cream) !important;
    color: var(--color-dark-moss) !important;
  }

  html[data-event="nyc"] .nyc-nav {
    padding: 24px 0;
  }

  html[data-event="nyc"] .nyc-strip-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid rgba(255, 249, 240, 0.15);
    text-decoration: none;
    color: var(--color-warm-cream);
    transition: color 0.15s;
  }

  html[data-event="nyc"] .nyc-strip-link:first-child {
    border-top: 1px solid rgba(255, 249, 240, 0.15);
  }

  html[data-event="nyc"] .nyc-strip-link:hover { color: var(--color-burnt-amber); }

  html[data-event="nyc"] .nyc-strip-title {
    font-size: 20px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  html[data-event="nyc"] .nyc-strip-desc {
    font-size: 12px;
    color: rgba(255, 249, 240, 0.45);
    text-align: right;
  }

  html[data-event="nyc"] .nyc-strip-arrow { color: var(--color-burnt-amber); }

  html[data-event="nyc"] .nyc-strip-cta .nyc-strip-title { color: var(--color-burnt-amber); }

  html[data-event="nyc"] .nyc-footer {
    border-top-color: rgba(255, 249, 240, 0.12) !important;
  }

  html[data-event="nyc"] .nyc-footer nav a,
  html[data-event="nyc"] .nyc-footer nav span,
  html[data-event="nyc"] .nyc-footer .copyright {
    color: rgba(255, 249, 240, 0.4) !important;
  }

  html[data-event="nyc"] .nyc-footer nav a:hover {
    color: var(--color-warm-cream) !important;
  }

  html[data-event="nyc"] .nyc-footer-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 8px;
  }

  /* ── Dark mode ──────────────────────────────── */

  @media (prefers-color-scheme: dark) {
    /*
      Dark mode colour logic:
        - Sky (above skyline) = lighter moss var(--color-dark-moss) — so the amber disc pops
        - Skyline + body sections below it = skyline-matched dark var(--color-nyc-skyline-dark)
    */

    html[data-event="nyc"] body {
      background: var(--color-dark-moss) !important;
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .nyc-header {
      background: var(--color-dark-moss) !important;
      border-bottom-color: rgba(255, 249, 240, 0.08) !important;
    }

    html[data-event="nyc"] .nyc-header .site-logo,
    html[data-event="nyc"] .nyc-header .site-logo:hover,
    html[data-event="nyc"] .nyc-header .event-toggle .active,
    html[data-event="nyc"] .nyc-header .event-toggle .divider {
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .nyc-header .event-toggle a {
      color: rgba(255, 249, 240, 0.45) !important;
    }

    /* RSVP button: system orange CTA in dark mode */
    html[data-event="nyc"] .nyc-rsvp-btn {
      background: var(--color-burnt-amber) !important;
      color: var(--color-warm-cream) !important;
    }

    /* Disc: full system orange — no dimming */
    /* (background: var(--color-burnt-amber) already set in light mode styles, no override needed) */

    /* Hero text: cream */
    html[data-event="nyc"] .nyc-hero-text h1,
    html[data-event="nyc"] .nyc-date {
      color: var(--color-warm-cream) !important;
    }

    html[data-event="nyc"] .nyc-rule {
      border-top-color: rgba(255, 249, 240, 0.15) !important;
    }

    html[data-event="nyc"] .nyc-venue {
      color: rgba(255, 249, 240, 0.45) !important;
    }

    /* Skyline: filled, darkened so it reads as a horizon against the lighter sky */
    html[data-event="nyc"] .nyc-skyline-fill {
      display: block;
      filter: none;
      color: var(--color-nyc-skyline-dark);
    }

    html[data-event="nyc"] .nyc-skyline-outline {
      display: none;
    }

    /* Body sections below skyline: deep dark moss */
    html[data-event="nyc"] .nyc-moss {
      background: var(--color-nyc-skyline-dark) !important;
      color: var(--color-warm-cream) !important;
    }

    /* Section bands: pull the lighter sky-green into the moss zone for contrast */
    html[data-event="nyc"] .nyc-calendar-band,
    html[data-event="nyc"] .nyc-explore-band {
      background: var(--color-dark-moss) !important;
      color: var(--color-warm-cream) !important;
      border-top: 1px solid rgba(255, 249, 240, 0.06);
      border-bottom: 1px solid rgba(255, 249, 240, 0.06);
    }

    /* Table rows: softer borders */
    html[data-event="nyc"] .nyc-info-row {
      border-bottom-color: rgba(255, 249, 240, 0.08) !important;
    }

    /* Strip links */
    html[data-event="nyc"] .nyc-strip-link {
      border-bottom-color: rgba(255, 249, 240, 0.08) !important;
    }

    html[data-event="nyc"] .nyc-strip-link:first-child {
      border-top-color: rgba(255, 249, 240, 0.08) !important;
    }
  }

  /* ── Mobile ─────────────────────────────────── */

  @media (max-width: 768px) {
    html[data-event="nyc"] .nyc-disc {
      /* Smaller disc so it doesn't obscure hero text on narrow screens */
      width: clamp(160px, 50vw, 260px);
      height: clamp(160px, 50vw, 260px);
      left: -18%;
      top: 72px; /* slightly behind mobile header for ~5% overlap */
    }

    html[data-event="nyc"] .nyc-hero-text {
      top: 30vh;
      right: 24px;
    }

    html[data-event="nyc"] .nyc-hero-text h1 {
