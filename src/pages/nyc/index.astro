---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { features } from '../../config/features';
import { generateToken } from '../../lib/calendar';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';

const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const guestId = Astro.locals.guestId;
const calendarToken = (features.nyc.calendarSubscribe && guestId)
  ? generateToken(guestId)
  : null;
const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.nyc.pageTitle)} description="NYC Wedding - October 2026" event="nyc">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        {showEventToggle && (
          <div class="event-toggle">
            <span class="active">{t(strings.global.toggle.nyc)}</span>
            <span class="divider">|</span>
            <a href="/france">{t(strings.global.toggle.france)}</a>
          </div>
        )}
        <a href="/nyc/rsvp" class="btn btn-primary rsvp-btn">{t(strings.global.rsvpBtn)}</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <ImagePlaceholder
        name="nyc-hero"
        folder="nyc"
        description="NYC skyline at dusk, or the venue exterior if available. Sets the urban, elegant tone."
        aspectRatio="16/9"
      />
      <div class="hero-overlay">
        <h1>{t(strings.nyc.heroTitle)}</h1>
        <p class="date">{t(strings.nyc.heroDate)} <span class="tentative">{t(strings.nyc.heroDateTentative)}</span></p>
        <p class="event-type">{t(strings.nyc.heroEventType)}</p>
      </div>
    </section>

    <!-- Quick Info Section -->
    <section class="quick-info">
      <div class="info-cards">
        <div class="content-box info-card">
          <h3>{t(strings.nyc.when.heading)}</h3>
          <p><strong>{t(strings.nyc.when.date)}</strong></p>
          {t(strings.nyc.when.weekend) && <p>{t(strings.nyc.when.weekend)}</p>}
          {t(strings.nyc.when.note) && <p class="note"><em>{t(strings.nyc.when.note)}</em></p>}
        </div>
        <div class="content-box info-card">
          <h3>{t(strings.nyc.where.heading)}</h3>
          <p><strong>{t(strings.nyc.where.dinner)}</strong></p>
          <p>{t(strings.nyc.where.dinnerType)}</p>
          <p class="separator">{t(strings.nyc.where.separator)}</p>
          <p><strong>{t(strings.nyc.where.dancing)}</strong></p>
        </div>
        <div class="content-box info-card">
          <h3>{t(strings.nyc.dressCode.heading)}</h3>
          <p><strong>{t(strings.nyc.dressCode.value)}</strong></p>
          <p class="dress-note">{t(strings.nyc.dressCode.note)}</p>
        </div>
      </div>
    </section>

    <!-- Calendar Subscribe (Prominent) -->
    <section class="calendar-subscribe">
      <div class="calendar-content">
        <h2>{t(strings.nyc.calendar.heading)}</h2>
        <p>{t(strings.nyc.calendar.subtext)}</p>
        {calendarToken ? (
          <a
            href={`webcal://${Astro.url.host}/api/calendar/${calendarToken}.ics`}
            class="calendar-btn-prominent"
          >
            {t(strings.nyc.calendar.addBtn)}
          </a>
        ) : (
          <>
            <button class="calendar-btn-prominent" disabled>{t(strings.nyc.calendar.addBtn)}</button>
            <p class="calendar-note">{t(strings.nyc.calendar.unavailableNote)}</p>
          </>
        )}
      </div>
    </section>

    <!-- Navigation Cards -->
    <section class="nav-cards">
      <nav class="event-nav" aria-label="Event sections">
        <a href="/nyc/details" class="nav-card">
          <span class="nav-title">{t(strings.nyc.nav.details.title)}</span>
          <span class="nav-desc">{t(strings.nyc.nav.details.desc)}</span>
        </a>
        <a href="/nyc/travel" class="nav-card">
          <span class="nav-title">{t(strings.nyc.nav.travel.title)}</span>
          <span class="nav-desc">{t(strings.nyc.nav.travel.desc)}</span>
        </a>
        <a href="/nyc/rsvp" class="nav-card highlight">
          <span class="nav-title">{t(strings.nyc.nav.rsvp.title)}</span>
          <span class="nav-desc">{t(strings.nyc.nav.rsvp.desc)}</span>
        </a>
      </nav>
    </section>

    <!-- Venue Preview -->
    <section class="venue-preview">
      <div class="venue-grid">
        <ImagePlaceholder
          name="nyc-venue"
          folder="nyc"
          description="Interior of the dinner venue — cocktail atmosphere, table settings, or similar aesthetic."
          aspectRatio="4/3"
        />
        <ImagePlaceholder
          name="nyc-dancing"
          folder="nyc"
          description="Dancing venue interior, or a mood-board style image showing the vibe (low lighting, celebration)."
          aspectRatio="4/3"
        />
      </div>
    </section>

    <!-- Optional Weekend Events -->
    <section class="optional-events">
      <h2>{t(strings.nyc.optional.heading)}</h2>
      <p class="placeholder-note">{t(strings.nyc.optional.placeholder)}</p>
    </section>
  </main>

  <footer class="site-footer">
    <nav>
      <a href="/registry">{t(strings.global.registry)}</a>
      <span> · </span>
      <span class="guest-name">{guest}</span>
      <span> · </span>
      <a href="/api/logout">{t(strings.global.logout)}</a>
    </nav>
    <div class="footer-meta">
      <p class="copyright">{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
  }

  .hero-overlay {
    padding: var(--space-xl) var(--page-margin);
    text-align: center;
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .date {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-xs);
  }

  .event-type {
    font-size: var(--font-size-body);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
  }

  .tentative {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
  }

  /* Quick Info */
  .quick-info {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .info-card p {
    margin-bottom: var(--space-xs);
  }

  .info-card .separator {
    font-size: var(--font-size-caption);
    color: var(--color-surface-text);
    opacity: 0.7;
  }

  .info-card .note {
    font-size: var(--font-size-caption);
    color: var(--color-accent);
    margin-top: var(--space-xs);
  }

  .dress-note {
    font-size: var(--font-size-caption);
    opacity: 0.7;
  }

  /* Calendar Subscribe */
  .calendar-subscribe {
    padding: var(--space-lg) var(--page-margin);
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .calendar-content {
    padding: var(--space-lg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .calendar-content > p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .calendar-btn-prominent {
    display: inline-block;
    text-decoration: none;
  }

  .calendar-note {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  /* Navigation Cards */
  .nav-cards {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .event-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-sm);
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    transition: border-color 0.15s;
    text-align: center;
  }

  .nav-card:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .nav-card.highlight {
    border-color: var(--color-text);
    border-width: 2px;
  }

  .nav-title {
    font-size: var(--font-size-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    margin-bottom: var(--space-xs);
  }

  .nav-desc {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
  }

  /* Venue Preview */
  .venue-preview {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .venue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  /* Optional Events */
  .optional-events {
    padding: var(--space-lg) var(--page-margin);
    max-width: var(--content-max-width);
    margin: 0 auto;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .optional-events h2 {
    margin-bottom: var(--space-sm);
  }

  .placeholder-note {
    color: var(--color-text-muted);
  }

  /* RSVP button in nav */
  .rsvp-btn {
    padding: 8px 24px;
    font-size: var(--font-size-caption);
  }

  /* Footer */
  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: var(--space-xs);
  }

  @media (max-width: 768px) {
    .hero-overlay {
      padding: var(--space-lg) var(--page-margin-mobile);
    }

    .site-nav {
      flex-direction: column;
      text-align: center;
      gap: var(--space-sm);
    }

    .nav-actions {
      flex-direction: column;
    }
  }
</style>
