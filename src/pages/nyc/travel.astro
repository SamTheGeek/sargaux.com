---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';

const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.nyc.travel.pageTitle)} event="nyc">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <a href="/nyc" class="back-link">{t(strings.nav.backToNyc)}</a>
    </nav>
  </header>

  <main>
    <h1>{t(strings.nyc.travel.heading)}</h1>
    <p class="subtitle">{t(strings.nyc.travel.subtitle)}</p>

    <section class="travel-sections">
      <!-- Hotels -->
      <div class="travel-card">
        <h2>{t(strings.nyc.travel.hotels.heading)}</h2>
        <p>{t(strings.nyc.travel.hotels.intro)}</p>
        <ul>
          <li>{t(strings.nyc.travel.hotels.hotel1)}</li>
          <li>{t(strings.nyc.travel.hotels.hotel2)}</li>
        </ul>
        <p class="placeholder-note">{t(strings.nyc.travel.hotels.roomBlock)}</p>
      </div>

      <!-- Getting There -->
      <div class="travel-card">
        <h2>{t(strings.nyc.travel.gettingThere.heading)}</h2>

        <h3>{t(strings.nyc.travel.gettingThere.air.heading)}</h3>
        <ul>
          <li>{t(strings.nyc.travel.gettingThere.air.jfk)}</li>
          <li>{t(strings.nyc.travel.gettingThere.air.lga)}</li>
          <li>{t(strings.nyc.travel.gettingThere.air.ewr)}</li>
        </ul>

        <h3>{t(strings.nyc.travel.gettingThere.train.heading)}</h3>
        <p>{t(strings.nyc.travel.gettingThere.train.text)}</p>

        <h3>{t(strings.nyc.travel.gettingThere.bus.heading)}</h3>
        <p>{t(strings.nyc.travel.gettingThere.bus.intro)}</p>
        <ul>
          <li>{t(strings.nyc.travel.gettingThere.bus.vamoose)}</li>
          <li>{t(strings.nyc.travel.gettingThere.bus.tripper)}</li>
        </ul>
      </div>

      <!-- Getting Around -->
      <div class="travel-card">
        <h2>{t(strings.nyc.travel.gettingAround.heading)}</h2>

        <h3>{t(strings.nyc.travel.gettingAround.subway.heading)}</h3>
        <p>{t(strings.nyc.travel.gettingAround.subway.intro)}</p>
        <ul>
          <li>{t(strings.nyc.travel.gettingAround.subway.fare)}</li>
          <li>{t(strings.nyc.travel.gettingAround.subway.maps)}</li>
        </ul>

        <h3>{t(strings.nyc.travel.gettingAround.parking.heading)}</h3>
        <p>{t(strings.nyc.travel.gettingAround.parking.text)}</p>
      </div>

      <!-- While You're Here -->
      <div class="travel-card">
        <h2>{t(strings.nyc.travel.whileHere.heading)}</h2>
        <p>{t(strings.nyc.travel.whileHere.intro)}</p>

        <h3>{t(strings.nyc.travel.whileHere.museums.heading)}</h3>
        <ul>
          <li>{t(strings.nyc.travel.whileHere.museums.met)}</li>
          <li>{t(strings.nyc.travel.whileHere.museums.moma)}</li>
          <li>{t(strings.nyc.travel.whileHere.museums.whitney)}</li>
          <li>{t(strings.nyc.travel.whileHere.museums.naturalHistory)}</li>
          <li>{t(strings.nyc.travel.whileHere.museums.guggenheim)}</li>
        </ul>

        <h3>{t(strings.nyc.travel.whileHere.exhibitions.heading)}</h3>
        <p class="placeholder-note">{t(strings.nyc.travel.whileHere.exhibitions.placeholder)}</p>

      </div>
    </section>
  </main>

  <footer>
    <div class="footer-row">
      <p>{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
  }

main {
    flex: 1;
    padding: 3rem 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }

  .travel-sections {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .travel-card {
    border: 1px solid var(--color-border);
    padding: 1.5rem;
  }

  .travel-card h2 {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .travel-card h3 {
    font-size: 1.125rem;
    font-weight: 500;
    margin: 1.5rem 0 0.75rem;
    color: var(--color-text);
  }

  .travel-card h3:first-of-type {
    margin-top: 0.5rem;
  }

  .travel-card p {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .travel-card ul {
    margin: 0.5rem 0 1rem;
    padding-left: 1.5rem;
  }

  .travel-card li {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .placeholder-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  footer {
    padding: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }

  .footer-row p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
