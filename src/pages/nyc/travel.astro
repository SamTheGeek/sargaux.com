---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { features } from '../../config/features';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';

const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.nyc.travel.pageTitle)} fullTitle="Chez Sargaux | NYC — Travel" event="nyc" page="travel">

  <!-- Amber disc — z:2, persists from index page -->
  <div class="nyc-disc" aria-hidden="true" transition:name="event-disc"></div>

  <!-- Sticky header -->
  <header class="site-header nyc-header" transition:name="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo" transition:name="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        {showEventToggle && (
          <div class="event-toggle" transition:name="event-toggle">
            <span class="active event-toggle-item event-toggle-item--nyc">{t(strings.global.toggle.nyc)}</span>
            <span class="divider">|</span>
            <a href="/france" class="event-toggle-item event-toggle-item--france">{t(strings.global.toggle.france)}</a>
          </div>
        )}
        <a href="/nyc/rsvp" class="btn nyc-rsvp-btn" transition:name="header-rsvp">{t(strings.global.rsvpBtn)}</a>
      </div>
    </nav>
  </header>

  <!-- Cream hero — right-aligned composition for travel -->
  <div class="details-hero travel-hero">
    <div class="page-content travel-hero-inner">
      <a href="/nyc" class="details-back">{t(strings.nav.backToEvent)}</a>
      <h1>{t(strings.nyc.travel.heading)}</h1>
      <p class="details-date">{t(strings.nyc.travel.subtitle)}</p>
    </div>
  </div>

  <!-- ═══════ Moss zone ═══════ -->

  <!-- Hotels -->
  <div class="nyc-moss details-band">{t(strings.nyc.travel.hotels.heading)}</div>
  <section class="nyc-moss details-section">
    <div class="page-content">
      <div class="nyc-info-table">
        {!features.nyc.wytheSoldOut && (
          <div class="nyc-info-row">
            <span class="nyc-info-key">Wythe Hotel</span>
            <span class="nyc-info-val nyc-info-val--stack">
              <span>{t(strings.nyc.travel.hotels.hotel1)} <a class="nyc-info-address" href="https://maps.app.goo.gl/kYLuYNuMUKNwkGRQA" target="_blank" rel="noopener">80 Wythe Avenue, Brooklyn, NY 11249</a></span>
              <a class="nyc-info-link--cta" href="https://app.mews.com/distributor/6b87e134-8c75-468a-82d4-aca900c43c70?mewsAvailabilityBlockId=81019661-425a-4bba-a1ff-b3fc0120bbfc&mewsStart=2026-10-10&mewsEnd=2026-10-12" target="_blank" rel="noopener">{t(strings.nyc.travel.hotels.hotel1BookNow)}</a>
            </span>
          </div>
        )}
        {!features.nyc.arloSoldOut && (
          <div class="nyc-info-row">
            <span class="nyc-info-key">Arlo Williamsburg</span>
            <span class="nyc-info-val nyc-info-val--stack">
              <span>{t(strings.nyc.travel.hotels.hotel2)} <a class="nyc-info-address" href="https://maps.app.goo.gl/d65Gn17JYfJHy4hB6" target="_blank" rel="noopener">96 Wythe Avenue, Brooklyn</a></span>
              <a class="nyc-info-link--cta" href="https://be.synxis.com/?Hotel=41850&Chain=19470&arrive=2026-10-10&depart=2026-10-12&adult=1&child=0&group=261010ANCE" target="_blank" rel="noopener">{t(strings.nyc.travel.hotels.hotel2BookNow)}</a>
            </span>
          </div>
        )}
        {!features.nyc.sevilleSoldOut && (
          <div class="nyc-info-row">
            <span class="nyc-info-key">Hotel Seville NoMad</span>
            <span class="nyc-info-val nyc-info-val--stack">
              <span>{t(strings.nyc.travel.hotels.hotel3)} <a class="nyc-info-address" href="https://maps.app.goo.gl/XtUmtf1KYhEVdCjt7" target="_blank" rel="noopener">22 E 29th St, New York, NY</a></span>
              <a class="nyc-info-link--cta" href="https://www.hyatt.com/events/en-US/group-booking/NYCUD/G-MBO0" target="_blank" rel="noopener">{t(strings.nyc.travel.hotels.hotel3BookNow)}</a>
            </span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Getting There (formerly Getting Around) -->
  <div class="nyc-moss details-band">{t(strings.nyc.travel.gettingThere.heading)}</div>
  <section class="nyc-moss details-section">
    <div class="page-content">
      <div class="nyc-info-table">
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.travel.gettingAround.subway.heading)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.travel.gettingAround.subway.intro)}
            <span class="travel-list">
              <span>{t(strings.nyc.travel.gettingAround.subway.fare)}</span>
              <span>{t(strings.nyc.travel.gettingAround.subway.maps)}</span>
            </span>
          </span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.travel.gettingAround.parking.heading)}</span>
          <span class="nyc-info-val">{t(strings.nyc.travel.gettingAround.parking.text)}</span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">By Bike</span>
          <span class="nyc-info-val">A CitiBike station is located just steps from the Wythe Hotel</span>
        </div>
      </div>
    </div>
  </section>

  <!-- While You're Here -->
  <div class="nyc-moss details-band">{t(strings.nyc.travel.whileHere.heading)}</div>
  <section class="nyc-moss details-section">
    <div class="page-content">
      <div class="nyc-info-table">
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.travel.whileHere.museums.heading)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.travel.whileHere.intro)}
            <span class="travel-list">
              <span>{t(strings.nyc.travel.whileHere.museums.met)}</span>
              <span>{t(strings.nyc.travel.whileHere.museums.moma)}</span>
              <span>{t(strings.nyc.travel.whileHere.museums.whitney)}</span>
              <span>{t(strings.nyc.travel.whileHere.museums.naturalHistory)}</span>
              <span>{t(strings.nyc.travel.whileHere.museums.guggenheim)}</span>
            </span>
          </span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.travel.whileHere.exhibitions.heading)}</span>
          <span class="nyc-info-val nyc-info-val--muted">{t(strings.nyc.travel.whileHere.exhibitions.placeholder)}</span>
        </div>
        <div class="nyc-info-row">
          <span class="nyc-info-key">{t(strings.nyc.travel.whileHere.cycling.heading)}</span>
          <span class="nyc-info-val">
            {t(strings.nyc.travel.whileHere.cycling.body)}{' '}
            <a class="nyc-info-link" href="https://ridewithgps.com/routes/54409165?privacy_code=KshzTPHp7mi0yNFE4vWgB8nLIRlb69QY" target="_blank" rel="noopener">{t(strings.nyc.travel.whileHere.cycling.linkText)}</a>{' '}
            {t(strings.nyc.travel.whileHere.cycling.bodyAfter)}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="nyc-moss nyc-footer site-footer">
    <nav>
      <a href="/registry">{t(strings.global.registry)}</a>
      <span> · </span>
      <span class="guest-name">{guest}</span>
      <span> · </span>
      <a href="/api/logout">{t(strings.global.logout)}</a>
    </nav>
    <div class="nyc-footer-meta">
      <p class="copyright">{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>

</WireframeLayout>

<style is:global>

  /* ── Foundation ──────────────────────────────────── */

  html[data-event="nyc"] body {
    background: #F1ECE3 !important;
    color: #2F3F36 !important;
    overflow-x: hidden;
  }

  /* ── Header ──────────────────────────────────────── */

  html[data-event="nyc"] .nyc-header {
    background: #F1ECE3 !important;
    border-bottom: 1px solid rgba(47, 63, 54, 0.18) !important;
  }

  html[data-event="nyc"] .nyc-header .site-logo,
  html[data-event="nyc"] .nyc-header .site-logo:hover,
  html[data-event="nyc"] .nyc-header .event-toggle .active,
  html[data-event="nyc"] .nyc-header .event-toggle .divider {
    color: #2F3F36 !important;
  }

  html[data-event="nyc"] .nyc-header .event-toggle a {
    color: rgba(47, 63, 54, 0.4) !important;
  }

  html[data-event="nyc"] .nyc-rsvp-btn {
    background: #2F3F36 !important;
    color: #F1ECE3 !important;
    height: 32px;
    padding: 0 24px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    line-height: 1;
    transition: opacity 0.15s;
    border: none;
  }

  html[data-event="nyc"] .nyc-rsvp-btn:hover {
    opacity: 0.85;
    color: #F1ECE3 !important;
  }

  /* ── Amber disc — z:2 ────────────────────────────── */

  html[data-event="nyc"] .nyc-disc {
    position: fixed;
    width: clamp(300px, 50vh, 580px);
    height: clamp(300px, 50vh, 580px);
    background: #D96A1E;
    border-radius: 50%;
    top: 3vh;
    left: -14%;
    z-index: 2;
  }

  /* ── Cream hero ──────────────────────────────────── */

  html[data-event="nyc"] .details-hero {
    position: relative;
    z-index: 3;
    min-height: 38vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 48px;
  }

  html[data-event="nyc"] .details-hero-inner {
    width: 100%;
  }

  /* Travel hero: right-aligned stack */
  html[data-event="nyc"] .travel-hero-inner {
    width: 100%;
    text-align: right;
  }

  /* Disc on the right for travel page */
  html[data-event="nyc"][data-page="travel"] .nyc-disc {
    left: auto !important;
    right: -8% !important;
  }

  html[data-event="nyc"] .details-back {
    display: inline-block;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #2F3F36;
    text-decoration: none;
    margin-bottom: 24px;
    transition: opacity 0.15s;
  }

  html[data-event="nyc"] .details-back:hover {
    opacity: 0.6;
  }

  html[data-event="nyc"] .details-hero h1 {
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 500;
    line-height: 0.93;
    color: #2F3F36;
    text-transform: uppercase;
    margin: 0 0 20px;
    white-space: nowrap;
  }

  html[data-event="nyc"] .details-date {
    font-size: 16px;
    letter-spacing: 0.05em;
    color: rgba(47, 63, 54, 0.55);
    margin: 0;
    text-transform: uppercase;
  }

  /* ── Moss zone — z:4 ─────────────────────────────── */

  html[data-event="nyc"] .nyc-moss {
    background: #2F3F36 !important;
    color: #F1ECE3 !important;
    position: relative;
    z-index: 4;
  }

  html[data-event="nyc"] .details-band {
    padding: 14px 64px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: #F1ECE3 !important;
    color: rgba(47, 63, 54, 0.5) !important;
    border-top: 1px solid rgba(47, 63, 54, 0.1);
  }

  html[data-event="nyc"] .details-section {
    padding: 40px 0 48px;
  }

  /* ── Info table ──────────────────────────────────── */

  html[data-event="nyc"] .nyc-info-table {
    margin: 0;
  }

  html[data-event="nyc"] .nyc-info-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid rgba(241, 236, 227, 0.15);
    align-items: baseline;
  }

  html[data-event="nyc"] .nyc-info-row:first-child {
    border-top: 1px solid rgba(241, 236, 227, 0.15);
  }

  html[data-event="nyc"] .nyc-info-key {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(241, 236, 227, 0.45);
    padding-top: 3px;
  }

  html[data-event="nyc"] .nyc-info-val {
    font-size: 16px;
    line-height: 1.6;
    color: #F1ECE3;
  }

  html[data-event="nyc"] .nyc-info-val--muted {
    font-size: 14px;
    color: rgba(241, 236, 227, 0.4);
    font-style: italic;
  }

  html[data-event="nyc"] .nyc-info-val--stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }

  html[data-event="nyc"] .nyc-info-secondary {
    display: block;
    font-size: 12px;
    color: rgba(241, 236, 227, 0.45);
    margin-top: 4px;
  }

  html[data-event="nyc"] .nyc-info-address {
    color: rgba(241, 236, 227, 0.75);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  html[data-event="nyc"] .nyc-info-address:hover {
    color: #F1ECE3;
  }

  html[data-event="nyc"] .nyc-info-link {
    display: inline-block;
    margin-top: 6px;
    font-size: 12px;
    color: rgba(241, 236, 227, 0.6);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  html[data-event="nyc"] .nyc-info-link:hover {
    color: #F1ECE3;
  }

  html[data-event="nyc"] .nyc-info-link--cta {
    display: block;
    color: #D96A1E;
    text-decoration: none;
    font-weight: 500;
  }

  html[data-event="nyc"] .nyc-info-link--cta:hover {
    color: #e87a30;
  }

  /* ── Travel list (replaces <ul>) ─────────────────── */

  html[data-event="nyc"] .travel-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 10px;
  }

  html[data-event="nyc"] .travel-list span {
    font-size: 14px;
    color: rgba(241, 236, 227, 0.7);
    line-height: 1.5;
    padding-left: 12px;
    position: relative;
  }

  html[data-event="nyc"] .travel-list span::before {
    content: '—';
    position: absolute;
    left: 0;
    color: rgba(241, 236, 227, 0.3);
    font-size: 11px;
    top: 3px;
  }

  /* ── Footer ──────────────────────────────────────── */

  html[data-event="nyc"] .nyc-footer {
    border-top-color: rgba(241, 236, 227, 0.12) !important;
  }

  html[data-event="nyc"] .nyc-footer nav a,
  html[data-event="nyc"] .nyc-footer nav span,
  html[data-event="nyc"] .nyc-footer .copyright {
    color: rgba(241, 236, 227, 0.4) !important;
  }

  html[data-event="nyc"] .nyc-footer nav a:hover {
    color: #F1ECE3 !important;
  }

  html[data-event="nyc"] .nyc-footer-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 8px;
  }

  /* ── Dark mode ────────────────────────────────────── */

  @media (prefers-color-scheme: dark) {
    html[data-event="nyc"] body {
      background: #2F3F36 !important;
      color: #F1ECE3 !important;
    }

    html[data-event="nyc"] .nyc-header {
      background: #2F3F36 !important;
      border-bottom-color: rgba(241, 236, 227, 0.08) !important;
    }

    html[data-event="nyc"] .nyc-header .site-logo,
    html[data-event="nyc"] .nyc-header .site-logo:hover,
    html[data-event="nyc"] .nyc-header .event-toggle .active,
    html[data-event="nyc"] .nyc-header .event-toggle .divider {
      color: #F1ECE3 !important;
    }

    html[data-event="nyc"] .nyc-header .event-toggle a {
      color: rgba(241, 236, 227, 0.45) !important;
    }

    html[data-event="nyc"] .nyc-rsvp-btn {
      background: #D96A1E !important;
      color: #F1ECE3 !important;
    }

    html[data-event="nyc"] .details-hero h1 {
      color: #F1ECE3 !important;
    }

    html[data-event="nyc"] .details-date {
      color: rgba(241, 236, 227, 0.45) !important;
    }

    html[data-event="nyc"] .details-back {
      color: rgba(241, 236, 227, 0.7) !important;
    }

    html[data-event="nyc"] .nyc-moss {
      background: #18211C !important;
      color: #F1ECE3 !important;
    }

    html[data-event="nyc"] .details-band {
      background: #2F3F36 !important;
      color: rgba(241, 236, 227, 0.4) !important;
      border-top-color: rgba(241, 236, 227, 0.06) !important;
    }

    html[data-event="nyc"] .nyc-info-row {
      border-bottom-color: rgba(241, 236, 227, 0.08) !important;
    }

    html[data-event="nyc"] .nyc-info-row:first-child {
      border-top-color: rgba(241, 236, 227, 0.08) !important;
    }
  }

  /* ── Mobile ───────────────────────────────────────── */

  @media (max-width: 768px) {
    html[data-event="nyc"] .nyc-disc {
      width: clamp(160px, 50vw, 260px);
      height: clamp(160px, 50vw, 260px);
      left: -18%;
      top: 72px;
    }

    html[data-event="nyc"] .details-hero {
      min-height: 28vh;
      padding-bottom: 32px;
    }

    html[data-event="nyc"] .details-hero h1 {
      font-size: clamp(40px, 12vw, 64px);
      white-space: normal;
    }

    html[data-event="nyc"][data-page="travel"] .nyc-disc {
      left: auto !important;
      right: -18% !important;
    }

    html[data-event="nyc"] .details-band {
      padding-left: 24px;
      padding-right: 24px;
    }

    html[data-event="nyc"] .nyc-info-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }

</style>
