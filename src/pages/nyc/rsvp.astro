---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import { getGuestParty, getGuestEvents, getLatestRSVP } from '../../lib/notion';
import { strings } from '../../content/strings';
import { createTranslator } from '../../lib/i18n';
import LangSwitcher from '../../components/LangSwitcher.astro';

const guest = Astro.locals.guest ?? 'Guest';
const guestId = Astro.locals.guestId;

let party: Awaited<ReturnType<typeof getGuestParty>> = [];
let coreEvents: Awaited<ReturnType<typeof getGuestEvents>> = [];
let optionalEvents: Awaited<ReturnType<typeof getGuestEvents>> = [];
let existingRSVP: Awaited<ReturnType<typeof getLatestRSVP>> = null;
let loadError: string | null = null;

if (guestId) {
  try {
    party = await getGuestParty(guestId);
    const events = (await getGuestEvents(guestId)).filter((event) => event.wedding === 'nyc');
    coreEvents = events.filter((event) => event.type === 'Core');
    optionalEvents = events.filter((event) => event.type === 'Optional');
    existingRSVP = await getLatestRSVP(guestId, 'nyc');
  } catch (error) {
    console.error('Failed to load NYC RSVP data:', error);
    loadError = 'We could not load your RSVP details right now. Please refresh and try again.';
  }
}

const primaryGuestEmail = party[0]?.email;

const attendingNames = new Set(
  (existingRSVP?.guestsAttending ?? '')
    .split(',')
    .map((name) => name.trim())
    .filter(Boolean)
);
const selectedEventIds = new Set(existingRSVP?.eventsAttending ?? []);
const existingDetails = existingRSVP?.details ?? {};
const lang = Astro.locals.lang ?? 'en';
const t = createTranslator(lang);
const existingSubmittedAt = existingRSVP?.submittedAt
  ? new Date(existingRSVP.submittedAt).toLocaleString(lang === 'fr' ? 'fr-FR' : 'en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    })
  : null;
---

<WireframeLayout title={t(strings.nyc.rsvp.pageTitle)} event="nyc">
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <a href="/nyc" class="back-link">{t(strings.nav.backToNyc)}</a>
    </nav>
  </header>

  <main>
    <h1>{t(strings.nyc.rsvp.heading)}</h1>
    <p class="subtitle">{t(strings.nyc.rsvp.subtitle)} <span class="tentative">{t(strings.nyc.rsvp.subtitleTentative)}</span></p>

    <div class="deadline-banner">
      <p>{t(strings.nyc.rsvp.deadline)} <strong>{t(strings.nyc.rsvp.deadlineDate)}</strong></p>
    </div>

    {!guestId ? (
      <div class="error-card" data-testid="notion-required">
        <h2>{t(strings.nyc.rsvp.unavailable.heading)}</h2>
        <p>{t(strings.nyc.rsvp.unavailable.text)}</p>
      </div>
    ) : loadError ? (
      <div class="error-card" data-testid="rsvp-load-error">
        <h2>{t(strings.nyc.rsvp.loadError.heading)}</h2>
        <p>{loadError}</p>
      </div>
    ) : (
      <>
        {existingRSVP && (
          <aside class="existing-rsvp-banner" data-testid="existing-rsvp-banner">
            <p>
              {t(strings.nyc.rsvp.existingBanner.prefix)} <strong>{existingSubmittedAt}</strong>.
              {t(strings.nyc.rsvp.existingBanner.suffix)}
            </p>
          </aside>
        )}

        <form class="rsvp-form" id="rsvp-form" data-event="nyc">
          <section class="form-section">
            <h2>{t(strings.nyc.rsvp.form.whosComing.heading)}</h2>
            <p class="section-note">{t(strings.nyc.rsvp.form.whosComing.note)}</p>

            {party.map((partyGuest) => {
              const isAttending =
                attendingNames.size > 0 ? attendingNames.has(partyGuest.name) : !partyGuest.isPlusOne;

              return (
                <div class:list={["guest-row", partyGuest.isPlusOne && 'plus-one']} data-guest-row>
                  <label class="guest-toggle">
                    <input
                      type="checkbox"
                      class="guest-attending"
                      checked={isAttending}
                    />
                    <span class="toggle-slider"></span>
                  </label>
                  <div class="guest-info">
                    <input
                      type="text"
                      class="guest-name"
                      value={partyGuest.name}
                      data-plus-one={partyGuest.isPlusOne ? 'true' : 'false'}
                    />
                    <span class="guest-status">{isAttending ? t(strings.global.attending) : t(strings.global.notAttending)}</span>
                  </div>
                </div>
              );
            })}
          </section>

          <section class="form-section">
            <h2>{t(strings.nyc.rsvp.form.coreEvents.heading)}</h2>
            <p class="section-note">{t(strings.nyc.rsvp.form.coreEvents.note)}</p>
            {coreEvents.length === 0 ? (
              <p class="placeholder-note">{t(strings.nyc.rsvp.form.coreEvents.empty)}</p>
            ) : (
              <div class="event-list">
                {coreEvents.map((event) => (
                  <label class="event-checkbox is-core">
                    <input
                      type="checkbox"
                      class="event-attending"
                      data-event-id={event.id}
                      data-event-type="core"
                      checked={selectedEventIds.size > 0 ? selectedEventIds.has(event.id) : true}
                    />
                    <span class="checkbox-mark"></span>
                    <div class="event-details">
                      <strong>{event.name}</strong>
                      <span class="event-info">{[event.time, event.location].filter(Boolean).join(' · ') || t(strings.global.detailsToCome)}</span>
                    </div>
                  </label>
                ))}
              </div>
            )}
          </section>

          <section class="form-section">
            <h2>{t(strings.nyc.rsvp.form.optionalEvents.heading)}</h2>
            <p class="section-note">{t(strings.nyc.rsvp.form.optionalEvents.note)}</p>

            {optionalEvents.length === 0 ? (
              <p class="placeholder-note" data-testid="no-optional-events">{t(strings.nyc.rsvp.form.optionalEvents.empty)}</p>
            ) : (
              <div class="event-list">
                {optionalEvents.map((event) => (
                  <label class="event-checkbox optional-event">
                    <input
                      type="checkbox"
                      class="event-attending"
                      data-event-id={event.id}
                      data-event-type="optional"
                      checked={selectedEventIds.has(event.id)}
                    />
                    <span class="checkbox-mark"></span>
                    <div class="event-details">
                      <strong>{event.name}</strong>
                      <span class="event-info">{[event.time, event.location].filter(Boolean).join(' · ') || t(strings.global.detailsToCome)}</span>
                    </div>
                  </label>
                ))}
              </div>
            )}
          </section>

          <section class="form-section">
            <h2>{t(strings.nyc.rsvp.form.dietary.heading)}</h2>
            <p class="section-note">{t(strings.nyc.rsvp.form.dietary.note)}</p>
            <textarea
              name="dietary"
              class="text-input"
              placeholder={t(strings.nyc.rsvp.form.dietary.placeholder)}
              rows="3"
            >{existingRSVP?.dietary ?? ''}</textarea>
          </section>

          <section class="form-section">
            <h2>{t(strings.nyc.rsvp.form.songRequest.heading)}</h2>
            <p class="section-note">{t(strings.nyc.rsvp.form.songRequest.note)}</p>
            <input
              type="text"
              name="songRequest"
              class="single-line-input"
              placeholder={t(strings.nyc.rsvp.form.songRequest.placeholder)}
              value={existingDetails.songRequest ?? ''}
            />
          </section>

          <section class="form-section">
            <h2>{t(strings.nyc.rsvp.form.message.heading)}</h2>
            <textarea
              name="message"
              class="text-input"
              placeholder={t(strings.nyc.rsvp.form.message.placeholder)}
              rows="4"
            >{existingRSVP?.message ?? ''}</textarea>
          </section>

          <section class="form-section">
            <h2>{t(strings.nyc.rsvp.form.email.heading)}</h2>
            {!primaryGuestEmail && (
              <div class="email-field">
                <label for="guest-email" class="section-note">{t(strings.nyc.rsvp.form.email.label)} <span class="optional-label">{t(strings.nyc.rsvp.form.email.optional)}</span></label>
                <input
                  type="email"
                  id="guest-email"
                  name="email"
                  class="single-line-input"
                  placeholder={t(strings.nyc.rsvp.form.email.placeholder)}
                  autocomplete="email"
                  data-testid="email-input"
                />
              </div>
            )}
            <label class="checkbox-label">
              <input type="checkbox" id="send-confirmation" name="sendConfirmation" data-testid="send-confirmation-checkbox" />
              <span>{t(strings.nyc.rsvp.form.email.sendConfirmation)}</span>
            </label>
          </section>

          <div class="feedback" aria-live="polite">
            <p id="form-success" class="success-message" hidden>{t(strings.nyc.rsvp.form.successMsg)}</p>
            <p id="form-error" class="error-message" hidden>{t(strings.nyc.rsvp.form.errorMsg)}</p>
          </div>

          <button type="submit" class="submit-btn">{existingRSVP ? t(strings.nyc.rsvp.form.updateBtn) : t(strings.nyc.rsvp.form.submitBtn)}</button>

          <p class="form-note">{t(strings.nyc.rsvp.form.signedInAs)} <strong>{guest}</strong>. {t(strings.nyc.rsvp.form.canUpdate)}</p>
        </form>
      </>
    )}
  </main>

  <footer>
    <div class="footer-row">
      <p>{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
  }

main {
    flex: 1;
    padding: 3rem 2rem;
    max-width: 680px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .tentative {
    font-size: 0.875rem;
    font-style: italic;
  }

  .deadline-banner {
    background: var(--color-bg);
    border: 1px solid var(--color-border);

    padding: 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .existing-rsvp-banner {
    background: var(--color-info-bg);
    border: 1px solid var(--color-info-border);

    padding: 1rem;
    margin-bottom: 1.5rem;
    color: var(--color-info);
  }

  .rsvp-form {
    display: flex;
    flex-direction: column;
  }

  .form-section {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .form-section h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .section-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .guest-row {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.8rem;
    border: 1px solid var(--color-border);

    margin-bottom: 0.75rem;
  }

  .guest-row.plus-one {
    border-style: dashed;
  }

  .guest-toggle {
    position: relative;
    width: 44px;
    height: 24px;
    flex-shrink: 0;
  }

  .guest-toggle input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-slider {
    position: absolute;
    inset: 0;
    background: var(--color-border);
    border-radius: 999px;
    transition: background 0.2s;
  }

  .toggle-slider::before {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    left: 3px;
    top: 3px;
    border-radius: 50%;
    background: var(--color-bg);
    transition: transform 0.2s;
  }

  .guest-toggle input:checked + .toggle-slider {
    background: var(--color-text);
  }

  .guest-toggle input:checked + .toggle-slider::before {
    transform: translateX(20px);
  }

  .guest-info {
    display: flex;
    flex: 1;
    align-items: center;
    gap: 0.75rem;
  }

  .guest-name {
    flex: 1;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    padding: 0.5rem 0.6rem;
    font-size: 0.95rem;
  }

  .guest-status {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    min-width: 90px;
    text-align: right;
  }

  .event-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .event-checkbox {
    display: flex;
    align-items: start;
    gap: 0.65rem;
    padding: 0.85rem;
    border: 1px solid var(--color-border);

    cursor: pointer;
  }

  .event-checkbox.is-core {
    background: var(--color-bg);
  }

  .checkbox-mark {
    width: 18px;
    height: 18px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin-top: 2px;
    flex-shrink: 0;
    position: relative;
  }

  .event-checkbox input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .event-checkbox input:checked + .checkbox-mark::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 1px;
    width: 5px;
    height: 10px;
    border: solid var(--color-text);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .event-details strong {
    display: block;
    margin-bottom: 0.1rem;
  }

  .event-info {
    color: var(--color-text-muted);
    font-size: 0.86rem;
  }

  .placeholder-note {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .single-line-input,
  .text-input {
    width: 100%;
    border: 1px solid var(--color-border);

    padding: 0.7rem 0.75rem;
    font-size: 0.95rem;
    font-family: inherit;
  }

  .feedback {
    margin-top: 1rem;
    min-height: 1.5rem;
  }

  .success-message {
    color: var(--color-success);
    font-size: 0.9rem;
  }

  .error-message {
    color: var(--color-error);
    font-size: 0.9rem;
  }

  .submit-btn {
    margin-top: 0.75rem;
    padding: 0.95rem 1.2rem;
    border: none;

    background: var(--color-text);
    color: var(--color-surface-text);
    font-weight: 600;
    cursor: pointer;
  }

  .submit-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .form-note {
    margin-top: 0.8rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  .email-field {
    margin-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .optional-label {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    cursor: pointer;
  }

  .error-card {
    border: 1px solid var(--color-error-border);
    background: var(--color-error-bg);

    padding: 1rem;
    color: var(--color-error);
  }

  footer {
    padding: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }

  .footer-row p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 768px) {
    main {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .guest-info {
      flex-direction: column;
      align-items: start;
    }

    .guest-status {
      min-width: 0;
      text-align: left;
    }
  }
</style>

<script is:inline>
  const form = document.getElementById('rsvp-form');

  if (form) {
    const submitButton = form.querySelector('button[type="submit"]');
    const successMessage = document.getElementById('form-success');
    const errorMessage = document.getElementById('form-error');

    const updateGuestStatus = (row) => {
      const checkbox = row.querySelector('.guest-attending');
      const status = row.querySelector('.guest-status');
      if (status && checkbox) {
        status.textContent = checkbox.checked ? 'Attending' : 'Not attending';
      }
    };

    const guestRows = form.querySelectorAll('[data-guest-row]');
    guestRows.forEach((row) => {
      updateGuestStatus(row);
      row.querySelector('.guest-attending')?.addEventListener('change', () => updateGuestStatus(row));
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const originalButtonText = submitButton?.textContent || 'Submit RSVP';
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Saving...';
      }
      if (successMessage) successMessage.hidden = true;
      if (errorMessage) errorMessage.hidden = true;

      const anyAttending = Array.from(form.querySelectorAll('.guest-attending')).some((checkbox) => checkbox.checked);

      const guestsAttending = Array.from(form.querySelectorAll('[data-guest-row]')).map((row) => {
        const nameInput = row.querySelector('.guest-name');
        const checkbox = row.querySelector('.guest-attending');
        return {
          name: nameInput?.value?.trim() || 'Guest',
          attending: checkbox?.checked === true,
        };
      });

      const optionalEvents = Array.from(form.querySelectorAll('.event-attending[data-event-type="optional"]'));
      const coreEventIds = Array.from(form.querySelectorAll('.event-attending[data-event-type="core"]')).map((input) => input.dataset.eventId).filter(Boolean);
      const optionalEventIds = optionalEvents
        .filter((input) => input.checked)
        .map((input) => input.dataset.eventId)
        .filter(Boolean);

      const emailInput = form.querySelector('input[name="email"]');
      const sendConfirmationCheckbox = form.querySelector('input[name="sendConfirmation"]');

      const payload = {
        event: form.dataset.event,
        guestsAttending,
        eventsAttending: anyAttending ? [...coreEventIds, ...optionalEventIds] : [],
        dietary: form.querySelector('textarea[name="dietary"]')?.value?.trim() || undefined,
        message: form.querySelector('textarea[name="message"]')?.value?.trim() || undefined,
        details: {
          songRequest: form.querySelector('input[name="songRequest"]')?.value?.trim() || undefined,
        },
        email: emailInput?.value?.trim() || undefined,
        sendConfirmation: sendConfirmationCheckbox?.checked === true,
      };

      try {
        const response = await fetch('/api/rsvp', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          throw new Error('Request failed');
        }

        window.location.href = '/nyc';
      } catch (error) {
        if (errorMessage) errorMessage.hidden = false;
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = originalButtonText;
        }
      }
    });
  }
</script>
