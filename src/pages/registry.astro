---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { strings } from '../content/strings';
import { createTranslator } from '../lib/i18n';
import { getPrimaryEventRoute } from '../lib/event-routing';
import { fetchJoyRegistry, JOY_REGISTRY_URL } from '../lib/joy';
import '../styles/registry.css';

const lang = Astro.locals.lang ?? 'en';
const t = createTranslator(lang);
const guest = Astro.locals.guest;
const eventInvitations = Astro.locals.eventInvitations ?? ['nyc', 'france'];
const showEventToggle = eventInvitations.includes('nyc') && eventInvitations.includes('france');
const singleEventHref = eventInvitations.includes('nyc')
  ? '/nyc'
  : eventInvitations.includes('france')
    ? '/france'
    : null;
const singleEventLabel = eventInvitations.includes('nyc')
  ? 'NYC'
  : eventInvitations.includes('france')
    ? 'France'
    : null;
const homeHref = getPrimaryEventRoute(eventInvitations as ('nyc' | 'france')[]);

function formatPrice(price: number | null, currencyCode: string | null): string | null {
  if (price == null) return null;
  return new Intl.NumberFormat(lang === 'fr' ? 'fr-FR' : 'en-US', {
    style: 'currency',
    currency: currencyCode ?? 'USD',
    minimumFractionDigits: Number.isInteger(price) ? 0 : 2,
  }).format(price);
}

const registry = await fetchJoyRegistry();
const funds = registry?.funds ?? [];
const gifts = (registry?.products ?? []).map((product) => ({
  ...product,
  priceLabel: formatPrice(product.price, product.currencyCode),
}));
const availableGifts = gifts.filter((gift) => gift.stillNeeded > 0);
const claimedGifts = gifts.filter((gift) => gift.stillNeeded === 0);
---

<WireframeLayout title={t(strings.registry.pageTitle)} description="Wedding registry for Sam and Margaux" event="nyc">
  <header class="site-header registry-header" transition:name="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo" transition:name="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        {showEventToggle && (
          <div class="event-toggle" transition:name="event-toggle">
            <a href="/nyc" class="event-toggle-item event-toggle-item--nyc">NYC</a>
            <span class="divider">|</span>
            <a href="/france" class="event-toggle-item event-toggle-item--france">France</a>
          </div>
        )}
        {!showEventToggle && singleEventHref && singleEventLabel && (
          <a href={singleEventHref} class="registry-event-nav-link">{singleEventLabel}</a>
        )}
      </div>
    </nav>
  </header>

  <main class="registry-shell">
    <section class="registry-hero">
      <div class="page-content">
        <h1>{t(strings.registry.heading)}</h1>
        <p class="registry-intro">{t(strings.registry.intro)}</p>
        <hr class="section-rule registry-rule" />
      </div>
    </section>

    {!registry && (
      <section class="registry-section page-content">
        <div class="registry-fallback">
          <h2>{t(strings.registry.fallback.title)}</h2>
          <p>{t(strings.registry.fallback.body)}</p>
          <a href={JOY_REGISTRY_URL} class="registry-joy-link" target="_blank" rel="noopener">
            {t(strings.registry.fallback.cta)}
          </a>
        </div>
      </section>
    )}

    {funds.length > 0 && (
      <section class="registry-section page-content" aria-labelledby="registry-funds-heading">
        <h2 id="registry-funds-heading">{t(strings.registry.fundsHeading)}</h2>
        <div class="registry-grid registry-grid--funds">
          {funds.map((fund) => (
            <article class="registry-card registry-card--fund">
              {fund.photoUrl && (
                <div class="registry-card-photo">
                  <img src={fund.photoUrl} alt="" loading="lazy" />
                </div>
              )}
              <div class="registry-card-body">
                <h3>{fund.title}</h3>
                {fund.description && <p class="registry-card-desc">{fund.description}</p>}
                <a href={JOY_REGISTRY_URL} class="registry-joy-link" target="_blank" rel="noopener">
                  {t(strings.registry.contributeOnJoy)}
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {availableGifts.length > 0 && (
      <section class="registry-section page-content" aria-labelledby="registry-gifts-heading">
        <h2 id="registry-gifts-heading">{t(strings.registry.giftsHeading)}</h2>
        <div class="registry-grid">
          {availableGifts.map((gift) => (
            <article class="registry-card">
              {gift.photoUrl && (
                <div class="registry-card-photo">
                  <img src={gift.photoUrl} alt="" loading="lazy" />
                </div>
              )}
              <div class="registry-card-body">
                <h3>{gift.title}</h3>
                <p class="registry-card-meta">
                  {gift.priceLabel}
                  {gift.priceLabel && gift.storeName && <span class="registry-meta-divider"> · </span>}
                  {gift.storeName}
                </p>
                <a href={JOY_REGISTRY_URL} class="registry-joy-link" target="_blank" rel="noopener">
                  {t(strings.registry.viewOnJoy)}
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {claimedGifts.length > 0 && (
      <section class="registry-section registry-section--claimed page-content" aria-labelledby="registry-claimed-heading">
        <h2 id="registry-claimed-heading">{t(strings.registry.claimedHeading)}</h2>
        <div class="registry-grid">
          {claimedGifts.map((gift) => (
            <article class="registry-card registry-card--claimed">
              {gift.photoUrl && (
                <div class="registry-card-photo">
                  <img src={gift.photoUrl} alt="" loading="lazy" />
                </div>
              )}
              <div class="registry-card-body">
                <h3>{gift.title}</h3>
                <p class="registry-card-meta">
                  <span class="registry-claimed-label">{t(strings.registry.claimedLabel)}</span>
                  {gift.storeName && <span class="registry-meta-divider"> · </span>}
                  {gift.storeName}
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {registry && (
      <section class="registry-section registry-section--outro page-content">
        <a href={JOY_REGISTRY_URL} class="registry-joy-link" target="_blank" rel="noopener">
          {t(strings.registry.fallback.cta)}
        </a>
      </section>
    )}
  </main>

  <SiteFooter guest={guest} lang={lang} homeHref={homeHref} />
</WireframeLayout>
