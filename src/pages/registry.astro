---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { strings } from '../content/strings';
import { createTranslator } from '../lib/i18n';
import LangSwitcher from '../components/LangSwitcher.astro';

const t = createTranslator(Astro.locals.lang ?? 'en');
---

<WireframeLayout title={t(strings.registry.pageTitle)}>
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{t(strings.global.siteName)}</a>
      <div class="nav-actions">
        <a href="/nyc">NYC</a>
        <span>·</span>
        <a href="/france">France</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="hero">
      <ImagePlaceholder
        name="couple-registry"
        folder="couple"
        description="Fun or playful couple photo — could be casual, candid, or showing personality"
        aspectRatio="3/1"
      />
    </section>

    <section class="registry-intro">
      <h1>{t(strings.registry.heading)}</h1>
      <div class="content-box">
        <h3>Intro Message</h3>
        <p>[Personalized message from Sam & Margaux about gifts]</p>
        <p>Example: "Your presence at our celebration is the greatest gift. If you wish to honor us with a gift, we've registered at the following places..."</p>
      </div>
    </section>

    <section class="registry-options">
      <div class="registry-grid">
        <div class="content-box registry-card">
          <h3>Registry Option 1</h3>
          <p><strong>[Store/Service Name]</strong></p>
          <p class="desc">[Brief description — what kind of items]</p>
          <a href="#" class="registry-link">View Registry →</a>
        </div>

        <div class="content-box registry-card">
          <h3>Registry Option 2</h3>
          <p><strong>[Store/Service Name]</strong></p>
          <p class="desc">[Brief description]</p>
          <a href="#" class="registry-link">View Registry →</a>
        </div>

        <div class="content-box registry-card">
          <h3>Honeymoon Fund?</h3>
          <p><em>Decision: Include a honeymoon/experience fund?</em></p>
          <p class="desc">Contribution toward travel, experiences, etc.</p>
        </div>
      </div>
    </section>

    <section class="open-question">
      <div class="content-box highlight">
        <h3>Open Question: French Guests</h3>
        <p><strong>How do we handle registry for French guests?</strong></p>
        <ul>
          <li>Different registry service available in France/EU?</li>
          <li>Currency considerations (€ vs $)?</li>
          <li>Shipping logistics?</li>
        </ul>
        <p class="note">Note: Ask Alice for input</p>
      </div>
    </section>

    <section class="shipping-note">
      <div class="content-box">
        <h3>Shipping Information</h3>
        <p><em>Decision: Include shipping address or instructions?</em></p>
        <p>Options:</p>
        <ul>
          <li>Ship directly through registry</li>
          <li>Provide a shipping address</li>
          <li>Bring to wedding (probably not ideal)</li>
        </ul>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-row">
      <p>{t(strings.global.copyright)}</p>
      <LangSwitcher lang={Astro.locals.lang ?? 'en'} />
    </div>
  </footer>
</WireframeLayout>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
  }

main {
    flex: 1;
  }

  .hero {
    margin-bottom: 2rem;
  }

  .registry-intro {
    padding: 0 2rem 2rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .registry-intro .content-box {
    text-align: left;
  }

  .registry-options {
    padding: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .registry-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .registry-card p {
    margin-bottom: 0.5rem;
  }

  .registry-card .desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .registry-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .registry-card em {
    color: var(--color-accent);
  }

  .open-question,
  .shipping-note {
    padding: 0 2rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .content-box.highlight {
    background: var(--color-info-bg);
    border-color: var(--color-accent);
  }

  .content-box ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .content-box li {
    margin-bottom: 0.5rem;
  }

  .content-box em {
    color: var(--color-accent);
  }

  .note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 500;
    margin-top: 1rem;
  }

  footer {
    padding: 2rem;
    border-top: 1px solid var(--color-border);
    margin-top: 2rem;
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }

  .footer-row p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
</style>
